<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:FreakLete"
             x:Class="FreakLete.HomePage"
             NavigationPage.HasNavigationBar="False"
             Title="">

    <Grid RowDefinitions="*,Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="24,18,24,20"
                                 Spacing="18">

                <Border Style="{StaticResource AccentCardBorder}">
                    <VerticalStackLayout Spacing="10">
                        <Label x:Name="WelcomeLabel"
                               Text="WELCOME BACK"
                               Style="{StaticResource Eyebrow}" />

                        <Label Text="Train with focus. Track with clarity."
                               Style="{StaticResource Headline}"
                               HorizontalTextAlignment="Start" />

                        <Label Text="Your workouts, PRs, and performance stats in one place."
                               Style="{StaticResource BodyMuted}" />
                    </VerticalStackLayout>
                </Border>

                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="12">
                    <Border Grid.Column="0"
                            Style="{StaticResource CardBorder}">
                        <VerticalStackLayout Spacing="12">
                            <Label Text="Workout"
                                   Style="{StaticResource SubHeadline}"
                                   HorizontalTextAlignment="Start" />
                            <Label Text="Build a session, log exercises, and keep progress moving."
                                   Style="{StaticResource BodyMuted}" />
                            <Button Text="Start"
                                    Clicked="OnStartWorkoutClicked" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="1"
                            Style="{StaticResource CardBorder}">
                        <VerticalStackLayout Spacing="12">
                            <Label Text="Calculations"
                                   Style="{StaticResource SubHeadline}"
                                   HorizontalTextAlignment="Start" />
                            <Label Text="Open 1RM and RSI tools, then keep both strength and athletic PRs together."
                                   Style="{StaticResource BodyMuted}" />
                            <Button Style="{StaticResource SecondaryButton}"
                                    Text="Open"
                                    Clicked="OnOpenCalculationsClicked" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <Label Text="Quick View"
                       Style="{StaticResource SubHeadline}"
                       HorizontalTextAlignment="Start" />

                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="12"
                      RowDefinitions="Auto,Auto"
                      RowSpacing="12">
                    <Border Grid.Row="0"
                            Grid.Column="0"
                            Style="{StaticResource CardBorder}">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Total Workouts"
                                   Style="{StaticResource BodyMuted}" />
                            <Label x:Name="WorkoutTotalLabel"
                                   Text="0"
                                   FontSize="28" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Row="0"
                            Grid.Column="1"
                            Style="{StaticResource CardBorder}">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Athletic Entries"
                                   Style="{StaticResource BodyMuted}" />
                            <Label x:Name="AthleticCountLabel"
                                   Text="0"
                                   FontSize="28" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Row="1"
                            Grid.ColumnSpan="2"
                            Style="{StaticResource CardBorder}">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Latest Saved PR"
                                   Style="{StaticResource BodyMuted}" />
                            <Label x:Name="LatestPrLabel"
                                   Text="No PR saved yet."
                                   FontSize="20"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>
            </VerticalStackLayout>
        </ScrollView>

        <local:BottomNavBar Grid.Row="1"
                            ActiveTab="home" />
    </Grid>

</ContentPage>
