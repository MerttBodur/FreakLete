<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:FreakLete"
             x:Class="FreakLete.HomePage"
             NavigationPage.HasNavigationBar="False"
             Title="">

    <Grid RowDefinitions="*,Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="24,18,24,20"
                                 Spacing="18">

                <!-- Hero -->
                <local:HeroPanel x:Name="HeroPanelView"
                                 Eyebrow="WELCOME BACK"
                                 Title="Train with focus."
                                 Subtitle="Workouts, PRs, performance — one place." />

                <!-- Action tiles -->
                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="12">
                    <local:ActionTile Grid.Column="0"
                                      Title="Workout"
                                      Description="Build a session, log exercises."
                                      ButtonText="Start"
                                      ButtonClicked="OnStartWorkoutClicked" />

                    <local:ActionTile Grid.Column="1"
                                      Title="Calculations"
                                      Description="1RM, RSI tools and PR tracking."
                                      ButtonText="Open"
                                      IsSecondary="True"
                                      ButtonClicked="OnOpenCalculationsClicked" />
                </Grid>

                <!-- Quick metrics -->
                <Label Text="Quick View"
                       Style="{StaticResource SubHeadline}"
                       FontSize="18"
                       HorizontalTextAlignment="Start" />

                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="12"
                      RowDefinitions="Auto,Auto"
                      RowSpacing="12">
                    <local:MetricTile Grid.Row="0"
                                      Grid.Column="0"
                                      x:Name="WorkoutMetric"
                                      Label="Total Workouts"
                                      Value="0" />

                    <local:MetricTile Grid.Row="0"
                                      Grid.Column="1"
                                      x:Name="AthleticMetric"
                                      Label="Athletic Entries"
                                      Value="0" />

                    <Border Grid.Row="1"
                            Grid.ColumnSpan="2"
                            Style="{StaticResource CardBorder}">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Latest PR"
                                   Style="{StaticResource BodyMuted}"
                                   FontSize="12" />
                            <Label x:Name="LatestPrLabel"
                                   Text="No PR saved yet."
                                   FontSize="18"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>
            </VerticalStackLayout>
        </ScrollView>

        <local:BottomNavBar Grid.Row="1"
                            ActiveTab="home" />
    </Grid>

</ContentPage>
