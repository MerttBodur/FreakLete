<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:FreakLete"
             x:Class="FreakLete.HomePage"
             NavigationPage.HasNavigationBar="False"
             Title="">

    <Grid RowDefinitions="*,Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="24,16,24,20" Spacing="20">

                <!-- Compact Identity Row -->
                <HorizontalStackLayout Spacing="12" VerticalOptions="Start">
                    <VerticalStackLayout Spacing="2" HorizontalOptions="FillAndExpand">
                        <Label FontSize="12"
                               FontFamily="OpenSansRegular"
                               TextColor="{StaticResource TextSecondary}"
                               Text="Welcome back" />
                        <Label x:Name="UserNameLabel"
                               FontSize="20"
                               FontFamily="OpenSansSemibold"
                               TextColor="{StaticResource TextPrimary}"
                               Text="User" />
                    </VerticalStackLayout>
                </HorizontalStackLayout>

                <!-- Stats Dashboard Grid - 3 columns with compact tiles -->
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                    <local:StatTile Grid.Column="0"
                                    x:Name="WorkoutCountTile"
                                    StatValue="0"
                                    StatLabel="Workouts" />

                    <local:StatTile Grid.Column="1"
                                    x:Name="StreakTile"
                                    StatValue="0"
                                    StatLabel="Streak" />

                    <local:StatTile Grid.Column="2"
                                    x:Name="LatestPrTile"
                                    StatValue="-"
                                    StatLabel="Latest PR" />
                </Grid>

                <!-- Weekly Activity Card - using shared BarChartCard foundation -->
                <local:BarChartCard x:Name="WeeklyActivityCard"
                                    Title="This Week" />

                <!-- Quick Actions -->
                <HorizontalStackLayout Spacing="8">
                    <Button Text="Start Workout"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="White"
                            CornerRadius="6"
                            Padding="16,10"
                            HorizontalOptions="FillAndExpand"
                            Clicked="OnStartWorkoutClicked" />
                    <Button Text="Calculations"
                            BackgroundColor="{StaticResource Accent}"
                            TextColor="White"
                            CornerRadius="6"
                            Padding="16,10"
                            HorizontalOptions="FillAndExpand"
                            Clicked="OnOpenCalculationsClicked" />
                </HorizontalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <local:BottomNavBar Grid.Row="1"
                            ActiveTab="home" />
    </Grid>

</ContentPage>
