<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:FreakLete"
             x:Class="FreakLete.HomePage"
             NavigationPage.HasNavigationBar="False"
             Title=""
             BackgroundColor="{StaticResource Background}">

    <Grid RowDefinitions="*,Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20,16,20,24" Spacing="20">

                <!-- Section 1: Header -->
                <VerticalStackLayout Spacing="2" Padding="0,4,0,0">
                    <Label x:Name="WelcomeLabel"
                           FontSize="12"
                           FontFamily="OpenSansSemibold"
                           TextColor="{StaticResource TextSecondary}"
                           Text="WELCOME"
                           CharacterSpacing="1" />
                    <HorizontalStackLayout Spacing="0">
                        <Label FontSize="12"
                               FontFamily="OpenSansSemibold"
                               TextColor="{StaticResource TextSecondary}"
                               Text=", "
                               CharacterSpacing="1" />
                        <Label x:Name="UserNameLabel"
                               FontSize="24"
                               FontFamily="OpenSansSemibold"
                               TextColor="{StaticResource TextPrimary}"
                               Text="User" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>

                <!-- Section 2: Start Workout Card -->
                <Border StrokeShape="RoundRectangle 20"
                        Stroke="{StaticResource SurfaceBorder}"
                        StrokeThickness="1"
                        Padding="0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="{StaticResource SurfaceRaised}" Offset="0.0" />
                            <GradientStop Color="{StaticResource Surface}" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid ColumnDefinitions="*,Auto" Padding="20,18">
                        <VerticalStackLayout Spacing="10" VerticalOptions="Center">
                            <Label x:Name="StartWorkoutLabel"
                                   Text="Start Workout"
                                   FontSize="20"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource TextPrimary}" />
                            <Button x:Name="StartButton"
                                    Text="Start"
                                    BackgroundColor="{StaticResource Accent}"
                                    TextColor="White"
                                    CornerRadius="14"
                                    Padding="20,12"
                                    FontSize="14"
                                    FontFamily="OpenSansSemibold"
                                    Clicked="OnStartWorkoutClicked"
                                    HorizontalOptions="Start" />
                        </VerticalStackLayout>
                        <!-- Workout count badge -->
                        <Border Grid.Column="1"
                                StrokeShape="RoundRectangle 14"
                                BackgroundColor="{StaticResource AccentSoft}"
                                Stroke="Transparent"
                                Padding="14,10"
                                VerticalOptions="Center">
                            <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                <Label x:Name="WorkoutCountLabel"
                                       Text="0"
                                       FontSize="22"
                                       FontFamily="OpenSansSemibold"
                                       TextColor="{StaticResource AccentGlow}"
                                       HorizontalTextAlignment="Center" />
                                <Label x:Name="WorkoutsBadgeLabel"
                                       Text="WORKOUTS"
                                       FontSize="9"
                                       FontFamily="OpenSansSemibold"
                                       TextColor="{StaticResource TextSecondary}"
                                       CharacterSpacing="0.5"
                                       HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </Border>

                <!-- Section 3: Exercise Comparison Chart -->
                <local:ExerciseComparisonChart x:Name="ComparisonChart"
                                               Exercise1Name="Bench Press"
                                               Exercise2Name="Squat"
                                               ChangeExercisesClicked="OnChangeComparisonExercisesClicked" />

                <!-- Section 4: Quick Workouts -->
                <VerticalStackLayout Spacing="10">
                    <Label x:Name="QuickWorkoutsTitle"
                           Text="Quick Workouts"
                           FontSize="18"
                           FontFamily="OpenSansSemibold"
                           TextColor="{StaticResource TextPrimary}"
                           Padding="0,0,0,0" />
                    <Label x:Name="QuickWorkoutsDesc"
                           Text="Ready-made workout templates to get started quickly"
                           FontSize="11"
                           FontFamily="OpenSansRegular"
                           TextColor="{StaticResource TextSecondary}" />
                    <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                        <HorizontalStackLayout x:Name="QuickWorkoutsLayout"
                                               Spacing="12"
                                               Padding="0,4" />
                    </ScrollView>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <local:BottomNavBar Grid.Row="1"
                            ActiveTab="home" />
    </Grid>

</ContentPage>
