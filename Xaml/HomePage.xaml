<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:FreakLete"
             x:Class="FreakLete.HomePage"
             NavigationPage.HasNavigationBar="False"
             Title="">

    <Grid RowDefinitions="*,Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="24,16,24,20" Spacing="20">

                <!-- Compact Identity Row -->
                <HorizontalStackLayout Spacing="12" VerticalOptions="Start">
                    <VerticalStackLayout Spacing="2" HorizontalOptions="FillAndExpand">
                        <Label FontSize="12"
                               FontFamily="OpenSansRegular"
                               TextColor="{StaticResource TextSecondary}"
                               Text="Welcome back" />
                        <Label x:Name="UserNameLabel"
                               FontSize="20"
                               FontFamily="OpenSansSemibold"
                               TextColor="{StaticResource TextPrimary}"
                               Text="User" />
                    </VerticalStackLayout>
                </HorizontalStackLayout>

                <!-- Stats Dashboard Grid - 3 columns with compact tiles -->
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                    <local:StatTile Grid.Column="0"
                                    x:Name="WorkoutCountTile"
                                    StatValue="0"
                                    StatLabel="Workouts" />

                    <local:StatTile Grid.Column="1"
                                    x:Name="StreakTile"
                                    StatValue="0"
                                    StatLabel="Streak" />

                    <local:StatTile Grid.Column="2"
                                    x:Name="LatestPrTile"
                                    StatValue="-"
                                    StatLabel="Latest PR" />
                </Grid>

                <!-- Weekly Activity Card -->
                <local:BarChartCard x:Name="WeeklyActivityCard"
                                    Title="This Week" />

                <!-- Featured/Focus Section -->
                <Border Style="{StaticResource CardBorder}"
                        Padding="0"
                        StrokeThickness="2"
                        Stroke="{StaticResource Accent}">
                    <VerticalStackLayout Spacing="12" Padding="16">
                        <Label x:Name="FeaturedTitleLabel"
                               FontSize="16"
                               FontFamily="OpenSansSemibold"
                               TextColor="{StaticResource TextPrimary}"
                               Text="Latest Workout" />

                        <!-- Featured Content -->
                        <VerticalStackLayout x:Name="FeaturedContentLayout"
                                           Spacing="8">
                            <Label x:Name="FeaturedWorkoutNameLabel"
                                   FontSize="14"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource TextPrimary}"
                                   Text="No recent workouts" />

                            <HorizontalStackLayout Spacing="16">
                                <VerticalStackLayout Spacing="2">
                                    <Label FontSize="10"
                                           TextColor="{StaticResource TextSecondary}"
                                           Text="Date" />
                                    <Label x:Name="FeaturedDateLabel"
                                           FontSize="12"
                                           FontFamily="OpenSansSemibold"
                                           TextColor="{StaticResource TextPrimary}"
                                           Text="-" />
                                </VerticalStackLayout>

                                <VerticalStackLayout Spacing="2">
                                    <Label FontSize="10"
                                           TextColor="{StaticResource TextSecondary}"
                                           Text="Exercises" />
                                    <Label x:Name="FeaturedExerciseCountLabel"
                                           FontSize="12"
                                           FontFamily="OpenSansSemibold"
                                           TextColor="{StaticResource TextPrimary}"
                                           Text="-" />
                                </VerticalStackLayout>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>

                        <!-- View Details Button -->
                        <Button x:Name="FeaturedViewButton"
                                Text="View Details"
                                BackgroundColor="{StaticResource Accent}"
                                TextColor="White"
                                CornerRadius="6"
                                Padding="12,8"
                                FontSize="12"
                                FontFamily="OpenSansSemibold"
                                Clicked="OnViewFeaturedWorkoutClicked"
                                IsVisible="False" />
                    </VerticalStackLayout>
                </Border>

                <!-- Quick Actions -->
                <HorizontalStackLayout Spacing="8">
                    <Button Text="Start Workout"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="White"
                            CornerRadius="6"
                            Padding="16,10"
                            HorizontalOptions="FillAndExpand"
                            Clicked="OnStartWorkoutClicked" />
                    <Button Text="Calculations"
                            BackgroundColor="{StaticResource Accent}"
                            TextColor="White"
                            CornerRadius="6"
                            Padding="16,10"
                            HorizontalOptions="FillAndExpand"
                            Clicked="OnOpenCalculationsClicked" />
                </HorizontalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <local:BottomNavBar Grid.Row="1"
                            ActiveTab="home" />
    </Grid>

</ContentPage>
