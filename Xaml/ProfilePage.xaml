<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:FreakLete"
             x:Class="FreakLete.ProfilePage"
             NavigationPage.HasNavigationBar="False"
             Title="Profile">

    <Grid RowDefinitions="*,Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="24,18,24,24"
                                 Spacing="18">

                <local:TopHeader Title="Profile" />

                <Border Style="{StaticResource AccentCardBorder}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="ATHLETE PROFILE"
                               Style="{StaticResource Eyebrow}" />
                        <Label x:Name="FullNameLabel"
                               Text="Your Name"
                               Style="{StaticResource Headline}"
                               HorizontalTextAlignment="Start" />
                        <Label x:Name="EmailLabel"
                               Style="{StaticResource BodyMuted}" />
                        <Label x:Name="StatusLabel"
                               FontSize="13"
                               IsVisible="False" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource CardBorder}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Profile Details"
                               Style="{StaticResource SubHeadline}"
                               HorizontalTextAlignment="Start" />

                        <Label Text="Date of Birth"
                               Style="{StaticResource BodyMuted}" />
                        <DatePicker x:Name="DateOfBirthPicker"
                                    DateSelected="OnDateOfBirthChanged" />

                        <Label x:Name="AgeLabel"
                               Text="Age: -" />

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="12">
                            <VerticalStackLayout Grid.Column="0"
                                                 Spacing="8">
                                <Label Text="Weight (kg)"
                                       Style="{StaticResource BodyMuted}" />
                                <Entry x:Name="WeightEntry"
                                       Placeholder="Example: 82.5"
                                       Keyboard="Numeric" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="8">
                                <Label Text="Body Fat (%)"
                                       Style="{StaticResource BodyMuted}" />
                                <Entry x:Name="BodyFatEntry"
                                       Placeholder="Example: 12.5"
                                       Keyboard="Numeric" />
                            </VerticalStackLayout>
                        </Grid>

                        <Label Text="Sport"
                               Style="{StaticResource BodyMuted}" />
                        <Picker x:Name="SportPicker"
                                Title="Select your sport"
                                SelectedIndexChanged="OnSportPickerChanged" />

                        <VerticalStackLayout x:Name="PositionContainer"
                                             Spacing="8"
                                             IsVisible="False">
                            <Label Text="Position / Discipline"
                                   Style="{StaticResource BodyMuted}" />
                            <Picker x:Name="PositionPicker"
                                    Title="Select your position" />
                        </VerticalStackLayout>

                        <Label Text="Gym Experience"
                               Style="{StaticResource BodyMuted}" />
                        <Picker x:Name="GymExperiencePicker"
                                Title="Select experience level" />

                        <Button Text="Save"
                                Clicked="OnSaveProfileClicked" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource CardBorder}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Coach Profile"
                               Style="{StaticResource SubHeadline}"
                               HorizontalTextAlignment="Start" />

                        <Label Text="Training Days / Week"
                               Style="{StaticResource BodyMuted}" />
                        <Picker x:Name="TrainingDaysPicker"
                                Title="Select days per week" />

                        <Label Text="Session Duration (minutes)"
                               Style="{StaticResource BodyMuted}" />
                        <Picker x:Name="SessionDurationPicker"
                                Title="Select session duration" />

                        <Label Text="Primary Training Goal"
                               Style="{StaticResource BodyMuted}" />
                        <Picker x:Name="PrimaryGoalPicker"
                                Title="Select your primary goal" />

                        <Label Text="Secondary Goal (optional)"
                               Style="{StaticResource BodyMuted}" />
                        <Picker x:Name="SecondaryGoalPicker"
                                Title="Select secondary goal" />

                        <Label Text="Available Equipment"
                               Style="{StaticResource BodyMuted}" />
                        <Editor x:Name="EquipmentEditor"
                                Placeholder="e.g. Full gym, Barbell, Dumbbells, Pull-up bar, Bands..."
                                AutoSize="TextChanges"
                                MaxLength="1000"
                                HeightRequest="60" />

                        <Label Text="Injury History"
                               Style="{StaticResource BodyMuted}" />
                        <Editor x:Name="InjuryHistoryEditor"
                                Placeholder="e.g. ACL reconstruction 2023 left knee, chronic shoulder impingement..."
                                AutoSize="TextChanges"
                                MaxLength="1000"
                                HeightRequest="60" />

                        <Label Text="Current Pain Points"
                               Style="{StaticResource BodyMuted}" />
                        <Editor x:Name="CurrentPainEditor"
                                Placeholder="e.g. Mild right knee discomfort during deep squats..."
                                AutoSize="TextChanges"
                                MaxLength="1000"
                                HeightRequest="60" />

                        <Label Text="Physical Limitations"
                               Style="{StaticResource BodyMuted}" />
                        <Editor x:Name="PhysicalLimitationsEditor"
                                Placeholder="e.g. Limited overhead mobility, can't do behind-neck movements..."
                                AutoSize="TextChanges"
                                MaxLength="1000"
                                HeightRequest="60" />

                        <Label Text="Dietary Preference (optional)"
                               Style="{StaticResource BodyMuted}" />
                        <Picker x:Name="DietaryPreferencePicker"
                                Title="Select dietary preference" />

                        <Button Text="Save Coach Profile"
                                Clicked="OnSaveCoachProfileClicked" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource CardBorder}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Quick Stats"
                               Style="{StaticResource SubHeadline}"
                               HorizontalTextAlignment="Start" />

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="10">
                            <Border Grid.Column="0"
                                    Style="{StaticResource CardBorder}"
                                    BackgroundColor="{StaticResource SurfaceRaised}"
                                    Padding="12">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Workouts"
                                           Style="{StaticResource BodyMuted}" />
                                    <Label x:Name="WorkoutCountLabel"
                                           Text="0"
                                           FontSize="22" />
                                </VerticalStackLayout>
                            </Border>

                            <Border Grid.Column="1"
                                    Style="{StaticResource CardBorder}"
                                    BackgroundColor="{StaticResource SurfaceRaised}"
                                    Padding="12">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Saved PRs"
                                           Style="{StaticResource BodyMuted}" />
                                    <Label x:Name="OneRmPrCountLabel"
                                           Text="0"
                                           FontSize="22" />
                                </VerticalStackLayout>
                            </Border>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource CardBorder}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Athletic Performance"
                               Style="{StaticResource SubHeadline}"
                               HorizontalTextAlignment="Start" />

                        <Label Text="Movement"
                               Style="{StaticResource BodyMuted}" />
                        <Border Style="{StaticResource CardBorder}"
                                BackgroundColor="{StaticResource SurfaceRaised}"
                                Padding="14">
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="10">
                                <VerticalStackLayout Grid.Column="0"
                                                     Spacing="4">
                                    <Label x:Name="SelectedPerformanceLabel"
                                           Text="No movement selected"
                                           FontSize="18" />
                                    <Label x:Name="SelectedPerformanceHintLabel"
                                           Text="Browse sprint, jump, plyo, and Olympic lift movements."
                                           Style="{StaticResource BodyMuted}" />
                                </VerticalStackLayout>

                                <Button Grid.Column="1"
                                        Text="Browse"
                                        Style="{StaticResource SecondaryButton}"
                                        Clicked="OnChoosePerformanceMovementClicked"
                                        VerticalOptions="Center" />
                            </Grid>
                        </Border>

                        <VerticalStackLayout Spacing="8">
                            <Label x:Name="PerformanceMetric1Label"
                                   Text="Result"
                                   Style="{StaticResource BodyMuted}" />
                            <Entry x:Name="PerformanceValueEntry"
                                   Placeholder="Enter result"
                                   Keyboard="Numeric" />
                        </VerticalStackLayout>

                        <VerticalStackLayout x:Name="PerformanceMetric2Container"
                                             Spacing="8"
                                             IsVisible="False">
                            <Label x:Name="PerformanceMetric2Label"
                                   Text="Second Result"
                                   Style="{StaticResource BodyMuted}" />
                            <Entry x:Name="PerformanceSecondaryValueEntry"
                                   Placeholder="Enter second result"
                                   Keyboard="Numeric" />
                        </VerticalStackLayout>

                        <VerticalStackLayout x:Name="PerformanceTimingContainer"
                                             Spacing="8"
                                             IsVisible="False">
                            <Label x:Name="PerformanceTimingLabel"
                                   Text="Timing"
                                   Style="{StaticResource BodyMuted}" />
                            <Entry x:Name="PerformanceTimingEntry"
                                   Placeholder="Optional (e.g. 1.96)"
                                   Keyboard="Numeric" />
                        </VerticalStackLayout>

                        <Button x:Name="PerformanceActionButton"
                                Text="Save"
                                Clicked="OnAddPerformanceClicked" />

                        <Button x:Name="PerformanceCancelButton"
                                Text="Cancel"
                                Style="{StaticResource SecondaryButton}"
                                IsVisible="False"
                                Clicked="OnCancelPerformanceEditClicked" />

                        <Label x:Name="AthleticPerformanceEmptyLabel"
                               Text="No athletic performance records yet."
                               HorizontalOptions="Center"
                               Style="{StaticResource BodyMuted}" />

                        <VerticalStackLayout x:Name="AthleticPerformanceList"
                                             Spacing="0"
                                             BindableLayout.ItemsSource="{x:Null}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource CardBorder}"
                                            BackgroundColor="{StaticResource SurfaceRaised}"
                                            Padding="14"
                                            Margin="0,0,0,10">
                                        <Grid ColumnDefinitions="*,Auto,Auto"
                                              ColumnSpacing="8">
                                            <Label Grid.Column="0"
                                                   Text="{Binding Text}"
                                                   VerticalOptions="Center" />
                                            <ImageButton Grid.Column="1"
                                                         Source="icon_edit.svg"
                                                         Clicked="OnEditPerformanceInvoked"
                                                         BackgroundColor="#24203A"
                                                         Padding="8"
                                                         WidthRequest="36"
                                                         HeightRequest="36"
                                                         CornerRadius="12" />
                                            <ImageButton Grid.Column="2"
                                                         Source="icon_delete.svg"
                                                         Clicked="OnDeletePerformanceInvoked"
                                                         BackgroundColor="#3A1623"
                                                         Padding="8"
                                                         WidthRequest="36"
                                                         HeightRequest="36"
                                                         CornerRadius="12" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource CardBorder}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Movement Goals"
                               Style="{StaticResource SubHeadline}"
                               HorizontalTextAlignment="Start" />

                        <Label Text="Goal movement"
                               Style="{StaticResource BodyMuted}" />
                        <Border Style="{StaticResource CardBorder}"
                                BackgroundColor="{StaticResource SurfaceRaised}"
                                Padding="14">
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="10">
                                <VerticalStackLayout Grid.Column="0"
                                                     Spacing="4">
                                    <Label x:Name="SelectedGoalLabel"
                                           Text="No movement selected"
                                           FontSize="18" />
                                    <Label x:Name="SelectedGoalHintLabel"
                                           Text="Browse the exercise catalog and set a target on the movement's main metric."
                                           Style="{StaticResource BodyMuted}" />
                                </VerticalStackLayout>

                                <Button Grid.Column="1"
                                        Text="Browse"
                                        Style="{StaticResource SecondaryButton}"
                                        Clicked="OnChooseGoalMovementClicked"
                                        VerticalOptions="Center" />
                            </Grid>
                        </Border>

                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="12">
                            <Entry Grid.Column="0"
                                   x:Name="GoalTargetValueEntry"
                                   Placeholder="Target value"
                                   Keyboard="Numeric" />
                            <Border Grid.Column="1"
                                    Style="{StaticResource CardBorder}"
                                    BackgroundColor="{StaticResource SurfaceRaised}"
                                    Padding="14,12">
                                <Label x:Name="GoalUnitLabel"
                                       Text="-"
                                       VerticalOptions="Center" />
                            </Border>
                        </Grid>

                        <Button x:Name="GoalActionButton"
                                Text="Save"
                                Clicked="OnSaveGoalClicked" />

                        <Button x:Name="GoalCancelButton"
                                Text="Cancel"
                                Style="{StaticResource SecondaryButton}"
                                IsVisible="False"
                                Clicked="OnCancelGoalEditClicked" />

                        <Label x:Name="MovementGoalsEmptyLabel"
                               Text="No movement goals set yet."
                               HorizontalOptions="Center"
                               Style="{StaticResource BodyMuted}" />

                        <VerticalStackLayout x:Name="MovementGoalsList"
                                             Spacing="0"
                                             BindableLayout.ItemsSource="{x:Null}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource CardBorder}"
                                            BackgroundColor="{StaticResource SurfaceRaised}"
                                            Padding="14"
                                            Margin="0,0,0,10">
                                        <Grid ColumnDefinitions="*,Auto,Auto"
                                              ColumnSpacing="8">
                                            <Label Grid.Column="0"
                                                   Text="{Binding Text}"
                                                   VerticalOptions="Center" />
                                            <ImageButton Grid.Column="1"
                                                         Source="icon_edit.svg"
                                                         Clicked="OnEditGoalInvoked"
                                                         BackgroundColor="#24203A"
                                                         Padding="8"
                                                         WidthRequest="36"
                                                         HeightRequest="36"
                                                         CornerRadius="12" />
                                            <ImageButton Grid.Column="2"
                                                         Source="icon_delete.svg"
                                                         Clicked="OnDeleteGoalInvoked"
                                                         BackgroundColor="#3A1623"
                                                         Padding="8"
                                                         WidthRequest="36"
                                                         HeightRequest="36"
                                                         CornerRadius="12" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="12">
                    <Button Grid.Column="0"
                            Text="Logout"
                            Style="{StaticResource SecondaryButton}"
                            Clicked="OnLogoutClicked" />

                    <Button Grid.Column="1"
                            Text="Delete"
                            BackgroundColor="{StaticResource DangerSoft}"
                            Clicked="OnDeleteAccountClicked" />
                </Grid>
            </VerticalStackLayout>
        </ScrollView>

        <local:BottomNavBar Grid.Row="1"
                            ActiveTab="profile" />
    </Grid>

</ContentPage>
