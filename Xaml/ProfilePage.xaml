<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:FreakLete"
             x:Class="FreakLete.ProfilePage"
             NavigationPage.HasNavigationBar="False"
             Title="Profile">

    <Grid RowDefinitions="*,Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="24,18,24,24"
                                 Spacing="18">

                <!-- Centered Hero Identity -->
                <VerticalStackLayout Spacing="8" HorizontalOptions="Center" Margin="0,14,0,4">
                    <!-- Initials Avatar Ring -->
                    <Border x:Name="AvatarRing"
                            StrokeShape="RoundRectangle 44"
                            StrokeThickness="3"
                            WidthRequest="88"
                            HeightRequest="88"
                            HorizontalOptions="Center">
                        <Border.Stroke>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="{StaticResource Accent}" Offset="0.0" />
                                <GradientStop Color="{StaticResource AccentGlow}" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.Stroke>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="{StaticResource AccentSoft}" Offset="0.0" />
                                <GradientStop Color="{StaticResource Surface}" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Label x:Name="InitialsLabel"
                               Text="?"
                               FontSize="30"
                               FontFamily="OpenSansSemibold"
                               TextColor="{StaticResource AccentGlow}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>
                    <Label x:Name="FullNameLabel"
                           Text="Your Name"
                           FontSize="26"
                           FontFamily="OpenSansSemibold"
                           TextColor="{StaticResource TextPrimary}"
                           HorizontalTextAlignment="Center"
                           Margin="0,4,0,0" />
                    <Label x:Name="EmailLabel"
                           FontSize="13"
                           FontFamily="OpenSansRegular"
                           TextColor="{StaticResource TextSecondary}"
                           HorizontalTextAlignment="Center" />
                    <!-- Status chip — derived from real context -->
                    <Border x:Name="StatusChip"
                            StrokeShape="RoundRectangle 12"
                            BackgroundColor="{StaticResource AccentSoft}"
                            Stroke="{StaticResource Accent}"
                            StrokeThickness="1"
                            Padding="14,5"
                            HorizontalOptions="Center"
                            Margin="0,4,0,0"
                            IsVisible="False">
                        <Label x:Name="StatusLabel"
                               FontSize="10"
                               FontFamily="OpenSansSemibold"
                               TextColor="{StaticResource AccentGlow}"
                               CharacterSpacing="1" />
                    </Border>
                </VerticalStackLayout>

                <!-- Stats Row -->
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10" Margin="0,4,0,0">
                    <Border Grid.Column="0"
                            StrokeShape="RoundRectangle 18"
                            Stroke="{StaticResource SurfaceBorder}"
                            StrokeThickness="1"
                            Padding="14,14">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="{StaticResource SurfaceRaised}" Offset="0.0" />
                                <GradientStop Color="{StaticResource Surface}" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                            <Label x:Name="WorkoutCountLabel"
                                   FontSize="26"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource AccentGlow}"
                                   HorizontalTextAlignment="Center"
                                   Text="0" />
                            <Label x:Name="WorkoutsSubLabel"
                                   FontSize="10"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource TextSecondary}"
                                   HorizontalTextAlignment="Center"
                                   Text="Workouts" />
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="1"
                            StrokeShape="RoundRectangle 18"
                            Stroke="{StaticResource SurfaceBorder}"
                            StrokeThickness="1"
                            Padding="14,14">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="{StaticResource SurfaceRaised}" Offset="0.0" />
                                <GradientStop Color="{StaticResource Surface}" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                            <Label x:Name="OneRmPrCountLabel"
                                   FontSize="26"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource AccentGlow}"
                                   HorizontalTextAlignment="Center"
                                   Text="0" />
                            <Label x:Name="SavedPrsSubLabel"
                                   FontSize="10"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource TextSecondary}"
                                   HorizontalTextAlignment="Center"
                                   Text="Saved PRs" />
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="2"
                            StrokeShape="RoundRectangle 18"
                            Stroke="{StaticResource SurfaceBorder}"
                            StrokeThickness="1"
                            Padding="14,14">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="{StaticResource SurfaceRaised}" Offset="0.0" />
                                <GradientStop Color="{StaticResource Surface}" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                            <Label x:Name="AthleticRecordsCountLabel"
                                   FontSize="26"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource AccentGlow}"
                                   HorizontalTextAlignment="Center"
                                   Text="0" />
                            <Label x:Name="RecordsSubLabel"
                                   FontSize="10"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource TextSecondary}"
                                   HorizontalTextAlignment="Center"
                                   CharacterSpacing="0.3"
                                   Text="Records" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Highlights Section -->
                <VerticalStackLayout x:Name="HighlightsSection" Spacing="10">
                    <Label x:Name="HighlightsLabel"
                           FontSize="18"
                           FontFamily="OpenSansSemibold"
                           TextColor="{StaticResource TextPrimary}"
                           Text="Highlights"
                           Margin="0,4,0,0" />
                    <VerticalStackLayout x:Name="HighlightsContainer" Spacing="8" />
                </VerticalStackLayout>

                <!-- Divider -->
                <BoxView HeightRequest="1"
                         Color="{StaticResource SurfaceBorder}"
                         Margin="0,4,0,0" />

                <Border Style="{StaticResource CardBorder}">
                    <VerticalStackLayout Spacing="12">
                        <Label x:Name="ProfileDetailsTitle"
                               Text="Profile Details"
                               Style="{StaticResource SubHeadline}"
                               HorizontalTextAlignment="Start" />

                        <Label x:Name="DobLabel"
                               Text="Date of Birth"
                               Style="{StaticResource BodyMuted}" />
                        <Border Style="{StaticResource CardBorder}"
                                BackgroundColor="{StaticResource SurfaceRaised}"
                                Padding="14,12">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnDateOfBirthTapped" />
                            </Border.GestureRecognizers>
                            <Label x:Name="DateOfBirthLabel"
                                   Text="Select date of birth"
                                   TextColor="{StaticResource TextSecondary}"
                                   FontSize="15" />
                        </Border>

                        <Label x:Name="AgeLabel"
                               Text="Age: -" />

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="12">
                            <VerticalStackLayout Grid.Column="0"
                                                 Spacing="8">
                                <Label x:Name="WeightKgLabel"
                                       Text="Weight (kg)"
                                       Style="{StaticResource BodyMuted}" />
                                <Entry x:Name="WeightEntry"
                                       Placeholder="Example: 82.5"
                                       Keyboard="Numeric"
                                       Unfocused="OnWeightUnfocused" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="8">
                                <Label x:Name="BodyFatLabel"
                                       Text="Body Fat (%)"
                                       Style="{StaticResource BodyMuted}" />
                                <Entry x:Name="BodyFatEntry"
                                       Placeholder="Example: 12.5"
                                       Keyboard="Numeric"
                                       Unfocused="OnBodyFatUnfocused" />
                            </VerticalStackLayout>
                        </Grid>

                        <VerticalStackLayout Spacing="8">
                            <Label x:Name="HeightCmLabel"
                                   Text="Height (cm)"
                                   Style="{StaticResource BodyMuted}" />
                            <Entry x:Name="HeightEntry"
                                   Placeholder="Example: 178"
                                   Keyboard="Numeric"
                                   Unfocused="OnHeightUnfocused" />
                        </VerticalStackLayout>

                        <Label x:Name="SexTitleLabel"
                               Text="Sex"
                               Style="{StaticResource BodyMuted}" />
                        <Border Style="{StaticResource CardBorder}"
                                BackgroundColor="{StaticResource SurfaceRaised}"
                                Padding="14,12">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnSexSelectorTapped" />
                            </Border.GestureRecognizers>
                            <Label x:Name="SexLabel"
                                   Text="Select sex"
                                   TextColor="{StaticResource TextSecondary}"
                                   FontSize="15" />
                        </Border>

                        <Label x:Name="SportTitleLabel"
                               Text="Sport"
                               Style="{StaticResource BodyMuted}" />
                        <Border Style="{StaticResource CardBorder}"
                                BackgroundColor="{StaticResource SurfaceRaised}"
                                Padding="14,12">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnSportSelectorTapped" />
                            </Border.GestureRecognizers>
                            <Label x:Name="SportLabel"
                                   Text="Select your sport"
                                   TextColor="{StaticResource TextSecondary}"
                                   FontSize="15" />
                        </Border>

                        <VerticalStackLayout x:Name="PositionContainer"
                                             Spacing="8"
                                             IsVisible="False">
                            <Label x:Name="PositionTitleLabel"
                                   Text="Position / Discipline"
                                   Style="{StaticResource BodyMuted}" />
                            <Border Style="{StaticResource CardBorder}"
                                    BackgroundColor="{StaticResource SurfaceRaised}"
                                    Padding="14,12">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnPositionSelectorTapped" />
                                </Border.GestureRecognizers>
                                <Label x:Name="PositionLabel"
                                       Text="Select your position"
                                       TextColor="{StaticResource TextSecondary}"
                                       FontSize="15" />
                            </Border>
                        </VerticalStackLayout>

                        <Label x:Name="GymExpTitleLabel"
                               Text="Gym Experience"
                               Style="{StaticResource BodyMuted}" />
                        <Border Style="{StaticResource CardBorder}"
                                BackgroundColor="{StaticResource SurfaceRaised}"
                                Padding="14,12">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnGymExperienceTapped" />
                            </Border.GestureRecognizers>
                            <Label x:Name="GymExperienceLabel"
                                   Text="Select experience level"
                                   TextColor="{StaticResource TextSecondary}"
                                   FontSize="15" />
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource CardBorder}">
                    <VerticalStackLayout Spacing="12">
                        <Label x:Name="CoachProfileTitle"
                               Text="Coach Profile"
                               Style="{StaticResource SubHeadline}"
                               HorizontalTextAlignment="Start" />

                        <Label x:Name="TrainingDaysTitleLabel"
                               Text="Training Days / Week"
                               Style="{StaticResource BodyMuted}" />
                        <Border Style="{StaticResource CardBorder}"
                                BackgroundColor="{StaticResource SurfaceRaised}"
                                Padding="14,12">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnTrainingDaysTapped" />
                            </Border.GestureRecognizers>
                            <Label x:Name="TrainingDaysLabel"
                                   Text="Select days per week"
                                   TextColor="{StaticResource TextSecondary}"
                                   FontSize="15" />
                        </Border>

                        <Label x:Name="SessionDurationTitleLabel"
                               Text="Session Duration (minutes)"
                               Style="{StaticResource BodyMuted}" />
                        <Border Style="{StaticResource CardBorder}"
                                BackgroundColor="{StaticResource SurfaceRaised}"
                                Padding="14,12">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnSessionDurationTapped" />
                            </Border.GestureRecognizers>
                            <Label x:Name="SessionDurationLabel"
                                   Text="Select session duration"
                                   TextColor="{StaticResource TextSecondary}"
                                   FontSize="15" />
                        </Border>

                        <Label x:Name="PrimaryGoalTitleLabel"
                               Text="Primary Training Goal"
                               Style="{StaticResource BodyMuted}" />
                        <Border Style="{StaticResource CardBorder}"
                                BackgroundColor="{StaticResource SurfaceRaised}"
                                Padding="14,12">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnPrimaryGoalTapped" />
                            </Border.GestureRecognizers>
                            <Label x:Name="PrimaryGoalLabel"
                                   Text="Select your primary goal"
                                   TextColor="{StaticResource TextSecondary}"
                                   FontSize="15" />
                        </Border>

                        <Label x:Name="SecondaryGoalTitleLabel"
                               Text="Secondary Goal (optional)"
                               Style="{StaticResource BodyMuted}" />
                        <Border Style="{StaticResource CardBorder}"
                                BackgroundColor="{StaticResource SurfaceRaised}"
                                Padding="14,12">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnSecondaryGoalTapped" />
                            </Border.GestureRecognizers>
                            <Label x:Name="SecondaryGoalLabel"
                                   Text="Select secondary goal"
                                   TextColor="{StaticResource TextSecondary}"
                                   FontSize="15" />
                        </Border>

                        <Label x:Name="EquipmentTitleLabel"
                               Text="Available Equipment"
                               Style="{StaticResource BodyMuted}" />
                        <Border x:Name="EquipmentSelector"
                                Style="{StaticResource CardBorder}"
                                BackgroundColor="{StaticResource Surface}"
                                Padding="16">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnEquipmentSelectorTapped" />
                            </Border.GestureRecognizers>
                            <Label x:Name="EquipmentLabel"
                                   Text="Select equipment access"
                                   TextColor="{StaticResource TextSecondary}"
                                   FontSize="15" />
                        </Border>

                        <Label x:Name="InjuryHistoryTitleLabel"
                               Text="Injury History"
                               Style="{StaticResource BodyMuted}" />
                        <Editor x:Name="InjuryHistoryEditor"
                                Placeholder="e.g. ACL reconstruction 2023 left knee, chronic shoulder impingement..."
                                AutoSize="TextChanges"
                                MaxLength="1000"
                                HeightRequest="60"
                                Unfocused="OnInjuryHistoryEditorUnfocused" />

                        <Label x:Name="CurrentPainTitleLabel"
                               Text="Current Pain Points"
                               Style="{StaticResource BodyMuted}" />
                        <Editor x:Name="CurrentPainEditor"
                                Placeholder="e.g. Mild right knee discomfort during deep squats..."
                                AutoSize="TextChanges"
                                MaxLength="1000"
                                HeightRequest="60"
                                Unfocused="OnCurrentPainEditorUnfocused" />

                        <Label x:Name="PhysicalLimitsTitleLabel"
                               Text="Physical Limitations"
                               Style="{StaticResource BodyMuted}" />
                        <Editor x:Name="PhysicalLimitationsEditor"
                                Placeholder="e.g. Limited overhead mobility, can't do behind-neck movements..."
                                AutoSize="TextChanges"
                                MaxLength="1000"
                                HeightRequest="60"
                                Unfocused="OnPhysicalLimitationsEditorUnfocused" />

                        <Label x:Name="DietaryPrefTitleLabel"
                               Text="Dietary Preference (optional)"
                               Style="{StaticResource BodyMuted}" />
                        <Border Style="{StaticResource CardBorder}"
                                BackgroundColor="{StaticResource SurfaceRaised}"
                                Padding="14,12">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnDietaryPreferenceTapped" />
                            </Border.GestureRecognizers>
                            <Label x:Name="DietaryPreferenceLabel"
                                   Text="Select dietary preference"
                                   TextColor="{StaticResource TextSecondary}"
                                   FontSize="15" />
                        </Border>

                    </VerticalStackLayout>
                </Border>

                <!-- Athlete Profile Section Header -->

                <Border Style="{StaticResource CardBorder}">
                    <VerticalStackLayout Spacing="12">
                        <Label x:Name="AthleticPerfTitle"
                               Text="Athletic Performance"
                               Style="{StaticResource SubHeadline}"
                               HorizontalTextAlignment="Start" />

                        <Label x:Name="AthleticMovementLabel"
                               Text="Movement"
                               Style="{StaticResource BodyMuted}" />
                        <Border Style="{StaticResource CardBorder}"
                                BackgroundColor="{StaticResource SurfaceRaised}"
                                Padding="14">
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="10">
                                <VerticalStackLayout Grid.Column="0"
                                                     Spacing="4">
                                    <Label x:Name="SelectedPerformanceLabel"
                                           Text="No movement selected"
                                           FontSize="18" />
                                    <Label x:Name="SelectedPerformanceHintLabel"
                                           Text="Browse sprint, jump, plyo, and Olympic lift movements."
                                           Style="{StaticResource BodyMuted}" />
                                </VerticalStackLayout>

                                <Button x:Name="BrowsePerformanceBtn"
                                        Grid.Column="1"
                                        Text="Browse"
                                        Style="{StaticResource SecondaryButton}"
                                        Clicked="OnChoosePerformanceMovementClicked"
                                        VerticalOptions="Center" />
                            </Grid>
                        </Border>

                        <VerticalStackLayout Spacing="8">
                            <Label x:Name="PerformanceMetric1Label"
                                   Text="Result"
                                   Style="{StaticResource BodyMuted}" />
                            <Entry x:Name="PerformanceValueEntry"
                                   Placeholder="Enter result"
                                   Keyboard="Numeric" />
                        </VerticalStackLayout>

                        <VerticalStackLayout x:Name="PerformanceMetric2Container"
                                             Spacing="8"
                                             IsVisible="False">
                            <Label x:Name="PerformanceMetric2Label"
                                   Text="Second Result"
                                   Style="{StaticResource BodyMuted}" />
                            <Entry x:Name="PerformanceSecondaryValueEntry"
                                   Placeholder="Enter second result"
                                   Keyboard="Numeric" />
                        </VerticalStackLayout>

                        <VerticalStackLayout x:Name="PerformanceTimingContainer"
                                             Spacing="8"
                                             IsVisible="False">
                            <Label x:Name="PerformanceTimingLabel"
                                   Text="Timing"
                                   Style="{StaticResource BodyMuted}" />
                            <Entry x:Name="PerformanceTimingEntry"
                                   Placeholder="Optional (e.g. 1.96)"
                                   Keyboard="Numeric" />
                        </VerticalStackLayout>

                        <Button x:Name="PerformanceActionButton"
                                Text="Save"
                                Clicked="OnAddPerformanceClicked" />

                        <Button x:Name="PerformanceCancelButton"
                                Text="Cancel"
                                Style="{StaticResource SecondaryButton}"
                                IsVisible="False"
                                Clicked="OnCancelPerformanceEditClicked" />

                        <Label x:Name="AthleticPerformanceEmptyLabel"
                               Text="No athletic performance records yet."
                               HorizontalOptions="Center"
                               Style="{StaticResource BodyMuted}" />

                        <VerticalStackLayout x:Name="AthleticPerformanceList"
                                             Spacing="0"
                                             BindableLayout.ItemsSource="{x:Null}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource CardBorder}"
                                            BackgroundColor="{StaticResource SurfaceRaised}"
                                            Padding="14"
                                            Margin="0,0,0,10">
                                        <Grid ColumnDefinitions="*,Auto,Auto"
                                              ColumnSpacing="8">
                                            <Label Grid.Column="0"
                                                   Text="{Binding Text}"
                                                   VerticalOptions="Center" />
                                            <ImageButton Grid.Column="1"
                                                         Source="icon_edit.svg"
                                                         Clicked="OnEditPerformanceInvoked"
                                                         BackgroundColor="{StaticResource EditSoft}"
                                                         Padding="8"
                                                         WidthRequest="36"
                                                         HeightRequest="36"
                                                         CornerRadius="12" />
                                            <ImageButton Grid.Column="2"
                                                         Source="icon_delete.svg"
                                                         Clicked="OnDeletePerformanceInvoked"
                                                         BackgroundColor="{StaticResource DangerSoft}"
                                                         Padding="8"
                                                         WidthRequest="36"
                                                         HeightRequest="36"
                                                         CornerRadius="12" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource CardBorder}">
                    <VerticalStackLayout Spacing="12">
                        <Label x:Name="MovementGoalsTitle"
                               Text="Movement Goals"
                               Style="{StaticResource SubHeadline}"
                               HorizontalTextAlignment="Start" />

                        <Label x:Name="GoalMovementLabel"
                               Text="Goal movement"
                               Style="{StaticResource BodyMuted}" />
                        <Border Style="{StaticResource CardBorder}"
                                BackgroundColor="{StaticResource SurfaceRaised}"
                                Padding="14">
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="10">
                                <VerticalStackLayout Grid.Column="0"
                                                     Spacing="4">
                                    <Label x:Name="SelectedGoalLabel"
                                           Text="No movement selected"
                                           FontSize="18" />
                                    <Label x:Name="SelectedGoalHintLabel"
                                           Text="Browse the exercise catalog and set a target on the movement's main metric."
                                           Style="{StaticResource BodyMuted}" />
                                </VerticalStackLayout>

                                <Button x:Name="BrowseGoalBtn"
                                        Grid.Column="1"
                                        Text="Browse"
                                        Style="{StaticResource SecondaryButton}"
                                        Clicked="OnChooseGoalMovementClicked"
                                        VerticalOptions="Center" />
                            </Grid>
                        </Border>

                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="12">
                            <Entry Grid.Column="0"
                                   x:Name="GoalTargetValueEntry"
                                   Placeholder="Target value"
                                   Keyboard="Numeric" />
                            <Border Grid.Column="1"
                                    Style="{StaticResource CardBorder}"
                                    BackgroundColor="{StaticResource SurfaceRaised}"
                                    Padding="14,12">
                                <Label x:Name="GoalUnitLabel"
                                       Text="-"
                                       VerticalOptions="Center" />
                            </Border>
                        </Grid>

                        <Button x:Name="GoalActionButton"
                                Text="Save"
                                Clicked="OnSaveGoalClicked" />

                        <Button x:Name="GoalCancelButton"
                                Text="Cancel"
                                Style="{StaticResource SecondaryButton}"
                                IsVisible="False"
                                Clicked="OnCancelGoalEditClicked" />

                        <Label x:Name="MovementGoalsEmptyLabel"
                               Text="No movement goals set yet."
                               HorizontalOptions="Center"
                               Style="{StaticResource BodyMuted}" />

                        <VerticalStackLayout x:Name="MovementGoalsList"
                                             Spacing="0"
                                             BindableLayout.ItemsSource="{x:Null}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource CardBorder}"
                                            BackgroundColor="{StaticResource SurfaceRaised}"
                                            Padding="14"
                                            Margin="0,0,0,10">
                                        <Grid ColumnDefinitions="*,Auto,Auto"
                                              ColumnSpacing="8">
                                            <Label Grid.Column="0"
                                                   Text="{Binding Text}"
                                                   VerticalOptions="Center" />
                                            <ImageButton Grid.Column="1"
                                                         Source="icon_edit.svg"
                                                         Clicked="OnEditGoalInvoked"
                                                         BackgroundColor="{StaticResource EditSoft}"
                                                         Padding="8"
                                                         WidthRequest="36"
                                                         HeightRequest="36"
                                                         CornerRadius="12" />
                                            <ImageButton Grid.Column="2"
                                                         Source="icon_delete.svg"
                                                         Clicked="OnDeleteGoalInvoked"
                                                         BackgroundColor="{StaticResource DangerSoft}"
                                                         Padding="8"
                                                         WidthRequest="36"
                                                         HeightRequest="36"
                                                         CornerRadius="12" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Settings -->
                <Button x:Name="SettingsBtn"
                        Text="&#x2699;  Settings"
                        Style="{StaticResource SecondaryButton}"
                        Clicked="OnSettingsClicked"
                        HorizontalOptions="Fill" />

                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="12">
                    <Button x:Name="LogoutBtn"
                            Grid.Column="0"
                            Text="Logout"
                            Style="{StaticResource SecondaryButton}"
                            Clicked="OnLogoutClicked" />

                    <Button x:Name="DeleteAccountBtn"
                            Grid.Column="1"
                            Text="Delete"
                            BackgroundColor="{StaticResource DangerSoft}"
                            Clicked="OnDeleteAccountClicked" />
                </Grid>
            </VerticalStackLayout>
        </ScrollView>

        <local:BottomNavBar Grid.Row="1"
                            ActiveTab="profile" />
    </Grid>

</ContentPage>
