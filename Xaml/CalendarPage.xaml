<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GymTracker.CalendarPage"
             xmlns:local="clr-namespace:GymTracker"
             NavigationPage.HasNavigationBar="False"
             Title="Calendar">

    <ScrollView>
        <VerticalStackLayout Padding="24,18,24,28"
                             Spacing="18">

            <local:TopHeader Title="Calendar"
                             ShowBackButton="True"
                             BackClicked="OnHeaderBackClicked" />

            <Border Style="{StaticResource AccentCardBorder}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="TRAINING HISTORY"
                           Style="{StaticResource Eyebrow}" />
                    <Label Text="Review sessions by day and keep your schedule visible."
                           Style="{StaticResource Headline}"
                           HorizontalTextAlignment="Start" />
                    <Label x:Name="SelectedDateLabel"
                           Style="{StaticResource BodyMuted}" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource CardBorder}">
                <VerticalStackLayout Spacing="14">
                    <Grid ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="12">
                        <Button Grid.Column="0"
                                Text="&lt;"
                                Style="{StaticResource SecondaryButton}"
                                Clicked="OnPreviousMonthClicked"
                                WidthRequest="56" />
                        <Label Grid.Column="1"
                               x:Name="MonthLabel"
                               HorizontalTextAlignment="Center"
                               VerticalTextAlignment="Center"
                               FontSize="20" />
                        <Button Grid.Column="2"
                                Text="&gt;"
                                Style="{StaticResource SecondaryButton}"
                                Clicked="OnNextMonthClicked"
                                WidthRequest="56" />
                    </Grid>

                    <Grid ColumnDefinitions="*,*,*,*,*,*,*"
                          ColumnSpacing="6">
                        <Label Grid.Column="0" Text="Mon" HorizontalTextAlignment="Center" Style="{StaticResource BodyMuted}" />
                        <Label Grid.Column="1" Text="Tue" HorizontalTextAlignment="Center" Style="{StaticResource BodyMuted}" />
                        <Label Grid.Column="2" Text="Wed" HorizontalTextAlignment="Center" Style="{StaticResource BodyMuted}" />
                        <Label Grid.Column="3" Text="Thu" HorizontalTextAlignment="Center" Style="{StaticResource BodyMuted}" />
                        <Label Grid.Column="4" Text="Fri" HorizontalTextAlignment="Center" Style="{StaticResource BodyMuted}" />
                        <Label Grid.Column="5" Text="Sat" HorizontalTextAlignment="Center" Style="{StaticResource BodyMuted}" />
                        <Label Grid.Column="6" Text="Sun" HorizontalTextAlignment="Center" Style="{StaticResource BodyMuted}" />
                    </Grid>

                    <CollectionView x:Name="CalendarDaysView"
                                    ItemsSource="{Binding CalendarDays}"
                                    SelectionMode="None">
                        <CollectionView.ItemsLayout>
                            <GridItemsLayout Orientation="Vertical"
                                             Span="7"
                                             HorizontalItemSpacing="6"
                                             VerticalItemSpacing="6" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 18"
                                        BackgroundColor="{Binding CellBackgroundColor}"
                                        Opacity="{Binding CellOpacity}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnDayTapped" />
                                    </Border.GestureRecognizers>
                                    <VerticalStackLayout Spacing="4"
                                                         HorizontalOptions="Center">
                                        <Label Text="{Binding DayText}"
                                               TextColor="{Binding DayTextColor}"
                                               HorizontalTextAlignment="Center" />
                                        <BoxView HeightRequest="6"
                                                 WidthRequest="6"
                                                 CornerRadius="3"
                                                 Color="{Binding MarkerColor}"
                                                 IsVisible="{Binding HasWorkout}" />
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource CardBorder}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Saved Workouts"
                           Style="{StaticResource SubHeadline}"
                           HorizontalTextAlignment="Start" />

                    <CollectionView x:Name="SavedWorkoutsView">
                        <CollectionView.EmptyView>
                            <Label Text="No workout saved for this date."
                                   HorizontalOptions="Center"
                                   Margin="0,8,0,0"
                                   Style="{StaticResource BodyMuted}" />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource CardBorder}"
                                        BackgroundColor="{StaticResource SurfaceRaised}"
                                        Padding="14"
                                        Margin="0,0,0,10">
                                    <Grid ColumnDefinitions="*,Auto,Auto"
                                          ColumnSpacing="8">
                                        <VerticalStackLayout Grid.Column="0"
                                                             Spacing="6">
                                            <Label Text="{Binding WorkoutName}"
                                                   FontSize="18" />
                                            <Label Text="{Binding ExercisesText}"
                                                   Style="{StaticResource BodyMuted}" />
                                        </VerticalStackLayout>
                                        <ImageButton Grid.Column="1"
                                                     Source="icon_edit.svg"
                                                     Clicked="OnEditWorkoutInvoked"
                                                     BackgroundColor="#24203A"
                                                     Padding="8"
                                                     WidthRequest="36"
                                                     HeightRequest="36"
                                                     CornerRadius="12"
                                                     VerticalOptions="Start" />
                                        <ImageButton Grid.Column="2"
                                                     Source="icon_delete.svg"
                                                     Clicked="OnDeleteWorkoutInvoked"
                                                     BackgroundColor="#3A1623"
                                                     Padding="8"
                                                     WidthRequest="36"
                                                     HeightRequest="36"
                                                     CornerRadius="12"
                                                     VerticalOptions="Start" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
