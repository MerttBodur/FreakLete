<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FreakLete.ProgramDetailPage"
             NavigationPage.HasNavigationBar="False"
             Title="Program Details"
             BackgroundColor="{StaticResource Background}">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Top Bar -->
        <HorizontalStackLayout Grid.Row="0"
                               Padding="16,14,16,8"
                               Spacing="12"
                               VerticalOptions="Center">
            <Border StrokeShape="RoundRectangle 14"
                    BackgroundColor="{StaticResource SurfaceRaised}"
                    Stroke="{StaticResource SurfaceBorder}"
                    StrokeThickness="1"
                    Padding="10,8"
                    HeightRequest="40"
                    WidthRequest="40">
                <Label Text="&#x2190;"
                       FontSize="18"
                       FontFamily="OpenSansSemibold"
                       TextColor="{StaticResource TextPrimary}"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackClicked" />
                </Border.GestureRecognizers>
            </Border>
            <Label x:Name="PageTitleLabel"
                   Text="Program Details"
                   FontSize="18"
                   FontFamily="OpenSansSemibold"
                   TextColor="{StaticResource TextPrimary}"
                   VerticalOptions="Center" />
        </HorizontalStackLayout>

        <!-- Main Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,8,20,24" Spacing="20">

                <!-- Program Header Card -->
                <Border StrokeShape="RoundRectangle 22"
                        StrokeThickness="1"
                        Padding="0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="{StaticResource AccentSoft}" Offset="0.0" />
                            <GradientStop Color="{StaticResource Surface}" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Stroke>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="{StaticResource Accent}" Offset="0.0" />
                            <GradientStop Color="{StaticResource AccentSoft}" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Stroke>
                    <VerticalStackLayout Padding="22,20" Spacing="10">
                        <HorizontalStackLayout Spacing="10">
                            <Label x:Name="TrainingProgramBadge"
                                   FontSize="11"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource AccentGlow}"
                                   Text="TRAINING PROGRAM"
                                   CharacterSpacing="1.5"
                                   VerticalOptions="Center" />
                            <!-- Status badge inline -->
                            <Border x:Name="StatusBadge"
                                    StrokeShape="RoundRectangle 10"
                                    BackgroundColor="{StaticResource SurfaceRaised}"
                                    Stroke="Transparent"
                                    Padding="10,4"
                                    VerticalOptions="Center"
                                    IsVisible="False">
                                <Label x:Name="StatusBadgeLabel"
                                       FontSize="10"
                                       FontFamily="OpenSansSemibold"
                                       TextColor="{StaticResource TextSecondary}" />
                            </Border>
                        </HorizontalStackLayout>
                        <Label x:Name="ProgramNameLabel"
                               FontSize="26"
                               FontFamily="OpenSansSemibold"
                               TextColor="{StaticResource TextPrimary}"
                               LineBreakMode="WordWrap"
                               LineHeight="1.1" />
                        <Label x:Name="ProgramDescriptionLabel"
                               FontSize="13"
                               FontFamily="OpenSansRegular"
                               TextColor="{StaticResource TextSecondary}"
                               LineBreakMode="WordWrap"
                               MaxLines="4" />

                        <!-- Metadata pills -->
                        <HorizontalStackLayout Spacing="8" Margin="0,4,0,0">
                            <Border x:Name="GoalPill"
                                    StrokeShape="RoundRectangle 10"
                                    BackgroundColor="{StaticResource AccentSoft}"
                                    Stroke="Transparent"
                                    Padding="12,5">
                                <Label x:Name="GoalPillLabel"
                                       FontSize="12"
                                       FontFamily="OpenSansSemibold"
                                       TextColor="{StaticResource AccentGlow}" />
                            </Border>
                            <Border x:Name="FrequencyPill"
                                    StrokeShape="RoundRectangle 10"
                                    BackgroundColor="{StaticResource SurfaceRaised}"
                                    Stroke="{StaticResource SurfaceBorder}"
                                    Padding="12,5">
                                <Label x:Name="FrequencyPillLabel"
                                       FontSize="12"
                                       FontFamily="OpenSansSemibold"
                                       TextColor="{StaticResource TextPrimary}" />
                            </Border>
                            <Border x:Name="DurationPill"
                                    StrokeShape="RoundRectangle 10"
                                    BackgroundColor="{StaticResource SurfaceRaised}"
                                    Stroke="{StaticResource SurfaceBorder}"
                                    Padding="12,5"
                                    IsVisible="False">
                                <Label x:Name="DurationPillLabel"
                                       FontSize="12"
                                       FontFamily="OpenSansSemibold"
                                       TextColor="{StaticResource TextPrimary}" />
                            </Border>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Stats Row -->
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                    <Border Grid.Column="0"
                            StrokeShape="RoundRectangle 18"
                            Stroke="{StaticResource SurfaceBorder}"
                            Padding="14,12">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="{StaticResource SurfaceRaised}" Offset="0.0" />
                                <GradientStop Color="{StaticResource Surface}" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                            <Label x:Name="WeeksCountLabel"
                                   FontSize="24"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource AccentGlow}"
                                   HorizontalTextAlignment="Center"
                                   Text="0" />
                            <Label x:Name="WeeksSubLabel"
                                   FontSize="10"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource TextSecondary}"
                                   HorizontalTextAlignment="Center"
                                   Text="Weeks" />
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="1"
                            StrokeShape="RoundRectangle 18"
                            Stroke="{StaticResource SurfaceBorder}"
                            Padding="14,12">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="{StaticResource SurfaceRaised}" Offset="0.0" />
                                <GradientStop Color="{StaticResource Surface}" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                            <Label x:Name="SessionsCountLabel"
                                   FontSize="24"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource AccentGlow}"
                                   HorizontalTextAlignment="Center"
                                   Text="0" />
                            <Label x:Name="SessionsSubLabel"
                                   FontSize="10"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource TextSecondary}"
                                   HorizontalTextAlignment="Center"
                                   Text="Sessions" />
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="2"
                            StrokeShape="RoundRectangle 18"
                            Stroke="{StaticResource SurfaceBorder}"
                            Padding="14,12">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="{StaticResource SurfaceRaised}" Offset="0.0" />
                                <GradientStop Color="{StaticResource Surface}" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                            <Label x:Name="ExercisesCountLabel"
                                   FontSize="24"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource AccentGlow}"
                                   HorizontalTextAlignment="Center"
                                   Text="0" />
                            <Label x:Name="ExercisesSubLabel"
                                   FontSize="10"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource TextSecondary}"
                                   HorizontalTextAlignment="Center"
                                   Text="Exercises" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Divider -->
                <BoxView HeightRequest="1"
                         Color="{StaticResource SurfaceBorder}"
                         Margin="0,2" />

                <!-- Program Structure Container (built dynamically) -->
                <VerticalStackLayout x:Name="WeeksContainer" Spacing="20" />

            </VerticalStackLayout>
        </ScrollView>

        <!-- Sticky Bottom CTA -->
        <Border Grid.Row="2"
                StrokeShape="RoundRectangle 0"
                Stroke="{StaticResource SurfaceBorder}"
                StrokeThickness="1"
                Padding="20,12,20,18">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="{StaticResource SurfaceRaised}" Offset="0.0" />
                    <GradientStop Color="{StaticResource Surface}" Offset="1.0" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid x:Name="BottomButtonGrid" ColumnDefinitions="*,12,*">
                <!-- Single button for starter templates (shown/hidden in code-behind) -->
                <Button x:Name="StartWorkoutButton"
                        Grid.ColumnSpan="3"
                        Text="Start"
                        BackgroundColor="{StaticResource Accent}"
                        TextColor="White"
                        Padding="24,14"
                        CornerRadius="14"
                        FontSize="15"
                        FontFamily="OpenSansSemibold"
                        Clicked="OnStartWorkoutClicked"
                        HorizontalOptions="FillAndExpand"
                        IsVisible="False" />
                <!-- Two buttons for user-owned programs -->
                <Button x:Name="AddWorkoutButton"
                        Grid.Column="0"
                        Text="Add Workout"
                        BackgroundColor="{StaticResource SurfaceRaised}"
                        TextColor="{StaticResource TextPrimary}"
                        BorderColor="{StaticResource SurfaceBorder}"
                        BorderWidth="1"
                        Padding="16,14"
                        CornerRadius="14"
                        FontSize="14"
                        FontFamily="OpenSansSemibold"
                        Clicked="OnAddWorkoutClicked"
                        HorizontalOptions="FillAndExpand" />
                <Button x:Name="StartLiveWorkoutButton"
                        Grid.Column="2"
                        Text="Start Workout"
                        BackgroundColor="{StaticResource Accent}"
                        TextColor="White"
                        Padding="16,14"
                        CornerRadius="14"
                        FontSize="14"
                        FontFamily="OpenSansSemibold"
                        Clicked="OnStartWorkoutClicked"
                        HorizontalOptions="FillAndExpand" />
            </Grid>
        </Border>

    </Grid>

</ContentPage>
