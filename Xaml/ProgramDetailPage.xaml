<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FreakLete.ProgramDetailPage"
             NavigationPage.HasNavigationBar="False"
             Title="Program Details"
             BackgroundColor="{StaticResource Background}">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Top Bar -->
        <HorizontalStackLayout Grid.Row="0"
                               Padding="16,14,16,8"
                               Spacing="12"
                               VerticalOptions="Center">
            <Border StrokeShape="RoundRectangle 14"
                    BackgroundColor="{StaticResource SurfaceRaised}"
                    Stroke="{StaticResource SurfaceBorder}"
                    StrokeThickness="1"
                    Padding="10,8"
                    HeightRequest="40"
                    WidthRequest="40">
                <Label Text="&#x2190;"
                       FontSize="18"
                       FontFamily="OpenSansSemibold"
                       TextColor="{StaticResource TextPrimary}"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackClicked" />
                </Border.GestureRecognizers>
            </Border>
            <Label Text="Program Details"
                   FontSize="20"
                   FontFamily="OpenSansSemibold"
                   TextColor="{StaticResource TextPrimary}"
                   VerticalOptions="Center" />
        </HorizontalStackLayout>

        <!-- Main Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,8,20,24" Spacing="20">

                <!-- Program Header Card -->
                <Border StrokeShape="RoundRectangle 24"
                        StrokeThickness="1"
                        Stroke="{StaticResource Primary}"
                        Padding="0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="{StaticResource AccentSoft}" Offset="0.0" />
                            <GradientStop Color="{StaticResource Surface}" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <VerticalStackLayout Padding="24,22" Spacing="12">
                        <Label FontSize="11"
                               FontFamily="OpenSansSemibold"
                               TextColor="{StaticResource AccentGlow}"
                               Text="TRAINING PROGRAM"
                               CharacterSpacing="1.5" />
                        <Label x:Name="ProgramNameLabel"
                               FontSize="28"
                               FontFamily="OpenSansSemibold"
                               TextColor="{StaticResource TextPrimary}"
                               LineBreakMode="WordWrap"
                               LineHeight="1.1" />
                        <Label x:Name="ProgramDescriptionLabel"
                               FontSize="14"
                               FontFamily="OpenSansRegular"
                               TextColor="{StaticResource TextSecondary}"
                               LineBreakMode="WordWrap"
                               MaxLines="4" />

                        <!-- Metadata pills -->
                        <HorizontalStackLayout Spacing="8" Margin="0,6,0,0">
                            <Border x:Name="GoalPill"
                                    StrokeShape="RoundRectangle 12"
                                    BackgroundColor="{StaticResource AccentSoft}"
                                    Stroke="Transparent"
                                    Padding="12,6">
                                <Label x:Name="GoalPillLabel"
                                       FontSize="12"
                                       FontFamily="OpenSansSemibold"
                                       TextColor="{StaticResource AccentGlow}" />
                            </Border>
                            <Border x:Name="FrequencyPill"
                                    StrokeShape="RoundRectangle 12"
                                    BackgroundColor="{StaticResource SurfaceRaised}"
                                    Stroke="{StaticResource SurfaceBorder}"
                                    Padding="12,6">
                                <Label x:Name="FrequencyPillLabel"
                                       FontSize="12"
                                       FontFamily="OpenSansSemibold"
                                       TextColor="{StaticResource TextPrimary}" />
                            </Border>
                            <Border x:Name="DurationPill"
                                    StrokeShape="RoundRectangle 12"
                                    BackgroundColor="{StaticResource SurfaceRaised}"
                                    Stroke="{StaticResource SurfaceBorder}"
                                    Padding="12,6"
                                    IsVisible="False">
                                <Label x:Name="DurationPillLabel"
                                       FontSize="12"
                                       FontFamily="OpenSansSemibold"
                                       TextColor="{StaticResource TextPrimary}" />
                            </Border>
                        </HorizontalStackLayout>

                        <!-- Status badge -->
                        <Border x:Name="StatusBadge"
                                StrokeShape="RoundRectangle 10"
                                BackgroundColor="{StaticResource SurfaceRaised}"
                                Stroke="Transparent"
                                Padding="10,5"
                                HorizontalOptions="Start"
                                IsVisible="False">
                            <Label x:Name="StatusBadgeLabel"
                                   FontSize="11"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource TextSecondary}" />
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <!-- Stats Row -->
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                    <Border Grid.Column="0"
                            StrokeShape="RoundRectangle 16"
                            Stroke="{StaticResource SurfaceBorder}"
                            BackgroundColor="{StaticResource SurfaceRaised}"
                            Padding="14,12">
                        <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                            <Label x:Name="WeeksCountLabel"
                                   FontSize="24"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource TextPrimary}"
                                   HorizontalTextAlignment="Center"
                                   Text="0" />
                            <Label FontSize="10"
                                   FontFamily="OpenSansRegular"
                                   TextColor="{StaticResource TextSecondary}"
                                   HorizontalTextAlignment="Center"
                                   Text="Weeks" />
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="1"
                            StrokeShape="RoundRectangle 16"
                            Stroke="{StaticResource SurfaceBorder}"
                            BackgroundColor="{StaticResource SurfaceRaised}"
                            Padding="14,12">
                        <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                            <Label x:Name="SessionsCountLabel"
                                   FontSize="24"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource TextPrimary}"
                                   HorizontalTextAlignment="Center"
                                   Text="0" />
                            <Label FontSize="10"
                                   FontFamily="OpenSansRegular"
                                   TextColor="{StaticResource TextSecondary}"
                                   HorizontalTextAlignment="Center"
                                   Text="Sessions" />
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="2"
                            StrokeShape="RoundRectangle 16"
                            Stroke="{StaticResource SurfaceBorder}"
                            BackgroundColor="{StaticResource SurfaceRaised}"
                            Padding="14,12">
                        <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                            <Label x:Name="ExercisesCountLabel"
                                   FontSize="24"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource TextPrimary}"
                                   HorizontalTextAlignment="Center"
                                   Text="0" />
                            <Label FontSize="10"
                                   FontFamily="OpenSansRegular"
                                   TextColor="{StaticResource TextSecondary}"
                                   HorizontalTextAlignment="Center"
                                   Text="Exercises" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Program Structure Container (built dynamically) -->
                <VerticalStackLayout x:Name="WeeksContainer" Spacing="20" />

            </VerticalStackLayout>
        </ScrollView>

        <!-- Sticky Bottom CTA -->
        <Border Grid.Row="2"
                BackgroundColor="{StaticResource SurfaceRaised}"
                Stroke="{StaticResource SurfaceBorder}"
                StrokeThickness="1,0,0,0"
                Padding="20,14,20,18"
                StrokeShape="RoundRectangle 0">
            <Button x:Name="StartWorkoutButton"
                    Text="Start Workout"
                    BackgroundColor="{StaticResource Accent}"
                    TextColor="White"
                    Padding="24,16"
                    CornerRadius="16"
                    FontSize="16"
                    FontFamily="OpenSansSemibold"
                    Clicked="OnStartWorkoutClicked"
                    HorizontalOptions="FillAndExpand" />
        </Border>

    </Grid>

</ContentPage>
