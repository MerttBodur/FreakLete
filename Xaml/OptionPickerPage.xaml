<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:FreakLete"
             x:Class="FreakLete.OptionPickerPage"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="Auto,*">
        <VerticalStackLayout Grid.Row="0"
                             Padding="24,18,24,12"
                             Spacing="18">

            <local:TopHeader x:Name="HeaderView"
                             ShowBackButton="True"
                             BackClicked="OnHeaderBackClicked" />

            <Border Style="{StaticResource AccentCardBorder}">
                <VerticalStackLayout Spacing="10">
                    <Label x:Name="BadgeLabel"
                           Text="SELECT"
                           Style="{StaticResource Eyebrow}" />
                    <Label x:Name="PageTitleLabel"
                           Text="Choose Option"
                           Style="{StaticResource Headline}"
                           HorizontalTextAlignment="Start" />
                </VerticalStackLayout>
            </Border>

            <!-- Search bar (hidden for small lists) -->
            <local:InputShell x:Name="SearchContainer"
                              IsVisible="False">
                <Entry x:Name="SearchEntry"
                       Placeholder=""
                       PlaceholderColor="{StaticResource TextMuted}"
                       TextColor="{StaticResource TextPrimary}"
                       BackgroundColor="Transparent"
                       TextChanged="OnSearchTextChanged" />
            </local:InputShell>

            <!-- Category chips (hidden when no categories) -->
            <ScrollView x:Name="CategoryScrollView"
                        Orientation="Horizontal"
                        HorizontalScrollBarVisibility="Never"
                        IsVisible="False">
                <HorizontalStackLayout x:Name="CategoryChipsLayout"
                                       Spacing="8" />
            </ScrollView>
        </VerticalStackLayout>

        <!-- Main content area -->
        <Grid Grid.Row="1">

            <!-- Loading indicator -->
            <VerticalStackLayout x:Name="LoadingView"
                                 IsVisible="False"
                                 VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="12">
                <ActivityIndicator IsRunning="True"
                                   WidthRequest="32"
                                   HeightRequest="32"
                                   Color="{StaticResource Accent}" />
                <Label x:Name="LoadingLabel"
                       Text="Loading..."
                       Style="{StaticResource BodyMuted}"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <!-- Empty state -->
            <VerticalStackLayout x:Name="EmptyView"
                                 IsVisible="False"
                                 VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="8"
                                 Padding="24">
                <Label x:Name="EmptyLabel"
                       Text=""
                       Style="{StaticResource BodyMuted}"
                       HorizontalTextAlignment="Center"
                       FontSize="16" />
                <Label x:Name="EmptyHintLabel"
                       Text=""
                       Style="{StaticResource BodyMuted}"
                       HorizontalTextAlignment="Center"
                       FontSize="13" />
            </VerticalStackLayout>

            <!-- Error state -->
            <VerticalStackLayout x:Name="ErrorView"
                                 IsVisible="False"
                                 VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="12"
                                 Padding="24">
                <Label x:Name="ErrorLabel"
                       Text=""
                       TextColor="Red"
                       HorizontalTextAlignment="Center"
                       FontSize="15" />
                <Button x:Name="RetryButton"
                        Text=""
                        Style="{StaticResource SecondaryButton}"
                        Clicked="OnRetryClicked"
                        HorizontalOptions="Center" />
            </VerticalStackLayout>

            <!-- Options list -->
            <CollectionView x:Name="OptionsCollection"
                            Margin="24,0,24,24"
                            SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardBorder}"
                                BackgroundColor="{Binding Background}"
                                Margin="0,0,0,10"
                                Padding="16">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnOptionTapped" />
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="2">
                                <Label Text="{Binding Text}"
                                       FontSize="17"
                                       TextColor="{Binding Foreground}"
                                       VerticalOptions="Center" />
                                <Label Text="{Binding GroupName}"
                                       FontSize="12"
                                       TextColor="{StaticResource TextMuted}"
                                       IsVisible="{Binding HasGroup}"
                                       VerticalOptions="Center" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </Grid>

</ContentPage>
