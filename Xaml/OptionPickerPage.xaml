<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:FreakLete"
             x:Class="FreakLete.OptionPickerPage"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="Auto,*">
        <VerticalStackLayout Grid.Row="0"
                             Padding="24,18,24,12"
                             Spacing="18">

            <local:TopHeader x:Name="HeaderView"
                             ShowBackButton="True"
                             BackClicked="OnHeaderBackClicked" />

            <Border Style="{StaticResource AccentCardBorder}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="SELECT"
                           Style="{StaticResource Eyebrow}" />
                    <Label x:Name="PageTitleLabel"
                           Text="Choose Option"
                           Style="{StaticResource Headline}"
                           HorizontalTextAlignment="Start" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>

        <CollectionView Grid.Row="1"
                        x:Name="OptionsCollection"
                        Margin="24,0,24,24"
                        SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource CardBorder}"
                            BackgroundColor="{Binding Background}"
                            Margin="0,0,0,10"
                            Padding="16">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnOptionTapped" />
                        </Border.GestureRecognizers>
                        <Label Text="{Binding Text}"
                               FontSize="17"
                               TextColor="{Binding Foreground}"
                               VerticalOptions="Center" />
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>

</ContentPage>
