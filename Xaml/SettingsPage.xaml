<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FreakLete.SettingsPage"
             NavigationPage.HasNavigationBar="False"
             Title="Settings">

    <Grid RowDefinitions="Auto,*"
          BackgroundColor="{StaticResource Background}">

        <!-- Top bar -->
        <Grid Grid.Row="0"
              ColumnDefinitions="Auto,*"
              Padding="16,14"
              ColumnSpacing="12">
            <Label Text="&#x2190;"
                   FontSize="22"
                   TextColor="{StaticResource TextPrimary}"
                   VerticalOptions="Center">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackClicked" />
                </Label.GestureRecognizers>
            </Label>
            <Label Grid.Column="1"
                   Text="Ayarlar"
                   FontSize="20"
                   FontFamily="OpenSansSemibold"
                   TextColor="{StaticResource TextPrimary}"
                   VerticalOptions="Center" />
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="24,12,24,24"
                                 Spacing="12">

                <!-- Change Password -->
                <Border Style="{StaticResource CardBorder}"
                        Padding="16,14">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnChangePasswordClicked" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                        <Label Text="&#x1F512;"
                               FontSize="20"
                               VerticalOptions="Center" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Şifre Değiştir"
                                   FontSize="15"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource TextPrimary}" />
                            <Label Text="Hesap şifrenizi güncelleyin"
                                   FontSize="11"
                                   FontFamily="OpenSansRegular"
                                   TextColor="{StaticResource TextSecondary}" />
                        </VerticalStackLayout>
                        <Label Grid.Column="2"
                               Text="&#x203A;"
                               FontSize="22"
                               TextColor="{StaticResource TextMuted}"
                               VerticalOptions="Center" />
                    </Grid>
                </Border>

                <!-- Language -->
                <Border Style="{StaticResource CardBorder}"
                        Padding="16,14">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLanguageClicked" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                        <Label Text="&#x1F310;"
                               FontSize="20"
                               VerticalOptions="Center" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Dil"
                                   FontSize="15"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource TextPrimary}" />
                            <Label Text="Uygulama dilini değiştirin"
                                   FontSize="11"
                                   FontFamily="OpenSansRegular"
                                   TextColor="{StaticResource TextSecondary}" />
                        </VerticalStackLayout>
                        <Label Grid.Column="2"
                               Text="&#x203A;"
                               FontSize="22"
                               TextColor="{StaticResource TextMuted}"
                               VerticalOptions="Center" />
                    </Grid>
                </Border>

                <!-- Leave Review -->
                <Border Style="{StaticResource CardBorder}"
                        Padding="16,14">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLeaveReviewClicked" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                        <Label Text="&#x2B50;"
                               FontSize="20"
                               VerticalOptions="Center" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Yorum Bırak"
                                   FontSize="15"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource TextPrimary}" />
                            <Label Text="Uygulamamızı değerlendirin"
                                   FontSize="11"
                                   FontFamily="OpenSansRegular"
                                   TextColor="{StaticResource TextSecondary}" />
                        </VerticalStackLayout>
                        <Label Grid.Column="2"
                               Text="&#x203A;"
                               FontSize="22"
                               TextColor="{StaticResource TextMuted}"
                               VerticalOptions="Center" />
                    </Grid>
                </Border>

                <!-- Donate -->
                <Border Style="{StaticResource CardBorder}"
                        Padding="16,14">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnDonateClicked" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                        <Label Text="&#x2764;"
                               FontSize="20"
                               VerticalOptions="Center" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Bağış Yap"
                                   FontSize="15"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource TextPrimary}" />
                            <Label Text="Geliştirmeyi destekleyin"
                                   FontSize="11"
                                   FontFamily="OpenSansRegular"
                                   TextColor="{StaticResource TextSecondary}" />
                        </VerticalStackLayout>
                        <Label Grid.Column="2"
                               Text="&#x203A;"
                               FontSize="22"
                               TextColor="{StaticResource TextMuted}"
                               VerticalOptions="Center" />
                    </Grid>
                </Border>

                <!-- Subscribe -->
                <Border Style="{StaticResource CardBorder}"
                        Padding="16,14">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSubscribeClicked" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                        <Label Text="&#x1F451;"
                               FontSize="20"
                               VerticalOptions="Center" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Abone Ol"
                                   FontSize="15"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource TextPrimary}" />
                            <Label Text="Premium özelliklerin kilidini açın"
                                   FontSize="11"
                                   FontFamily="OpenSansRegular"
                                   TextColor="{StaticResource TextSecondary}" />
                        </VerticalStackLayout>
                        <Label Grid.Column="2"
                               Text="&#x203A;"
                               FontSize="22"
                               TextColor="{StaticResource TextMuted}"
                               VerticalOptions="Center" />
                    </Grid>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>
