<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FreakLete.SettingsPage"
             NavigationPage.HasNavigationBar="False"
             Title="Settings">

    <Grid RowDefinitions="Auto,*"
          BackgroundColor="{StaticResource Background}">

        <!-- Top bar -->
        <Grid Grid.Row="0"
              ColumnDefinitions="Auto,*"
              Padding="16,14"
              ColumnSpacing="12">
            <Label Text="&#x2190;"
                   FontSize="22"
                   TextColor="{StaticResource TextPrimary}"
                   VerticalOptions="Center">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackClicked" />
                </Label.GestureRecognizers>
            </Label>
            <Label x:Name="PageTitle"
                   Grid.Column="1"
                   Text="Settings"
                   FontSize="20"
                   FontFamily="OpenSansSemibold"
                   TextColor="{StaticResource TextPrimary}"
                   VerticalOptions="Center" />
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="24,12,24,24"
                                 Spacing="12">

                <!-- Change Password -->
                <Border Style="{StaticResource CardBorder}"
                        Padding="16,14">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnChangePasswordClicked" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                        <Label Text="&#x1F512;"
                               FontSize="20"
                               VerticalOptions="Center" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label x:Name="LblChangePassword"
                                   Text="Change Password"
                                   FontSize="15"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource TextPrimary}" />
                            <Label x:Name="LblChangePasswordDesc"
                                   Text="Update your account password"
                                   FontSize="11"
                                   FontFamily="OpenSansRegular"
                                   TextColor="{StaticResource TextSecondary}" />
                        </VerticalStackLayout>
                        <Label Grid.Column="2"
                               Text="&#x203A;"
                               FontSize="22"
                               TextColor="{StaticResource TextMuted}"
                               VerticalOptions="Center" />
                    </Grid>
                </Border>

                <!-- Language -->
                <Border Style="{StaticResource CardBorder}"
                        Padding="16,14">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLanguageClicked" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                        <Label Text="&#x1F310;"
                               FontSize="20"
                               VerticalOptions="Center" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label x:Name="LblLanguage"
                                   Text="Language"
                                   FontSize="15"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource TextPrimary}" />
                            <Label x:Name="LblLanguageDesc"
                                   Text="Change app language"
                                   FontSize="11"
                                   FontFamily="OpenSansRegular"
                                   TextColor="{StaticResource TextSecondary}" />
                        </VerticalStackLayout>
                        <Border Grid.Column="2"
                                BackgroundColor="{StaticResource AccentSoft}"
                                StrokeThickness="0"
                                Padding="8,4"
                                StrokeShape="RoundRectangle 10">
                            <Label x:Name="LblLanguageCurrent"
                                   Text="English"
                                   FontSize="10"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource AccentGlow}" />
                        </Border>
                    </Grid>
                </Border>

                <!-- Leave Review -->
                <Border Style="{StaticResource CardBorder}"
                        Padding="16,14"
                        Opacity="0.5">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnComingSoonClicked" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                        <Label Text="&#x2B50;"
                               FontSize="20"
                               VerticalOptions="Center" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label x:Name="LblReview"
                                   Text="Leave Review"
                                   FontSize="15"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource TextPrimary}" />
                            <Label x:Name="LblReviewDesc"
                                   Text="Rate our app"
                                   FontSize="11"
                                   FontFamily="OpenSansRegular"
                                   TextColor="{StaticResource TextSecondary}" />
                        </VerticalStackLayout>
                        <Border Grid.Column="2"
                                BackgroundColor="{StaticResource AccentSoft}"
                                StrokeThickness="0"
                                Padding="8,4"
                                StrokeShape="RoundRectangle 10">
                            <Label x:Name="LblReviewBadge"
                                   Text="Soon"
                                   FontSize="10"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource AccentGlow}" />
                        </Border>
                    </Grid>
                </Border>

                <!-- Donate -->
                <Border Style="{StaticResource CardBorder}"
                        Padding="16,14"
                        Opacity="0.5">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnComingSoonClicked" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                        <Label Text="&#x2764;"
                               FontSize="20"
                               VerticalOptions="Center" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label x:Name="LblDonate"
                                   Text="Donate"
                                   FontSize="15"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource TextPrimary}" />
                            <Label x:Name="LblDonateDesc"
                                   Text="Support development"
                                   FontSize="11"
                                   FontFamily="OpenSansRegular"
                                   TextColor="{StaticResource TextSecondary}" />
                        </VerticalStackLayout>
                        <Border Grid.Column="2"
                                BackgroundColor="{StaticResource AccentSoft}"
                                StrokeThickness="0"
                                Padding="8,4"
                                StrokeShape="RoundRectangle 10">
                            <Label x:Name="LblDonateBadge"
                                   Text="Soon"
                                   FontSize="10"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource AccentGlow}" />
                        </Border>
                    </Grid>
                </Border>

                <!-- Subscribe -->
                <Border Style="{StaticResource CardBorder}"
                        Padding="16,14"
                        Opacity="0.5">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnComingSoonClicked" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                        <Label Text="&#x1F451;"
                               FontSize="20"
                               VerticalOptions="Center" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label x:Name="LblSubscribe"
                                   Text="Subscribe"
                                   FontSize="15"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource TextPrimary}" />
                            <Label x:Name="LblSubscribeDesc"
                                   Text="Unlock premium features"
                                   FontSize="11"
                                   FontFamily="OpenSansRegular"
                                   TextColor="{StaticResource TextSecondary}" />
                        </VerticalStackLayout>
                        <Border Grid.Column="2"
                                BackgroundColor="{StaticResource AccentSoft}"
                                StrokeThickness="0"
                                Padding="8,4"
                                StrokeShape="RoundRectangle 10">
                            <Label x:Name="LblSubscribeBadge"
                                   Text="Soon"
                                   FontSize="10"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource AccentGlow}" />
                        </Border>
                    </Grid>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Language picker overlay -->
        <Grid x:Name="LanguageOverlay"
              Grid.RowSpan="2"
              IsVisible="False"
              Opacity="0"
              BackgroundColor="{StaticResource OverlayScrim}"
              Padding="24">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnLanguageOverlayDismiss" />
            </Grid.GestureRecognizers>
            <Border Style="{StaticResource CardBorder}"
                    Padding="20"
                    VerticalOptions="Center"
                    HorizontalOptions="Center"
                    MaximumWidthRequest="420"
                    BackgroundColor="{StaticResource SurfaceRaised}">
                <VerticalStackLayout Spacing="14">
                    <Label x:Name="LangPickerTitle"
                           Text="Select Language"
                           Style="{StaticResource SubHeadline}"
                           HorizontalTextAlignment="Start" />

                    <Button x:Name="BtnLangEnglish"
                            Text="English"
                            Clicked="OnLangEnglishClicked"
                            FontFamily="OpenSansSemibold"
                            FontSize="15"
                            HeightRequest="48"
                            CornerRadius="18" />

                    <Button x:Name="BtnLangTurkish"
                            Text="Türkçe"
                            Clicked="OnLangTurkishClicked"
                            FontFamily="OpenSansSemibold"
                            FontSize="15"
                            HeightRequest="48"
                            CornerRadius="18" />

                    <Button x:Name="BtnLangCancel"
                            Text="Cancel"
                            Style="{StaticResource SecondaryButton}"
                            Clicked="OnLanguageOverlayDismiss"
                            Margin="0,4,0,0" />
                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- Coming soon toast -->
        <Border x:Name="ToastBanner"
                Grid.RowSpan="2"
                IsVisible="False"
                Opacity="0"
                BackgroundColor="{StaticResource AccentSoft}"
                StrokeThickness="1"
                Stroke="{StaticResource Accent}"
                StrokeShape="RoundRectangle 12"
                Padding="16,12"
                HorizontalOptions="Center"
                VerticalOptions="End"
                Margin="24,0,24,32">
            <HorizontalStackLayout Spacing="8">
                <Label Text="&#x1F6A7;"
                       FontSize="16"
                       VerticalOptions="Center" />
                <Label x:Name="ToastText"
                       Text="This feature is coming soon!"
                       FontSize="13"
                       FontFamily="OpenSansSemibold"
                       TextColor="{StaticResource AccentGlow}"
                       VerticalOptions="Center" />
            </HorizontalStackLayout>
        </Border>
    </Grid>

</ContentPage>
