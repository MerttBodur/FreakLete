<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             NavigationPage.HasNavigationBar="False"
             x:Class="GymTracker.LoginPage">

    <ScrollView>
        <VerticalStackLayout Padding="24,36,24,30"
                             Spacing="18">

            <Border Style="{StaticResource AccentCardBorder}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="GYM TRACKER"
                           Style="{StaticResource Eyebrow}" />
                    <Label Text="Welcome back."
                           Style="{StaticResource Headline}"
                           HorizontalTextAlignment="Start" />
                    <Label Text="Login to continue building workouts, PRs, and performance records."
                           Style="{StaticResource BodyMuted}" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource CardBorder}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Email"
                           Style="{StaticResource BodyMuted}" />
                    <Entry x:Name="EmailEntry"
                           Placeholder="Enter your email"
                           Keyboard="Email" />

                    <Label Text="Password"
                           Style="{StaticResource BodyMuted}" />
                    <Entry x:Name="PasswordEntry"
                           Placeholder="Enter your password"
                           IsPassword="True" />

                    <Label x:Name="ErrorLabel"
                           TextColor="{StaticResource Danger}"
                           FontSize="13"
                           IsVisible="False" />

                    <Button x:Name="LoginBtn"
                            Text="Login"
                            Clicked="OnLoginClicked"
                            HorizontalOptions="Fill" />

                    <Button x:Name="RegisterBtn"
                            Text="Create Account"
                            Style="{StaticResource SecondaryButton}"
                            Clicked="OnRegisterClicked"
                            HorizontalOptions="Fill" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
