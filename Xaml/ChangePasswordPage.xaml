<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FreakLete.ChangePasswordPage"
             NavigationPage.HasNavigationBar="False"
             Title="Change Password">

    <Grid RowDefinitions="Auto,*"
          BackgroundColor="{StaticResource Background}">

        <!-- Top bar -->
        <Grid Grid.Row="0"
              ColumnDefinitions="Auto,*"
              Padding="16,14"
              ColumnSpacing="12">
            <Label Text="&#x2190;"
                   FontSize="22"
                   TextColor="{StaticResource TextPrimary}"
                   VerticalOptions="Center">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackClicked" />
                </Label.GestureRecognizers>
            </Label>
            <Label Grid.Column="1"
                   Text="Şifre Değiştir"
                   FontSize="20"
                   FontFamily="OpenSansSemibold"
                   TextColor="{StaticResource TextPrimary}"
                   VerticalOptions="Center" />
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="24,12,24,24"
                                 Spacing="14">

                <Border Style="{StaticResource CardBorder}">
                    <VerticalStackLayout Spacing="12">

                        <Label Text="E-posta"
                               Style="{StaticResource BodyMuted}" />
                        <Entry x:Name="EmailEntry"
                               Placeholder="E-posta adresiniz"
                               Keyboard="Email" />

                        <Label Text="Mevcut Şifre"
                               Style="{StaticResource BodyMuted}" />
                        <Entry x:Name="CurrentPasswordEntry"
                               Placeholder="Mevcut şifrenizi girin"
                               IsPassword="True" />

                        <Label Text="Yeni Şifre"
                               Style="{StaticResource BodyMuted}" />
                        <Entry x:Name="NewPasswordEntry"
                               Placeholder="Yeni şifrenizi girin"
                               IsPassword="True" />

                        <Label Text="Yeni Şifre Tekrar"
                               Style="{StaticResource BodyMuted}" />
                        <Entry x:Name="NewPasswordRepeatEntry"
                               Placeholder="Yeni şifrenizi tekrar girin"
                               IsPassword="True" />

                        <Border Style="{StaticResource CardBorder}"
                                BackgroundColor="{StaticResource SurfaceRaised}"
                                Padding="14">
                            <Label Text="Şifre kuralları: en az 8 karakter, 1 büyük harf ve 1 özel karakter."
                                   Style="{StaticResource BodyMuted}" />
                        </Border>

                        <Label x:Name="ErrorLabel"
                               TextColor="{StaticResource Danger}"
                               FontSize="13"
                               IsVisible="False" />

                        <Label x:Name="SuccessLabel"
                               TextColor="{StaticResource Success}"
                               FontSize="13"
                               IsVisible="False" />

                        <Button x:Name="SubmitButton"
                                Text="Şifreyi Değiştir"
                                Clicked="OnSubmitClicked"
                                HorizontalOptions="Fill" />

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>
