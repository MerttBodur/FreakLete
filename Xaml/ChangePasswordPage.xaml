<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:FreakLete"
             x:Class="FreakLete.ChangePasswordPage"
             NavigationPage.HasNavigationBar="False"
             Title="Change Password">

    <Grid RowDefinitions="Auto,*"
          BackgroundColor="{StaticResource Background}">

        <!-- Top bar -->
        <Grid Grid.Row="0"
              ColumnDefinitions="Auto,*"
              Padding="16,14"
              ColumnSpacing="12">
            <Label Text="&#x2190;"
                   FontSize="22"
                   TextColor="{StaticResource TextPrimary}"
                   VerticalOptions="Center">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackClicked" />
                </Label.GestureRecognizers>
            </Label>
            <Label x:Name="PageTitle"
                   Grid.Column="1"
                   Text="Change Password"
                   FontSize="20"
                   FontFamily="OpenSansSemibold"
                   TextColor="{StaticResource TextPrimary}"
                   VerticalOptions="Center" />
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="24,12,24,24"
                                 Spacing="14">

                <Border Style="{StaticResource CardBorder}">
                    <VerticalStackLayout Spacing="12">

                        <Label x:Name="CpEmailLabel"
                               Text="Email"
                               Style="{StaticResource BodyMuted}" />
                        <local:InputShell>
                            <Entry x:Name="EmailEntry"
                                   Placeholder="Your email address"
                                   Keyboard="Email" />
                        </local:InputShell>

                        <Label x:Name="CpCurrentLabel"
                               Text="Current Password"
                               Style="{StaticResource BodyMuted}" />
                        <local:InputShell>
                            <Entry x:Name="CurrentPasswordEntry"
                                   Placeholder="Enter your current password"
                                   IsPassword="True" />
                        </local:InputShell>

                        <Label x:Name="CpNewLabel"
                               Text="New Password"
                               Style="{StaticResource BodyMuted}" />
                        <local:InputShell>
                            <Entry x:Name="NewPasswordEntry"
                                   Placeholder="Enter your new password"
                                   IsPassword="True" />
                        </local:InputShell>

                        <Label x:Name="CpRepeatLabel"
                               Text="New Password Repeat"
                               Style="{StaticResource BodyMuted}" />
                        <local:InputShell>
                            <Entry x:Name="NewPasswordRepeatEntry"
                                   Placeholder="Repeat your new password"
                                   IsPassword="True" />
                        </local:InputShell>

                        <Border Style="{StaticResource CardBorder}"
                                BackgroundColor="{StaticResource SurfaceRaised}"
                                Padding="14">
                            <Label x:Name="CpRulesLabel"
                                   Text="Password rules: at least 8 characters, 1 uppercase letter, and 1 special character."
                                   Style="{StaticResource BodyMuted}" />
                        </Border>

                        <Label x:Name="ErrorLabel"
                               TextColor="{StaticResource Danger}"
                               FontSize="13"
                               IsVisible="False" />

                        <Label x:Name="SuccessLabel"
                               TextColor="{StaticResource Success}"
                               FontSize="13"
                               IsVisible="False" />

                        <Button x:Name="SubmitButton"
                                Text="Change Password"
                                Clicked="OnSubmitClicked"
                                HorizontalOptions="Fill" />

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>
