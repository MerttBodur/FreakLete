<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:FreakLete"
             x:Class="FreakLete.CalculationsPage"
             NavigationPage.HasNavigationBar="False"
             Title="Calculations">

    <Grid RowDefinitions="*,Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="24,18,24,24"
                                 Spacing="20">

                <!-- Page Title -->
                <VerticalStackLayout Spacing="4">
                    <Label x:Name="CalcTitleLabel"
                           FontSize="32"
                           FontFamily="OpenSansSemibold"
                           TextColor="{StaticResource TextPrimary}"
                           Text="Progress" />
                    <Label x:Name="CalcSubtitleLabel"
                           FontSize="14"
                           FontFamily="OpenSansRegular"
                           TextColor="{StaticResource TextSecondary}"
                           Text="Track your personal records" />
                </VerticalStackLayout>

                <!-- Exercise Selection Chips (horizontal scroll) -->
                <ScrollView x:Name="ExerciseChipsScroll"
                            Orientation="Horizontal"
                            HorizontalScrollBarVisibility="Never">
                    <HorizontalStackLayout x:Name="ExerciseChipsContainer"
                                           Spacing="8" />
                </ScrollView>

                <!-- Empty Dashboard State -->
                <Border x:Name="EmptyDashboardCard"
                        StrokeShape="RoundRectangle 20"
                        Stroke="{StaticResource SurfaceBorder}"
                        BackgroundColor="{StaticResource SurfaceRaised}"
                        Padding="24,28"
                        IsVisible="False">
                    <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                        <Label x:Name="NoPrsLabel"
                               FontSize="18"
                               FontFamily="OpenSansSemibold"
                               TextColor="{StaticResource TextPrimary}"
                               Text="No PRs recorded yet"
                               HorizontalTextAlignment="Center" />
                        <Label x:Name="NoPrsDescLabel"
                               FontSize="14"
                               FontFamily="OpenSansRegular"
                               TextColor="{StaticResource TextSecondary}"
                               Text="Save a personal record below to see your progress here"
                               HorizontalTextAlignment="Center"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Border>

                <!-- Hero PR Card -->
                <Border x:Name="HeroPrCard"
                        StrokeShape="RoundRectangle 24"
                        StrokeThickness="1"
                        Stroke="{StaticResource Primary}"
                        Padding="0"
                        IsVisible="False">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="{StaticResource AccentSoft}" Offset="0.0" />
                            <GradientStop Color="{StaticResource Surface}" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <VerticalStackLayout Padding="24,22" Spacing="8">
                        <Label x:Name="HeroPrExerciseLabel"
                               FontSize="11"
                               FontFamily="OpenSansSemibold"
                               TextColor="{StaticResource AccentGlow}"
                               CharacterSpacing="1.5" />
                        <Label x:Name="HeroPrStrengthLabel"
                               FontSize="11"
                               FontFamily="OpenSansSemibold"
                               TextColor="{StaticResource TextSecondary}"
                               CharacterSpacing="0.5" />
                        <Label x:Name="HeroPrValueLabel"
                               FontSize="42"
                               FontFamily="OpenSansSemibold"
                               TextColor="{StaticResource TextPrimary}"
                               LineHeight="1.0" />
                        <Label x:Name="HeroPrDateLabel"
                               FontSize="12"
                               FontFamily="OpenSansRegular"
                               TextColor="{StaticResource TextSecondary}" />
                    </VerticalStackLayout>
                </Border>

                <!-- Real Line/Area Chart -->
                <Border x:Name="ChartCard"
                        StrokeShape="RoundRectangle 20"
                        Stroke="{StaticResource SurfaceBorder}"
                        BackgroundColor="{StaticResource SurfaceRaised}"
                        Padding="16,14"
                        IsVisible="False">
                    <VerticalStackLayout Spacing="10">
                        <Label x:Name="ChartTitleLabel"
                               FontSize="14"
                               FontFamily="OpenSansSemibold"
                               TextColor="{StaticResource TextPrimary}"
                               Text="PR Progress" />
                        <GraphicsView x:Name="PrChartView"
                                      HeightRequest="180"
                                      HorizontalOptions="FillAndExpand" />
                    </VerticalStackLayout>
                </Border>

                <!-- Divider -->
                <BoxView HeightRequest="1"
                         Color="{StaticResource SurfaceBorder}"
                         Margin="0,6,0,0" />

                <!-- Calculator Sections - Start -->
                <Label x:Name="ToolsSectionLabel"
                       FontSize="18"
                       FontFamily="OpenSansSemibold"
                       TextColor="{StaticResource TextPrimary}"
                       Text="Strength &amp; Athletic Tools"
                       Margin="0,4,0,0" />

                <local:TabSwitcher x:Name="CalcTabSwitcher"
                                   Items="{x:Static local:CalculationsPage.CalcTabItems}" />

                <Border Style="{StaticResource CardBorder}"
                        Padding="8"
                        IsVisible="False">
                    <Grid ColumnDefinitions="*,*,*"
                          ColumnSpacing="8">
                        <Button Grid.Column="0"
                                x:Name="OneRmTabButton"
                                Text="1RM"
                                Clicked="OnOneRmTabClicked" />
                        <Button Grid.Column="1"
                                x:Name="RsiTabButton"
                                Text="RSI"
                                Style="{StaticResource SecondaryButton}"
                                Clicked="OnRsiTabClicked" />
                        <Button Grid.Column="2"
                                x:Name="FfmiTabButton"
                                Text="FFMI"
                                Style="{StaticResource SecondaryButton}"
                                Clicked="OnFfmiTabClicked" />
                    </Grid>
                </Border>

                <VerticalStackLayout x:Name="OneRmSection"
                                     Spacing="18">
                    <Border Style="{StaticResource CardBorder}">
                        <VerticalStackLayout Spacing="12">
                            <Label x:Name="StrengthEstimateLabel"
                                   Text="Strength Estimate"
                                   Style="{StaticResource SubHeadline}"
                                   HorizontalTextAlignment="Start" />

                            <Label x:Name="StrengthMovementLabel"
                                   Text="Strength movement"
                                   Style="{StaticResource BodyMuted}" />
                            <Border Style="{StaticResource CardBorder}"
                                    BackgroundColor="{StaticResource SurfaceRaised}"
                                    Padding="14">
                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="10">
                                    <VerticalStackLayout Grid.Column="0"
                                                         Spacing="4">
                                        <Label x:Name="SelectedStrengthExerciseLabel"
                                               Text="No strength movement selected"
                                               FontSize="18" />
                                        <Label x:Name="SelectedStrengthExerciseHintLabel"
                                               Text="Browse weighted movements for the 1RM estimate."
                                               Style="{StaticResource BodyMuted}" />
                                    </VerticalStackLayout>

                                    <Button x:Name="BrowseStrengthBtn"
                                            Grid.Column="1"
                                            Text="Browse"
                                            Style="{StaticResource SecondaryButton}"
                                            Clicked="OnChooseStrengthExerciseClicked"
                                            VerticalOptions="Center" />
                                </Grid>
                            </Border>

                            <Grid ColumnDefinitions="*,*"
                                  ColumnSpacing="12">
                                <VerticalStackLayout Grid.Column="0"
                                                     Spacing="8">
                                    <Label x:Name="WeightRangeLabel"
                                           Text="Weight (kg): 40 - 250"
                                           Style="{StaticResource BodyMuted}" />
                                    <local:InputShell>
                                        <Entry x:Name="WeightEntry"
                                               Keyboard="Numeric"
                                               Placeholder="Example: 100" />
                                    </local:InputShell>
                                </VerticalStackLayout>

                                <VerticalStackLayout Grid.Column="1"
                                                     Spacing="8">
                                    <Label x:Name="RepsRangeLabel"
                                           Text="Reps: 1 - 8"
                                           Style="{StaticResource BodyMuted}" />
                                    <local:InputShell>
                                        <Entry x:Name="RepsEntry"
                                               Keyboard="Numeric"
                                               Placeholder="Example: 5" />
                                    </local:InputShell>
                                </VerticalStackLayout>
                            </Grid>

                            <Grid ColumnDefinitions="*,*"
                                  ColumnSpacing="12">
                                <VerticalStackLayout Grid.Column="0"
                                                     Spacing="8">
                                    <Label x:Name="RirRangeLabel"
                                           Text="RIR: 0 - 5"
                                           Style="{StaticResource BodyMuted}" />
                                    <local:InputShell>
                                        <Entry x:Name="RirEntry"
                                               Keyboard="Numeric"
                                               Placeholder="Example: 1" />
                                    </local:InputShell>
                                </VerticalStackLayout>

                                <VerticalStackLayout Grid.Column="1"
                                                     Spacing="8">
                                    <Label x:Name="ConcentricTimeLbl"
                                           Text="Concentric Time (s)"
                                           Style="{StaticResource BodyMuted}" />
                                    <local:InputShell>
                                        <Entry x:Name="ConcentricTimeEntry"
                                               Keyboard="Numeric"
                                               Placeholder="Optional" />
                                    </local:InputShell>
                                </VerticalStackLayout>
                            </Grid>

                            <Button x:Name="CalculateBtn"
                                    Text="Calculate"
                                    Clicked="OnCalculateOneRmClicked" />

                            <Label x:Name="OneRmStatusLabel"
                                   TextColor="{StaticResource Danger}"
                                   IsVisible="False"
                                   FontSize="13" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Style="{StaticResource CardBorder}">
                        <VerticalStackLayout Spacing="12">
                            <Label x:Name="CalcRangeLabel"
                                   Text="Calculated Range"
                                   Style="{StaticResource SubHeadline}"
                                   HorizontalTextAlignment="Start" />

                            <Label x:Name="OneRmPrimaryValueLabel"
                                   Text=""
                                   FontSize="36"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource AccentGlow}" />
                            <Label x:Name="OneRmPrimaryCaptionLabel"
                                   Text="Estimated 1RM"
                                   Style="{StaticResource Eyebrow}" />
                            <Label x:Name="OneRmSecondaryLabel"
                                   Text="No 1RM calculated yet."
                                   LineBreakMode="WordWrap"
                                   Style="{StaticResource BodyMuted}" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- 1RM Insight Card -->
                    <Border x:Name="OneRmInsightCard"
                            Style="{StaticResource CardBorder}"
                            IsVisible="False">
                        <VerticalStackLayout Spacing="8">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label x:Name="OneRmInsightTitleLabel"
                                       Grid.Column="0"
                                       Text="Analysis"
                                       Style="{StaticResource SubHeadline}"
                                       FontSize="15" />
                                <Border Grid.Column="1"
                                        x:Name="OneRmInsightBandBadge"
                                        StrokeShape="RoundRectangle 10"
                                        Stroke="Transparent"
                                        BackgroundColor="{StaticResource AccentSoft}"
                                        Padding="10,4">
                                    <Label x:Name="OneRmInsightBandLabel"
                                           FontSize="11"
                                           FontFamily="OpenSansSemibold"
                                           TextColor="{StaticResource AccentGlow}" />
                                </Border>
                            </Grid>
                            <Label x:Name="OneRmInsightSummaryLabel"
                                   Style="{StaticResource BodyMuted}"
                                   LineBreakMode="WordWrap" />
                            <Label x:Name="OneRmInsightSportLabel"
                                   Style="{StaticResource BodyMuted}"
                                   FontSize="12"
                                   LineBreakMode="WordWrap" />
                            <Label x:Name="OneRmInsightGlobalLabel"
                                   FontSize="11"
                                   FontFamily="OpenSansRegular"
                                   TextColor="{StaticResource TextMuted}"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Style="{StaticResource CardBorder}">
                        <VerticalStackLayout Spacing="12">
                            <Label x:Name="SavePrTitle"
                                   Text="Save PR"
                                   Style="{StaticResource SubHeadline}"
                                   HorizontalTextAlignment="Start" />

                            <Label x:Name="MovementLabel"
                                   Text="Movement"
                                   Style="{StaticResource BodyMuted}" />
                            <Border Style="{StaticResource CardBorder}"
                                    BackgroundColor="{StaticResource SurfaceRaised}"
                                    Padding="14">
                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="10">
                                    <VerticalStackLayout Grid.Column="0"
                                                         Spacing="4">
                                        <Label x:Name="SelectedPrExerciseLabel"
                                               Text="No PR movement selected"
                                               FontSize="18" />
                                        <Label x:Name="SelectedPrExerciseHintLabel"
                                               Text="Browse gym and athletic movements before saving a PR."
                                               Style="{StaticResource BodyMuted}" />
                                    </VerticalStackLayout>

                                    <Button x:Name="BrowsePrBtn"
                                            Grid.Column="1"
                                            Text="Browse"
                                            Style="{StaticResource SecondaryButton}"
                                            Clicked="OnChoosePrExerciseClicked"
                                            VerticalOptions="Center" />
                                </Grid>
                            </Border>

                            <VerticalStackLayout x:Name="PrStrengthInputsSection"
                                                 Spacing="12"
                                                 IsVisible="False">
                                <Grid ColumnDefinitions="*,*"
                                      ColumnSpacing="12">
                                    <VerticalStackLayout Grid.Column="0"
                                                         Spacing="8">
                                        <Label x:Name="PrWeightLabel"
                                               Text="Weight (kg)"
                                               Style="{StaticResource BodyMuted}" />
                                        <local:InputShell>
                                            <Entry x:Name="PrWeightEntry"
                                                   Keyboard="Numeric"
                                                   Placeholder="Example: 100" />
                                        </local:InputShell>
                                    </VerticalStackLayout>

                                    <VerticalStackLayout Grid.Column="1"
                                                         Spacing="8">
                                        <Label x:Name="PrRepsLabel"
                                               Text="Reps"
                                               Style="{StaticResource BodyMuted}" />
                                        <local:InputShell>
                                            <Entry x:Name="PrRepsEntry"
                                                   Keyboard="Numeric"
                                                   Placeholder="Example: 5" />
                                        </local:InputShell>
                                    </VerticalStackLayout>
                                </Grid>

                                <Grid ColumnDefinitions="*,*"
                                      ColumnSpacing="12">
                                    <VerticalStackLayout Grid.Column="0"
                                                         Spacing="8">
                                        <Label x:Name="PrRirLabel"
                                               Text="RIR"
                                               Style="{StaticResource BodyMuted}" />
                                        <local:InputShell>
                                            <Entry x:Name="PrRirEntry"
                                                   Keyboard="Numeric"
                                                   Placeholder="Optional" />
                                        </local:InputShell>
                                    </VerticalStackLayout>

                                    <VerticalStackLayout Grid.Column="1"
                                                         Spacing="8">
                                        <Label x:Name="PrConcentricTimeLbl"
                                               Text="Concentric Time (s)"
                                               Style="{StaticResource BodyMuted}" />
                                        <local:InputShell>
                                            <Entry x:Name="PrConcentricTimeEntry"
                                                   Keyboard="Numeric"
                                                   Placeholder="Optional" />
                                        </local:InputShell>
                                    </VerticalStackLayout>
                                </Grid>
                            </VerticalStackLayout>

                            <VerticalStackLayout x:Name="PrCustomInputsSection"
                                                 Spacing="12"
                                                 IsVisible="False">
                                <VerticalStackLayout Spacing="8">
                                    <Label x:Name="PrMetric1Label"
                                           Text="Metric 1"
                                           Style="{StaticResource BodyMuted}" />
                                    <local:InputShell>
                                        <Entry x:Name="PrMetric1Entry"
                                               Keyboard="Numeric"
                                               Placeholder="Enter value" />
                                    </local:InputShell>
                                </VerticalStackLayout>

                                <VerticalStackLayout x:Name="PrMetric2Container"
                                                     Spacing="8"
                                                     IsVisible="False">
                                    <Label x:Name="PrMetric2Label"
                                           Text="Metric 2"
                                           Style="{StaticResource BodyMuted}" />
                                    <local:InputShell>
                                        <Entry x:Name="PrMetric2Entry"
                                               Keyboard="Numeric"
                                               Placeholder="Enter value" />
                                    </local:InputShell>
                                </VerticalStackLayout>

                                <VerticalStackLayout x:Name="PrGctContainer"
                                                     Spacing="8"
                                                     IsVisible="False">
                                    <Label x:Name="PrGctLabel"
                                           Text="Ground Contact Time (s)"
                                           Style="{StaticResource BodyMuted}" />
                                    <local:InputShell>
                                        <Entry x:Name="PrGroundContactTimeEntry"
                                               Keyboard="Numeric"
                                               Placeholder="Optional (e.g. 1.96)" />
                                    </local:InputShell>
                                </VerticalStackLayout>
                            </VerticalStackLayout>

                            <Grid ColumnDefinitions="*,*"
                                  ColumnSpacing="12">
                                <Button Grid.Column="0"
                                        x:Name="SavePrButton"
                                        Text="Save PR"
                                        Clicked="OnSavePrClicked" />
                                <Button Grid.Column="1"
                                        x:Name="CancelPrEditButton"
                                        Text="Cancel"
                                        Style="{StaticResource SecondaryButton}"
                                        IsVisible="False"
                                        Clicked="OnCancelPrEditClicked" />
                            </Grid>

                            <Label x:Name="PrStatusLabel"
                                   TextColor="{StaticResource Danger}"
                                   IsVisible="False"
                                   FontSize="13" />
                            <Label x:Name="NextMilestoneLabel"
                                   FontFamily="OpenSansRegular"
                                   FontSize="12"
                                   TextColor="{StaticResource TextMuted}"
                                   IsVisible="False" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Style="{StaticResource CardBorder}">
                        <VerticalStackLayout Spacing="12">
                            <Label x:Name="SavedPrEntriesLabel"
                                   Text="Saved PR Entries"
                                   Style="{StaticResource SubHeadline}"
                                   HorizontalTextAlignment="Start" />

                            <CollectionView x:Name="SavedPrView">
                                <CollectionView.EmptyView>
                                    <Label x:Name="NoSavedPrLabel"
                                           Text="No saved PR yet."
                                           HorizontalOptions="Center"
                                           Style="{StaticResource BodyMuted}" />
                                </CollectionView.EmptyView>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource CardBorder}"
                                                BackgroundColor="{StaticResource SurfaceRaised}"
                                                Padding="14"
                                                Margin="0,0,0,10">
                                            <Grid ColumnDefinitions="*,Auto,Auto,Auto"
                                                  ColumnSpacing="8">
                                                <Label Grid.Column="0"
                                                       Text="{Binding Text}"
                                                       VerticalOptions="Center"
                                                       LineBreakMode="TailTruncation" />
                                                <Border Grid.Column="1"
                                                        IsVisible="{Binding HasTierBadge}"
                                                        StrokeShape="RoundRectangle 8"
                                                        StrokeThickness="0"
                                                        BackgroundColor="{Binding TierBadgeBackgroundColor}"
                                                        Padding="8,4"
                                                        VerticalOptions="Center">
                                                    <Label Text="{Binding TierBadgeText}"
                                                           FontSize="10"
                                                           FontFamily="OpenSansSemibold"
                                                           TextColor="{Binding TierBadgeTextColor}"
                                                           HorizontalTextAlignment="Center"
                                                           VerticalTextAlignment="Center" />
                                                </Border>
                                                <ImageButton Grid.Column="2"
                                                             Source="icon_edit.svg"
                                                             Clicked="OnEditSavedPrInvoked"
                                                             BackgroundColor="{StaticResource EditSoft}"
                                                             Padding="8"
                                                             WidthRequest="36"
                                                             HeightRequest="36"
                                                             CornerRadius="12" />
                                                <ImageButton Grid.Column="3"
                                                             Source="icon_delete.svg"
                                                             Clicked="OnDeleteSavedPrInvoked"
                                                             BackgroundColor="{StaticResource DangerSoft}"
                                                             Padding="8"
                                                             WidthRequest="36"
                                                             HeightRequest="36"
                                                             CornerRadius="12" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout x:Name="RsiSection"
                                     Spacing="18"
                                     IsVisible="False">
                    <Border Style="{StaticResource CardBorder}">
                        <VerticalStackLayout Spacing="12">
                            <Label x:Name="RsiTitleLabel"
                                   Text="Reactive Strength Index"
                                   Style="{StaticResource SubHeadline}"
                                   HorizontalTextAlignment="Start" />
                            <Label x:Name="RsiDescLabel"
                                   Text="RSI uses jump height and ground contact time to estimate reactive output."
                                   Style="{StaticResource BodyMuted}" />

                            <Grid ColumnDefinitions="*,*"
                                  ColumnSpacing="12">
                                <VerticalStackLayout Grid.Column="0"
                                                     Spacing="8">
                                    <Label x:Name="JumpHeightLabel"
                                           Text="Jump Height (cm)"
                                           Style="{StaticResource BodyMuted}" />
                                    <local:InputShell>
                                        <Entry x:Name="RsiJumpHeightEntry"
                                               Keyboard="Numeric"
                                               Placeholder="Example: 42.5" />
                                    </local:InputShell>
                                </VerticalStackLayout>

                                <VerticalStackLayout Grid.Column="1"
                                                     Spacing="8">
                                    <Label x:Name="GctLabel"
                                           Text="GCT (s)"
                                           Style="{StaticResource BodyMuted}" />
                                    <local:InputShell>
                                        <Entry x:Name="RsiGroundContactTimeEntry"
                                               Keyboard="Numeric"
                                               Placeholder="Example: 0.21" />
                                    </local:InputShell>
                                </VerticalStackLayout>
                            </Grid>

                            <Button x:Name="CalculateRsiBtn"
                                    Text="Calculate RSI"
                                    Clicked="OnCalculateRsiClicked" />

                            <Label x:Name="RsiStatusLabel"
                                   TextColor="{StaticResource Danger}"
                                   IsVisible="False"
                                   FontSize="13" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Style="{StaticResource CardBorder}">
                        <VerticalStackLayout Spacing="12">
                            <Label x:Name="RsiResultTitle"
                                   Text="Result"
                                   Style="{StaticResource SubHeadline}"
                                   HorizontalTextAlignment="Start" />

                            <Label x:Name="RsiPrimaryValueLabel"
                                   Text=""
                                   FontSize="36"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource AccentGlow}" />
                            <Label x:Name="RsiPrimaryCaptionLabel"
                                   Text="Reactive Strength Index"
                                   Style="{StaticResource Eyebrow}" />
                            <Label x:Name="RsiSecondaryLabel"
                                   Text="No RSI calculated yet."
                                   Style="{StaticResource BodyMuted}" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- RSI Insight Card -->
                    <Border x:Name="RsiInsightCard"
                            Style="{StaticResource CardBorder}"
                            IsVisible="False">
                        <VerticalStackLayout Spacing="8">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label x:Name="RsiInsightTitleLabel"
                                       Grid.Column="0"
                                       Text="Analysis"
                                       Style="{StaticResource SubHeadline}"
                                       FontSize="15" />
                                <Border Grid.Column="1"
                                        x:Name="RsiInsightBandBadge"
                                        StrokeShape="RoundRectangle 10"
                                        Stroke="Transparent"
                                        BackgroundColor="{StaticResource AccentSoft}"
                                        Padding="10,4">
                                    <Label x:Name="RsiInsightBandLabel"
                                           FontSize="11"
                                           FontFamily="OpenSansSemibold"
                                           TextColor="{StaticResource AccentGlow}" />
                                </Border>
                            </Grid>
                            <Label x:Name="RsiInsightSummaryLabel"
                                   Style="{StaticResource BodyMuted}"
                                   LineBreakMode="WordWrap" />
                            <Label x:Name="RsiInsightSportLabel"
                                   Style="{StaticResource BodyMuted}"
                                   FontSize="12"
                                   LineBreakMode="WordWrap" />
                            <Label x:Name="RsiInsightGlobalLabel"
                                   FontSize="11"
                                   FontFamily="OpenSansRegular"
                                   TextColor="{StaticResource TextMuted}"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout x:Name="FfmiSection"
                                     Spacing="18"
                                     IsVisible="False">

                    <Border x:Name="FfmiMissingDataCard"
                            Style="{StaticResource CardBorder}"
                            IsVisible="False">
                        <VerticalStackLayout Spacing="12"
                                             HorizontalOptions="Center">
                            <Label x:Name="FfmiMissingDataLabel"
                                   Text="FFMI requires weight, height, and body fat percentage in your profile."
                                   Style="{StaticResource BodyMuted}"
                                   HorizontalTextAlignment="Center"
                                   LineBreakMode="WordWrap" />
                            <Button x:Name="FfmiGoToProfileBtn"
                                    Text="Edit Profile"
                                    Style="{StaticResource SecondaryButton}"
                                    Clicked="OnFfmiGoToProfileClicked" />
                        </VerticalStackLayout>
                    </Border>

                    <Border x:Name="FfmiInputCard"
                            Style="{StaticResource CardBorder}">
                        <VerticalStackLayout Spacing="12">
                            <Label x:Name="FfmiTitleLabel"
                                   Text="Fat-Free Mass Index"
                                   Style="{StaticResource SubHeadline}"
                                   HorizontalTextAlignment="Start" />
                            <Label x:Name="FfmiDescLabel"
                                   Text="FFMI evaluates your lean body mass relative to your height."
                                   Style="{StaticResource BodyMuted}" />

                            <Grid ColumnDefinitions="*,*"
                                  ColumnSpacing="12">
                                <VerticalStackLayout Grid.Column="0"
                                                     Spacing="8">
                                    <Label x:Name="FfmiWeightLabel"
                                           Text="Weight (kg)"
                                           Style="{StaticResource BodyMuted}" />
                                    <local:InputShell>
                                        <Entry x:Name="FfmiWeightEntry"
                                               Keyboard="Numeric"
                                               Placeholder="80" />
                                    </local:InputShell>
                                </VerticalStackLayout>

                                <VerticalStackLayout Grid.Column="1"
                                                     Spacing="8">
                                    <Label x:Name="FfmiHeightLabel"
                                           Text="Height (cm)"
                                           Style="{StaticResource BodyMuted}" />
                                    <local:InputShell>
                                        <Entry x:Name="FfmiHeightEntry"
                                               Keyboard="Numeric"
                                               Placeholder="178" />
                                    </local:InputShell>
                                </VerticalStackLayout>
                            </Grid>

                            <VerticalStackLayout Spacing="8">
                                <Label x:Name="FfmiBodyFatLabel"
                                       Text="Body Fat (%)"
                                       Style="{StaticResource BodyMuted}" />
                                <local:InputShell>
                                    <Entry x:Name="FfmiBodyFatEntry"
                                           Keyboard="Numeric"
                                           Placeholder="15" />
                                </local:InputShell>
                            </VerticalStackLayout>

                            <Button x:Name="CalculateFfmiBtn"
                                    Text="Calculate FFMI"
                                    Clicked="OnCalculateFfmiClicked" />

                            <Label x:Name="FfmiStatusLabel"
                                   TextColor="{StaticResource Danger}"
                                   IsVisible="False"
                                   FontSize="13" />
                        </VerticalStackLayout>
                    </Border>

                    <Border x:Name="FfmiResultCard"
                            Style="{StaticResource CardBorder}">
                        <VerticalStackLayout Spacing="12">
                            <Label x:Name="FfmiResultTitle"
                                   Text="Result"
                                   Style="{StaticResource SubHeadline}"
                                   HorizontalTextAlignment="Start" />

                            <Label x:Name="FfmiNormalizedLabel"
                                   Text=""
                                   FontSize="36"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource AccentGlow}" />
                            <Label x:Name="FfmiNormalizedCaption"
                                   Text="NORMALIZED FFMI"
                                   Style="{StaticResource Eyebrow}" />

                            <Label x:Name="FfmiSecondaryLabel"
                                   Text="No FFMI calculated yet."
                                   Style="{StaticResource BodyMuted}" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- FFMI Insight Card -->
                    <Border x:Name="FfmiInsightCard"
                            Style="{StaticResource CardBorder}"
                            IsVisible="False">
                        <VerticalStackLayout Spacing="8">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label x:Name="FfmiInsightTitleLabel"
                                       Grid.Column="0"
                                       Text="Analysis"
                                       Style="{StaticResource SubHeadline}"
                                       FontSize="15" />
                                <Border Grid.Column="1"
                                        x:Name="FfmiInsightBandBadge"
                                        StrokeShape="RoundRectangle 10"
                                        Stroke="Transparent"
                                        BackgroundColor="{StaticResource AccentSoft}"
                                        Padding="10,4">
                                    <Label x:Name="FfmiInsightBandLabel"
                                           FontSize="11"
                                           FontFamily="OpenSansSemibold"
                                           TextColor="{StaticResource AccentGlow}" />
                                </Border>
                            </Grid>
                            <Label x:Name="FfmiInsightSummaryLabel"
                                   Style="{StaticResource BodyMuted}"
                                   LineBreakMode="WordWrap" />
                            <Label x:Name="FfmiInsightSportLabel"
                                   Style="{StaticResource BodyMuted}"
                                   FontSize="12"
                                   LineBreakMode="WordWrap" />
                            <Label x:Name="FfmiInsightGlobalLabel"
                                   FontSize="11"
                                   FontFamily="OpenSansRegular"
                                   TextColor="{StaticResource TextMuted}"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <local:BottomNavBar Grid.Row="1"
                            ActiveTab="calculations" />
    </Grid>

</ContentPage>
