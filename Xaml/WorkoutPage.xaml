<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:FreakLete"
             x:Class="FreakLete.WorkoutPage"
             NavigationPage.HasNavigationBar="False"
             Title="Workout"
             BackgroundColor="{StaticResource Background}">

    <Grid RowDefinitions="*,Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="16,12,16,24"
                                 Spacing="18">

                <!-- Page Title -->
                <HorizontalStackLayout Spacing="12" VerticalOptions="Start">
                    <Label FontSize="32"
                           FontFamily="OpenSansSemibold"
                           TextColor="{StaticResource TextPrimary}"
                           Text="Workout"
                           HorizontalOptions="FillAndExpand" />
                    <ImageButton x:Name="HeaderCalendarButton"
                                Source="calendar_icon.svg"
                                Clicked="OnHeaderCalendarClicked"
                                WidthRequest="44"
                                HeightRequest="44"
                                BackgroundColor="Transparent"
                                Aspect="AspectFit" />
                </HorizontalStackLayout>

                <!-- Hero Card: Premium Workout Building -->
                <Border StrokeShape="RoundRectangle 24"
                        Stroke="{StaticResource Accent}"
                        StrokeThickness="2"
                        BackgroundColor="{StaticResource AccentSoft}"
                        Padding="0"
                        MinimumHeightRequest="168">
                    <Grid Padding="0" RowDefinitions="Auto,*">
                        <!-- Top gradient bar with accent -->
                        <BoxView Grid.Row="0"
                                BackgroundColor="{StaticResource Accent}"
                                HeightRequest="6" />
                        
                        <!-- Content area with strong hierarchy and gradient depth -->
                        <Grid Grid.Row="1" Padding="0">
                            <BoxView BackgroundColor="{StaticResource AccentSoft}" />
                            <VerticalStackLayout Padding="28,20,28,20"
                                               Spacing="16"
                                               VerticalOptions="FillAndExpand">
                                <!-- Badge with subtle background -->
                                <Label FontSize="11"
                                       FontFamily="OpenSansSemibold"
                                       TextColor="{StaticResource AccentGlow}"
                                       Text="READY TO TRAIN"
                                       CharacterSpacing="1.8" />
                                
                                <!-- Strong Headline - More Visual Weight -->
                                <Label FontSize="30"
                                       FontFamily="OpenSansSemibold"
                                       TextColor="{StaticResource TextPrimary}"
                                       LineBreakMode="WordWrap"
                                       LineHeight="1.1">
                                    <Label.Text>Start your session</Label.Text>
                                </Label>

                                <!-- CTA Button - Full Width, Premium Style -->
                                <Button x:Name="StartWorkoutButton"
                                        Text="Begin Workout"
                                        BackgroundColor="{StaticResource Accent}"
                                        TextColor="White"
                                        Padding="24,18"
                                        CornerRadius="16"
                                        FontSize="16"
                                        FontFamily="OpenSansSemibold"
                                        Clicked="OnOpenNewWorkoutClicked"
                                        HorizontalOptions="FillAndExpand" />
                            </VerticalStackLayout>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Secondary Actions Row - Visual Emphasis -->
                <Grid ColumnDefinitions="*,*" 
                      ColumnSpacing="12">
                    
                    <!-- Quick Builder - Mini Hero Surface -->
                    <Border Grid.Column="0"
                            StrokeShape="RoundRectangle 18"
                            Stroke="{StaticResource Accent}"
                            StrokeThickness="2"
                            BackgroundColor="{StaticResource AccentSoft}"
                            Padding="0">
                        <VerticalStackLayout Padding="20,18,20,18" Spacing="12" VerticalOptions="Center" HorizontalOptions="Center">
                            <!-- Icon with Premium Border Circle -->
                            <Border StrokeShape="RoundRectangle 14"
                                    Stroke="{StaticResource Accent}"
                                    StrokeThickness="2"
                                    BackgroundColor="Transparent"
                                    Padding="8"
                                    HorizontalOptions="Center">
                                <Label FontSize="20"
                                       FontFamily="OpenSansSemibold"
                                       TextColor="{StaticResource Accent}"
                                       Text="+"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>
                            <Label FontSize="15"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource TextPrimary}"
                                   Text="Quick Add"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnOpenNewWorkoutClicked" />
                        </Border.GestureRecognizers>
                    </Border>

                    <!-- Calendar Access - Premium Surface -->
                    <Border Grid.Column="1"
                            StrokeShape="RoundRectangle 18"
                            Stroke="{StaticResource Accent}"
                            StrokeThickness="2"
                            BackgroundColor="{StaticResource AccentSoft}"
                            Padding="0">
                        <VerticalStackLayout Padding="20,18,20,18" Spacing="12" VerticalOptions="Center" HorizontalOptions="Center">
                            <!-- Calendar Icon with Border Circle -->
                            <Border StrokeShape="RoundRectangle 14"
                                    Stroke="{StaticResource Accent}"
                                    StrokeThickness="2"
                                    BackgroundColor="Transparent"
                                    Padding="8"
                                    HorizontalOptions="Center">
                                <Label FontSize="20"
                                       FontFamily="OpenSansSemibold"
                                       TextColor="{StaticResource Accent}"
                                       Text="📅"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>
                            <Label FontSize="15"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource TextPrimary}"
                                   Text="Calendar"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnOpenCalendarPageClicked" />
                        </Border.GestureRecognizers>
                    </Border>
                </Grid>

                <!-- Stats Row: Real Dashboard Metrics -->
                <Grid ColumnDefinitions="*,*" 
                      ColumnSpacing="12">
                    
                    <!-- Sessions This Week - Real Data -->
                    <Border Grid.Column="0"
                            StrokeShape="RoundRectangle 16"
                            Stroke="{StaticResource SurfaceBorder}"
                            StrokeThickness="1"
                            BackgroundColor="{StaticResource SurfaceRaised}"
                            Padding="16">
                        <VerticalStackLayout Spacing="8" VerticalOptions="Center" HorizontalOptions="Center">
                            <Label FontSize="10"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource TextSecondary}"
                                   CharacterSpacing="0.5"
                                   Text="THIS WEEK" />
                            <Label x:Name="SessionsCountLabel"
                                   FontSize="32"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource TextPrimary}"
                                   Text="0"
                                   HorizontalTextAlignment="Center" />
                            <Label FontSize="10"
                                   FontFamily="OpenSansRegular"
                                   TextColor="{StaticResource TextSecondary}"
                                   Text="sessions"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Available Programs Count - Real Data -->
                    <Border Grid.Column="1"
                            StrokeShape="RoundRectangle 16"
                            Stroke="{StaticResource Accent}"
                            StrokeThickness="1"
                            BackgroundColor="{StaticResource AccentSoft}"
                            Padding="16">
                        <VerticalStackLayout Spacing="8" VerticalOptions="Center" HorizontalOptions="Center">
                            <Label FontSize="10"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource AccentGlow}"
                                   CharacterSpacing="0.5"
                                   Text="PROGRAMS" />
                            <Label x:Name="ProgramCountLabel"
                                   FontSize="32"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource TextPrimary}"
                                   Text="0"
                                   HorizontalTextAlignment="Center" />
                            <Label FontSize="10"
                                   FontFamily="OpenSansRegular"
                                   TextColor="{StaticResource TextSecondary}"
                                   Text="available"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Training Programs Section Header -->
                <VerticalStackLayout Spacing="2" Margin="0,8,0,0">
                    <Label FontSize="18"
                           FontFamily="OpenSansSemibold"
                           TextColor="{StaticResource TextPrimary}"
                           Text="Training Programs" />
                </VerticalStackLayout>

                <!-- Training Templates - Premium Design -->
                <CollectionView x:Name="TemplatesCollectionView"
                                SelectionMode="Single">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical"
                                         ItemSpacing="10" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border StrokeShape="RoundRectangle 18"
                                    Stroke="{StaticResource Accent}"
                                    StrokeThickness="1"
                                    BackgroundColor="{StaticResource SurfaceRaised}"
                                    Padding="0"
                                    MinimumHeightRequest="100">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="0" Padding="0">
                                    <!-- Left Content Area - Rich Hierarchy -->
                                    <VerticalStackLayout Grid.Column="0" 
                                                        Padding="24,18,20,18"
                                                        Spacing="12"
                                                        VerticalOptions="Center">
                                        <!-- Program Name - Bold Primary -->
                                        <Label Text="{Binding Name}"
                                               FontSize="18"
                                               FontFamily="OpenSansSemibold"
                                               TextColor="{StaticResource TextPrimary}"
                                               LineBreakMode="TailTruncation" />
                                        
                                        <!-- Goal + Frequency - Better Visual Separation -->
                                        <Grid ColumnDefinitions="*,1,*" ColumnSpacing="16" RowSpacing="0">
                                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                                <Label FontSize="9"
                                                       FontFamily="OpenSansSemibold"
                                                       TextColor="{StaticResource Accent}"
                                                       CharacterSpacing="0.6"
                                                       Text="GOAL" />
                                                <Label Text="{Binding Goal}"
                                                       FontSize="14"
                                                       FontFamily="OpenSansSemibold"
                                                       TextColor="{StaticResource TextPrimary}"
                                                       LineBreakMode="TailTruncation" />
                                            </VerticalStackLayout>

                                            <BoxView Grid.Column="1"
                                                    BackgroundColor="{StaticResource SurfaceBorder}"
                                                    WidthRequest="1"
                                                    Opacity="0.3" />

                                            <VerticalStackLayout Grid.Column="2" Spacing="4">
                                                <Label FontSize="9"
                                                       FontFamily="OpenSansSemibold"
                                                       TextColor="{StaticResource Accent}"
                                                       CharacterSpacing="0.6"
                                                       Text="FREQUENCY" />
                                                <Label Text="{Binding DaysPerWeek, StringFormat='{0}x/week'}"
                                                       FontSize="14"
                                                       FontFamily="OpenSansSemibold"
                                                       TextColor="{StaticResource TextPrimary}" />
                                            </VerticalStackLayout>
                                        </Grid>
                                    </VerticalStackLayout>

                                    <!-- Right: Premium Accent Bar with Chevron Icon -->
                                    <Grid Grid.Column="1"
                                          BackgroundColor="{StaticResource Accent}"
                                          WidthRequest="56"
                                          Padding="0">
                                        <Label Text="▸"
                                               FontSize="22"
                                               FontFamily="OpenSansSemibold"
                                               TextColor="White"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center" />
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Empty State for Templates -->
                <Label x:Name="NoTemplatesLabel"
                       Text="No training templates available"
                       FontSize="14"
                       TextColor="{StaticResource TextSecondary}"
                       HorizontalTextAlignment="Center"
                       IsVisible="False"
                       Margin="0,20,0,0" />

            </VerticalStackLayout>
        </ScrollView>

        <local:BottomNavBar Grid.Row="1"
                            ActiveTab="workout" />
    </Grid>

</ContentPage>