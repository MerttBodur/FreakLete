<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:FreakLete"
             x:Class="FreakLete.WorkoutPage"
             NavigationPage.HasNavigationBar="False"
             Title="Workout">

    <Grid RowDefinitions="*,Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="24,18,24,20"
                                 Spacing="18">

                <local:TopHeader Title="Workout"
                                 ActionIcon="calendar_icon.svg"
                                 ActionClicked="OnHeaderCalendarClicked" />

                <Border Style="{StaticResource AccentCardBorder}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="WORKOUT BUILDER"
                               Style="{StaticResource Eyebrow}" />
                        <Label Text="Create clean sessions and keep your training history organized."
                               Style="{StaticResource Headline}"
                               HorizontalTextAlignment="Start" />
                        <Label Text="Log the day, add exercises, and check your saved sessions from the calendar."
                               Style="{StaticResource BodyMuted}" />
                    </VerticalStackLayout>
                </Border>

                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="12">
                    <Border Grid.Column="0"
                            Style="{StaticResource CardBorder}">
                        <VerticalStackLayout Spacing="12">
                            <Label Text="Start a Session"
                                   Style="{StaticResource SubHeadline}"
                                   HorizontalTextAlignment="Start" />
                            <Label Text="Build a new workout with date, name, exercise list, and set details."
                                   Style="{StaticResource BodyMuted}" />
                            <Button Text="New Workout"
                                    Clicked="OnOpenNewWorkoutClicked" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="1"
                            Style="{StaticResource CardBorder}">
                        <VerticalStackLayout Spacing="12">
                            <Label Text="Review History"
                                   Style="{StaticResource SubHeadline}"
                                   HorizontalTextAlignment="Start" />
                            <Label Text="Open the calendar to view, edit, or remove saved sessions by day."
                                   Style="{StaticResource BodyMuted}" />
                            <Button Style="{StaticResource SecondaryButton}"
                                    Text="Calendar"
                                    Clicked="OnOpenCalendarPageClicked" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <Border Style="{StaticResource CardBorder}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Flow"
                               Style="{StaticResource Eyebrow}" />
                        <Label Text="Pick a date, name the workout, add exercises, then confirm the session."
                               FontSize="18"
                               LineBreakMode="WordWrap" />
                        <Label Text="Later, you can return from Calendar to update or remove that workout."
                               Style="{StaticResource BodyMuted}" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <local:BottomNavBar Grid.Row="1"
                            ActiveTab="workout" />
    </Grid>

</ContentPage>
