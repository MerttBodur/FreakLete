<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:FreakLete"
             x:Class="FreakLete.WorkoutPage"
             NavigationPage.HasNavigationBar="False"
             Title="Workout"
             BackgroundColor="{StaticResource Background}">

    <Grid RowDefinitions="*,Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20,16,20,24"
                                 Spacing="20">

                <!-- Page Header -->
                <VerticalStackLayout Spacing="4">
                    <Label FontSize="32"
                           FontFamily="OpenSansSemibold"
                           TextColor="{StaticResource TextPrimary}"
                           Text="Programs" />
                    <Label FontSize="14"
                           FontFamily="OpenSansRegular"
                           TextColor="{StaticResource TextSecondary}"
                           Text="Your training plans" />
                </VerticalStackLayout>

                <!-- Hero Card: Active Program -->
                <Border x:Name="HeroProgramCard"
                        StrokeShape="RoundRectangle 24"
                        StrokeThickness="1"
                        Stroke="{StaticResource Primary}"
                        Padding="0"
                        IsVisible="False">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="{StaticResource AccentSoft}" Offset="0.0" />
                            <GradientStop Color="{StaticResource Surface}" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <VerticalStackLayout Padding="24,22" Spacing="14">
                        <Label FontSize="11"
                               FontFamily="OpenSansSemibold"
                               TextColor="{StaticResource AccentGlow}"
                               Text="ACTIVE PROGRAM"
                               CharacterSpacing="1.5" />
                        <Label x:Name="HeroProgramName"
                               FontSize="26"
                               FontFamily="OpenSansSemibold"
                               TextColor="{StaticResource TextPrimary}"
                               LineBreakMode="WordWrap"
                               LineHeight="1.1" />
                        <Label x:Name="HeroProgramGoal"
                               FontSize="14"
                               FontFamily="OpenSansRegular"
                               TextColor="{StaticResource TextSecondary}" />

                        <!-- Stat pills row -->
                        <HorizontalStackLayout Spacing="8" Margin="0,4,0,0">
                            <Border x:Name="HeroFrequencyPill"
                                    StrokeShape="RoundRectangle 12"
                                    BackgroundColor="{StaticResource SurfaceRaised}"
                                    Stroke="{StaticResource SurfaceBorder}"
                                    Padding="10,5">
                                <Label x:Name="HeroFrequencyLabel"
                                       FontSize="12"
                                       FontFamily="OpenSansSemibold"
                                       TextColor="{StaticResource TextPrimary}" />
                            </Border>
                            <Border x:Name="HeroDurationPill"
                                    StrokeShape="RoundRectangle 12"
                                    BackgroundColor="{StaticResource SurfaceRaised}"
                                    Stroke="{StaticResource SurfaceBorder}"
                                    Padding="10,5"
                                    IsVisible="False">
                                <Label x:Name="HeroDurationLabel"
                                       FontSize="12"
                                       FontFamily="OpenSansSemibold"
                                       TextColor="{StaticResource TextPrimary}" />
                            </Border>
                            <Border x:Name="HeroWeeklyPill"
                                    StrokeShape="RoundRectangle 12"
                                    BackgroundColor="{StaticResource AccentSoft}"
                                    Stroke="Transparent"
                                    Padding="10,5">
                                <Label x:Name="HeroWeeklyLabel"
                                       FontSize="12"
                                       FontFamily="OpenSansSemibold"
                                       TextColor="{StaticResource AccentGlow}" />
                            </Border>
                        </HorizontalStackLayout>

                        <!-- CTA -->
                        <Button Text="Start Workout"
                                BackgroundColor="{StaticResource Accent}"
                                TextColor="White"
                                Padding="24,16"
                                CornerRadius="16"
                                FontSize="16"
                                FontFamily="OpenSansSemibold"
                                Clicked="OnHeroStartWorkoutClicked"
                                HorizontalOptions="FillAndExpand"
                                Margin="0,4,0,0" />
                    </VerticalStackLayout>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnHeroCardTapped" />
                    </Border.GestureRecognizers>
                </Border>

                <!-- Empty Hero: No Active Program -->
                <Border x:Name="EmptyHeroCard"
                        StrokeShape="RoundRectangle 24"
                        StrokeThickness="1"
                        Stroke="{StaticResource SurfaceBorder}"
                        BackgroundColor="{StaticResource SurfaceRaised}"
                        Padding="0"
                        IsVisible="True">
                    <VerticalStackLayout Padding="24,28" Spacing="14"
                                         HorizontalOptions="Center">
                        <Label FontSize="11"
                               FontFamily="OpenSansSemibold"
                               TextColor="{StaticResource AccentGlow}"
                               Text="GET STARTED"
                               CharacterSpacing="1.5"
                               HorizontalTextAlignment="Center" />
                        <Label FontSize="22"
                               FontFamily="OpenSansSemibold"
                               TextColor="{StaticResource TextPrimary}"
                               Text="No active program"
                               HorizontalTextAlignment="Center" />
                        <Label FontSize="14"
                               FontFamily="OpenSansRegular"
                               TextColor="{StaticResource TextSecondary}"
                               Text="Create a training program with FreakAI or start a quick workout"
                               HorizontalTextAlignment="Center"
                               LineBreakMode="WordWrap"
                               MaxLines="2" />
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,6,0,0">
                            <Button Grid.Column="0"
                                    Text="FreakAI"
                                    BackgroundColor="{StaticResource Accent}"
                                    TextColor="White"
                                    Padding="16,14"
                                    CornerRadius="14"
                                    FontSize="14"
                                    FontFamily="OpenSansSemibold"
                                    Clicked="OnGoToFreakAiClicked" />
                            <Button Grid.Column="1"
                                    Text="Quick Workout"
                                    BackgroundColor="{StaticResource SurfaceStrong}"
                                    TextColor="{StaticResource TextPrimary}"
                                    Padding="16,14"
                                    CornerRadius="14"
                                    FontSize="14"
                                    FontFamily="OpenSansSemibold"
                                    Clicked="OnOpenNewWorkoutClicked" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Stats Row -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Border Grid.Column="0"
                            StrokeShape="RoundRectangle 16"
                            Stroke="{StaticResource SurfaceBorder}"
                            StrokeThickness="1"
                            BackgroundColor="{StaticResource SurfaceRaised}"
                            Padding="16,14">
                        <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                            <Label FontSize="10"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource TextSecondary}"
                                   CharacterSpacing="0.5"
                                   Text="THIS WEEK"
                                   HorizontalTextAlignment="Center" />
                            <Label x:Name="SessionsCountLabel"
                                   FontSize="28"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource TextPrimary}"
                                   Text="0"
                                   HorizontalTextAlignment="Center" />
                            <Label FontSize="10"
                                   FontFamily="OpenSansRegular"
                                   TextColor="{StaticResource TextSecondary}"
                                   Text="sessions"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="1"
                            StrokeShape="RoundRectangle 16"
                            Stroke="{StaticResource Accent}"
                            StrokeThickness="1"
                            BackgroundColor="{StaticResource AccentSoft}"
                            Padding="16,14">
                        <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                            <Label FontSize="10"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource AccentGlow}"
                                   CharacterSpacing="0.5"
                                   Text="PROGRAMS"
                                   HorizontalTextAlignment="Center" />
                            <Label x:Name="ProgramCountLabel"
                                   FontSize="28"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource TextPrimary}"
                                   Text="0"
                                   HorizontalTextAlignment="Center" />
                            <Label FontSize="10"
                                   FontFamily="OpenSansRegular"
                                   TextColor="{StaticResource TextSecondary}"
                                   Text="available"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Goal Filter Chips -->
                <ScrollView x:Name="GoalChipsScroll"
                            Orientation="Horizontal"
                            HorizontalScrollBarVisibility="Never"
                            IsVisible="False">
                    <HorizontalStackLayout x:Name="GoalChipsContainer"
                                           Spacing="8" />
                </ScrollView>

                <!-- Recommended Workouts Section -->
                <VerticalStackLayout x:Name="RecommendedSection"
                                     Spacing="12"
                                     IsVisible="False">
                    <Label FontSize="18"
                           FontFamily="OpenSansSemibold"
                           TextColor="{StaticResource TextPrimary}"
                           Text="Recommended Workouts" />
                    <VerticalStackLayout x:Name="RecommendedCardsContainer"
                                         Spacing="12" />
                </VerticalStackLayout>

                <!-- Section Header -->
                <Label FontSize="18"
                       FontFamily="OpenSansSemibold"
                       TextColor="{StaticResource TextPrimary}"
                       Text="All Programs"
                       Margin="0,4,0,0" />

                <!-- Program Cards -->
                <CollectionView x:Name="ProgramsCollectionView"
                                SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical"
                                           ItemSpacing="12" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border StrokeShape="RoundRectangle 20"
                                    Stroke="{StaticResource SurfaceBorder}"
                                    StrokeThickness="1"
                                    BackgroundColor="{StaticResource SurfaceRaised}"
                                    Padding="0">
                                <Grid RowDefinitions="Auto,Auto" Padding="0">
                                    <!-- Top: Program info -->
                                    <VerticalStackLayout Grid.Row="0"
                                                         Padding="20,18,20,14"
                                                         Spacing="10">
                                        <HorizontalStackLayout Spacing="10">
                                            <Label Text="{Binding Name}"
                                                   FontSize="17"
                                                   FontFamily="OpenSansSemibold"
                                                   TextColor="{StaticResource TextPrimary}"
                                                   LineBreakMode="TailTruncation"
                                                   HorizontalOptions="FillAndExpand" />
                                            <!-- Status pill -->
                                            <Border StrokeShape="RoundRectangle 10"
                                                    BackgroundColor="{StaticResource AccentSoft}"
                                                    Stroke="Transparent"
                                                    Padding="10,4"
                                                    VerticalOptions="Center">
                                                <Label Text="{Binding Status}"
                                                       FontSize="10"
                                                       FontFamily="OpenSansSemibold"
                                                       TextColor="{StaticResource AccentGlow}" />
                                            </Border>
                                        </HorizontalStackLayout>
                                        <Label Text="{Binding Goal}"
                                               FontSize="13"
                                               FontFamily="OpenSansRegular"
                                               TextColor="{StaticResource TextSecondary}"
                                               LineBreakMode="TailTruncation" />
                                    </VerticalStackLayout>

                                    <!-- Bottom: Metadata bar -->
                                    <Grid Grid.Row="1"
                                          BackgroundColor="{StaticResource Surface}"
                                          Padding="20,10"
                                          ColumnDefinitions="Auto,*,Auto">
                                        <Label Grid.Column="0"
                                               Text="{Binding DaysPerWeek, StringFormat='{0}x/week'}"
                                               FontSize="12"
                                               FontFamily="OpenSansSemibold"
                                               TextColor="{StaticResource TextSecondary}"
                                               VerticalOptions="Center" />
                                        <Label Grid.Column="2"
                                               Text="View Details >"
                                               FontSize="12"
                                               FontFamily="OpenSansSemibold"
                                               TextColor="{StaticResource AccentGlow}"
                                               VerticalOptions="Center" />
                                    </Grid>
                                </Grid>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnProgramCardTapped" />
                                </Border.GestureRecognizers>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Empty State -->
                <Label x:Name="NoProgramsLabel"
                       Text="No training programs yet"
                       FontSize="14"
                       TextColor="{StaticResource TextSecondary}"
                       HorizontalTextAlignment="Center"
                       IsVisible="False"
                       Margin="0,8,0,0" />

                <!-- Quick Actions Row -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Border Grid.Column="0"
                            StrokeShape="RoundRectangle 18"
                            Stroke="{StaticResource SurfaceBorder}"
                            StrokeThickness="1"
                            BackgroundColor="{StaticResource SurfaceRaised}"
                            Padding="0">
                        <VerticalStackLayout Padding="18,16" Spacing="10"
                                             VerticalOptions="Center"
                                             HorizontalOptions="Center">
                            <Border StrokeShape="RoundRectangle 12"
                                    BackgroundColor="{StaticResource AccentSoft}"
                                    Stroke="Transparent"
                                    Padding="8"
                                    HorizontalOptions="Center">
                                <Label FontSize="18"
                                       FontFamily="OpenSansSemibold"
                                       TextColor="{StaticResource AccentGlow}"
                                       Text="+"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>
                            <Label FontSize="14"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource TextPrimary}"
                                   Text="Quick Add"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnOpenNewWorkoutClicked" />
                        </Border.GestureRecognizers>
                    </Border>

                    <Border Grid.Column="1"
                            StrokeShape="RoundRectangle 18"
                            Stroke="{StaticResource SurfaceBorder}"
                            StrokeThickness="1"
                            BackgroundColor="{StaticResource SurfaceRaised}"
                            Padding="0">
                        <VerticalStackLayout Padding="18,16" Spacing="10"
                                             VerticalOptions="Center"
                                             HorizontalOptions="Center">
                            <Border StrokeShape="RoundRectangle 12"
                                    BackgroundColor="{StaticResource AccentSoft}"
                                    Stroke="Transparent"
                                    Padding="8"
                                    HorizontalOptions="Center">
                                <Image Source="calendar_icon.svg"
                                       WidthRequest="18"
                                       HeightRequest="18"
                                       HorizontalOptions="Center" />
                            </Border>
                            <Label FontSize="14"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource TextPrimary}"
                                   Text="Calendar"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnOpenCalendarPageClicked" />
                        </Border.GestureRecognizers>
                    </Border>
                </Grid>

            </VerticalStackLayout>
        </ScrollView>

        <local:BottomNavBar Grid.Row="1"
                            ActiveTab="workout" />
    </Grid>

</ContentPage>
