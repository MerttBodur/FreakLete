<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:FreakLete"
             x:Class="FreakLete.FreakAiPage"
             NavigationPage.HasNavigationBar="False"
             Title="FreakAI">

    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto,Auto,Auto">

        <local:TopHeader Grid.Row="0"
                         Title="FreakAI" />

        <!-- Quick Actions Bar -->
        <ScrollView Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalScrollBarVisibility="Never"
                    Padding="12,4,12,0">
            <HorizontalStackLayout Spacing="8">
                <Button x:Name="BtnGenerateProgram"
                        Text="Generate Program"
                        Style="{StaticResource SecondaryButton}"
                        FontSize="12"
                        Padding="12,6"
                        Clicked="OnGenerateProgramClicked" />
                <Button x:Name="BtnViewProgram"
                        Text="View Program"
                        Style="{StaticResource SecondaryButton}"
                        FontSize="12"
                        Padding="12,6"
                        Clicked="OnViewProgramClicked" />
                <Button x:Name="BtnAnalyzeTraining"
                        Text="Analyze Training"
                        Style="{StaticResource SecondaryButton}"
                        FontSize="12"
                        Padding="12,6"
                        Clicked="OnAnalyzeTrainingClicked" />
                <Button x:Name="BtnNutritionHelp"
                        Text="Nutrition Help"
                        Style="{StaticResource SecondaryButton}"
                        FontSize="12"
                        Padding="12,6"
                        Clicked="OnNutritionHelpClicked" />
            </HorizontalStackLayout>
        </ScrollView>

        <!-- Usage / Plan Card -->
        <Border x:Name="UsageCard"
                Grid.Row="2"
                Style="{StaticResource CardBorder}"
                BackgroundColor="{StaticResource SurfaceRaised}"
                Padding="14,10"
                Margin="12,4,12,0"
                IsVisible="False">
            <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="6">
                <!-- Plan badge -->
                <HorizontalStackLayout Grid.Row="0" Grid.Column="0" Spacing="8" VerticalOptions="Center">
                    <Border BackgroundColor="{StaticResource AccentSoft}"
                            StrokeThickness="0"
                            Padding="8,3"
                            StrokeShape="RoundRectangle 10">
                        <Label x:Name="UsagePlanBadge"
                               Text="Free Plan"
                               FontSize="11"
                               FontFamily="OpenSansSemibold"
                               TextColor="{StaticResource AccentGlow}" />
                    </Border>
                </HorizontalStackLayout>

                <!-- Upgrade CTA (free only) -->
                <Button x:Name="UsageUpgradeBtn"
                        Grid.Row="0" Grid.Column="1"
                        Text="Go Premium"
                        FontSize="11"
                        FontFamily="OpenSansSemibold"
                        BackgroundColor="{StaticResource Accent}"
                        TextColor="{StaticResource TextPrimary}"
                        Padding="10,4"
                        CornerRadius="10"
                        HeightRequest="28"
                        VerticalOptions="Center"
                        Clicked="OnUsageUpgradeClicked" />

                <!-- Quota metrics row -->
                <HorizontalStackLayout Grid.Row="1" Grid.ColumnSpan="2" Spacing="14">
                    <VerticalStackLayout Spacing="1">
                        <Label x:Name="UsageChatLabel"
                               Text="Chat"
                               FontSize="10"
                               FontFamily="OpenSansRegular"
                               TextColor="{StaticResource TextMuted}" />
                        <Label x:Name="UsageChatValue"
                               Text="3/day"
                               FontSize="13"
                               FontFamily="OpenSansSemibold"
                               TextColor="{StaticResource TextPrimary}" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Spacing="1">
                        <Label x:Name="UsageGenerateLabel"
                               Text="Generate"
                               FontSize="10"
                               FontFamily="OpenSansRegular"
                               TextColor="{StaticResource TextMuted}" />
                        <Label x:Name="UsageGenerateValue"
                               Text="1/mo"
                               FontSize="13"
                               FontFamily="OpenSansSemibold"
                               TextColor="{StaticResource TextPrimary}" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Spacing="1">
                        <Label x:Name="UsageAnalyzeLabel"
                               Text="Analyze"
                               FontSize="10"
                               FontFamily="OpenSansRegular"
                               TextColor="{StaticResource TextMuted}" />
                        <Label x:Name="UsageAnalyzeValue"
                               Text="1/mo"
                               FontSize="13"
                               FontFamily="OpenSansSemibold"
                               TextColor="{StaticResource TextPrimary}" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Spacing="1">
                        <Label x:Name="UsageNutritionLabel"
                               Text="Nutrition"
                               FontSize="10"
                               FontFamily="OpenSansRegular"
                               TextColor="{StaticResource TextMuted}" />
                        <Label x:Name="UsageNutritionValue"
                               Text="Ready"
                               FontSize="13"
                               FontFamily="OpenSansSemibold"
                               TextColor="{StaticResource TextPrimary}" />
                    </VerticalStackLayout>
                </HorizontalStackLayout>
            </Grid>
        </Border>

        <ScrollView Grid.Row="3"
                    x:Name="ChatScrollView"
                    Padding="16,0">
            <VerticalStackLayout x:Name="ChatContainer"
                                 Spacing="12"
                                 Padding="0,12,0,12">

                <!-- Welcome message -->
                <Border x:Name="WelcomeBorder"
                        Style="{StaticResource CardBorder}"
                        BackgroundColor="{StaticResource SurfaceRaised}"
                        Padding="16">
                    <VerticalStackLayout Spacing="8">
                        <Label x:Name="WelcomeTitle"
                               Text="FreakAI Coach"
                               FontSize="20"
                               FontAttributes="Bold" />
                        <Label x:Name="WelcomeBody"
                               Text="Your personal hybrid training coach."
                               Style="{StaticResource BodyMuted}" />
                        <Label x:Name="WelcomeHint"
                               Text="Try: 'Write me a program'"
                               Style="{StaticResource BodyMuted}"
                               FontAttributes="Italic" />
                    </VerticalStackLayout>
                </Border>

                <!-- Active Program Card (shown when program exists) -->
                <Border x:Name="ActiveProgramCard"
                        Style="{StaticResource CardBorder}"
                        BackgroundColor="{StaticResource SurfaceRaised}"
                        Padding="14"
                        IsVisible="False">
                    <VerticalStackLayout Spacing="6">
                        <Label x:Name="ActiveProgramLabel"
                               Text="ACTIVE PROGRAM"
                               FontSize="11"
                               FontAttributes="Bold"
                               TextColor="{StaticResource Accent}" />
                        <Label x:Name="ActiveProgramName"
                               Text=""
                               FontSize="16"
                               FontAttributes="Bold" />
                        <Label x:Name="ActiveProgramDetails"
                               Text=""
                               Style="{StaticResource BodyMuted}"
                               FontSize="12" />
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Loading indicator -->
        <HorizontalStackLayout Grid.Row="4"
                               x:Name="LoadingIndicator"
                               IsVisible="False"
                               Padding="20,8"
                               Spacing="8">
            <ActivityIndicator IsRunning="True"
                               WidthRequest="16"
                               HeightRequest="16"
                               Color="{StaticResource Accent}" />
            <Label x:Name="LoadingLabel"
                   Text="FreakAI is thinking..."
                   Style="{StaticResource BodyMuted}"
                   VerticalOptions="Center" />
        </HorizontalStackLayout>

        <!-- Input area -->
        <Border Grid.Row="5"
                Style="{StaticResource CardBorder}"
                BackgroundColor="{StaticResource SurfaceRaised}"
                Stroke="{StaticResource SurfaceBorder}"
                Padding="12"
                Margin="12,4,12,12"
                StrokeShape="RoundRectangle 20">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="8">
                <Editor x:Name="MessageEditor"
                        Grid.Column="0"
                        Placeholder="Ask FreakAI…"
                        AutoSize="TextChanges"
                        MaxLength="2000"
                        HeightRequest="40"
                        FontSize="15"
                        BackgroundColor="Transparent" />
                <ImageButton Grid.Column="1"
                             x:Name="SendButton"
                             Source="icon_send.svg"
                             BackgroundColor="{StaticResource Accent}"
                             WidthRequest="40"
                             HeightRequest="40"
                             CornerRadius="20"
                             Padding="10"
                             Clicked="OnSendClicked"
                             VerticalOptions="End" />
            </Grid>
        </Border>

        <local:BottomNavBar Grid.Row="6"
                            ActiveTab="freakai" />

    </Grid>

</ContentPage>
