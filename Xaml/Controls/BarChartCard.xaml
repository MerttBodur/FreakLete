<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FreakLete.BarChartCard">

	<Border Style="{StaticResource CardBorder}">
		<VerticalStackLayout Spacing="16" Padding="16">
			<Label x:Name="TitleLabel"
			       FontSize="18"
			       FontFamily="OpenSansSemibold"
		       TextColor="{StaticResource TextPrimary}" />
			<VerticalStackLayout x:Name="ChartContainer"
			                     Spacing="12">
			<!-- Weekly Activity Grid -->
			<Grid ColumnDefinitions="*,*,*,*,*,*,*" ColumnSpacing="4" HeightRequest="100">
				<!-- Days of week activity bars -->
				<VerticalStackLayout Grid.Column="0">
					<BoxView BackgroundColor="{StaticResource Primary}" CornerRadius="3" HeightRequest="0" />
					<Label FontSize="9" TextColor="{StaticResource TextSecondary}" Text="Mon" HorizontalOptions="Center" />
				</VerticalStackLayout>
				<VerticalStackLayout Grid.Column="1">
					<BoxView BackgroundColor="{StaticResource Primary}" CornerRadius="3" HeightRequest="0" />
					<Label FontSize="9" TextColor="{StaticResource TextSecondary}" Text="Tue" HorizontalOptions="Center" />
				</VerticalStackLayout>
				<VerticalStackLayout Grid.Column="2">
					<BoxView BackgroundColor="{StaticResource Primary}" CornerRadius="3" HeightRequest="0" />
					<Label FontSize="9" TextColor="{StaticResource TextSecondary}" Text="Wed" HorizontalOptions="Center" />
				</VerticalStackLayout>
				<VerticalStackLayout Grid.Column="3">
					<BoxView BackgroundColor="{StaticResource Primary}" CornerRadius="3" HeightRequest="0" />
					<Label FontSize="9" TextColor="{StaticResource TextSecondary}" Text="Thu" HorizontalOptions="Center" />
				</VerticalStackLayout>
				<VerticalStackLayout Grid.Column="4">
					<BoxView BackgroundColor="{StaticResource Primary}" CornerRadius="3" HeightRequest="0" />
					<Label FontSize="9" TextColor="{StaticResource TextSecondary}" Text="Fri" HorizontalOptions="Center" />
				</VerticalStackLayout>
				<VerticalStackLayout Grid.Column="5">
					<BoxView BackgroundColor="{StaticResource Primary}" CornerRadius="3" HeightRequest="0" />
					<Label FontSize="9" TextColor="{StaticResource TextSecondary}" Text="Sat" HorizontalOptions="Center" />
				</VerticalStackLayout>
				<VerticalStackLayout Grid.Column="6">
					<BoxView BackgroundColor="{StaticResource Primary}" CornerRadius="3" HeightRequest="0" />
					<Label FontSize="9" TextColor="{StaticResource TextSecondary}" Text="Sun" HorizontalOptions="Center" />
				</VerticalStackLayout>
			</Grid>
			<Label FontSize="11" TextColor="{StaticResource TextSecondary}" Text="0 workouts this week" />
			</VerticalStackLayout>
		</VerticalStackLayout>
	</Border>

</ContentView>
