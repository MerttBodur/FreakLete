<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FreakLete.BarChartCard"
             x:Name="BarChartCardView">

	<Border StrokeShape="RoundRectangle 20"
	        Stroke="{StaticResource SurfaceBorder}"
	        StrokeThickness="1"
	        Padding="0">
		<Border.Background>
			<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
				<GradientStop Color="{StaticResource SurfaceRaised}" Offset="0.0" />
				<GradientStop Color="{StaticResource Surface}" Offset="1.0" />
			</LinearGradientBrush>
		</Border.Background>
		<VerticalStackLayout Spacing="14" Padding="18,16">
			<HorizontalStackLayout Spacing="8">
				<Label x:Name="TitleLabel"
				       FontSize="16"
				       FontFamily="OpenSansSemibold"
				       TextColor="{StaticResource TextPrimary}" />
				<Label x:Name="SummaryLabel"
				       FontSize="12"
				       FontFamily="OpenSansRegular"
				       TextColor="{StaticResource TextSecondary}"
				       VerticalOptions="Center"
				       Text="" />
			</HorizontalStackLayout>
			<VerticalStackLayout x:Name="ChartContainer"
			                     Spacing="0">
				<ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
					<HorizontalStackLayout Spacing="6" Padding="0" BindableLayout.ItemsSource="{Binding Items, Source={x:Reference BarChartCardView}}">
						<BindableLayout.ItemTemplate>
							<DataTemplate>
								<VerticalStackLayout Spacing="6" WidthRequest="38">
									<Border StrokeShape="RoundRectangle 4"
									        Stroke="Transparent"
									        HeightRequest="{Binding HeightInPixels}"
									        WidthRequest="28"
									        HorizontalOptions="Center"
									        Padding="0">
										<Border.Background>
											<LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
												<GradientStop Color="{StaticResource AccentGlow}" Offset="0.0" />
												<GradientStop Color="{StaticResource Accent}" Offset="1.0" />
											</LinearGradientBrush>
										</Border.Background>
									</Border>
									<Label Text="{Binding Label}"
									       FontSize="9"
									       FontFamily="OpenSansSemibold"
									       TextColor="{StaticResource TextSecondary}"
									       HorizontalOptions="Center" />
								</VerticalStackLayout>
							</DataTemplate>
						</BindableLayout.ItemTemplate>
					</HorizontalStackLayout>
				</ScrollView>
			</VerticalStackLayout>
		</VerticalStackLayout>
	</Border>

</ContentView>
