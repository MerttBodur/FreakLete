<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FreakLete.BarChartCard"
             x:Name="BarChartCardView">

	<Border Style="{StaticResource CardBorder}">
		<VerticalStackLayout Spacing="16" Padding="16">
			<Label x:Name="TitleLabel"
			       FontSize="18"
			       FontFamily="OpenSansSemibold"
			       TextColor="{StaticResource TextPrimary}" />
			<VerticalStackLayout x:Name="ChartContainer"
			                     Spacing="12">
				<!-- Dynamic Chart using BindableLayout -->
				<ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
					<HorizontalStackLayout Spacing="8" Padding="0,0,0,0" BindableLayout.ItemsSource="{Binding Items, Source={x:Reference BarChartCardView}}">
						<BindableLayout.ItemTemplate>
							<DataTemplate>
								<VerticalStackLayout Spacing="4" WidthRequest="40">
									<BoxView BackgroundColor="{StaticResource Primary}"
									         CornerRadius="3"
									         HeightRequest="{Binding HeightInPixels}"
									         WidthRequest="32" />
									<Label Text="{Binding Label}"
									       FontSize="9"
									       TextColor="{StaticResource TextSecondary}"
									       HorizontalOptions="Center" />
								</VerticalStackLayout>
							</DataTemplate>
						</BindableLayout.ItemTemplate>
					</HorizontalStackLayout>
				</ScrollView>
				<Label x:Name="SummaryLabel"
				       FontSize="11"
				       TextColor="{StaticResource TextSecondary}"
				       Text="" />
			</VerticalStackLayout>
		</VerticalStackLayout>
	</Border>

</ContentView>
