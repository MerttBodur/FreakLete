<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FreakLete.BottomNavBar">

    <Border Style="{StaticResource CardBorder}"
            BackgroundColor="{StaticResource SurfaceRaised}"
            Stroke="{StaticResource SurfaceBorder}"
            Padding="8,8"
            Margin="14,0,14,10"
            StrokeShape="RoundRectangle 26">
        <Grid ColumnDefinitions="*,*,*,*,*" ColumnSpacing="4">
            <!-- Home Tab -->
            <Border Grid.Column="0"
                    x:Name="HomePill"
                    StrokeShape="RoundRectangle 18"
                    BackgroundColor="Transparent"
                    Padding="12,8"
                    HorizontalOptions="Center">
                <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                    <ImageButton x:Name="HomeButton"
                                 Source="nav_home.svg"
                                 BackgroundColor="Transparent"
                                 WidthRequest="22"
                                 HeightRequest="22"
                                 Clicked="OnHomeClicked" />
                </VerticalStackLayout>
            </Border>

            <!-- Workout Tab -->
            <Border Grid.Column="1"
                    x:Name="WorkoutPill"
                    StrokeShape="RoundRectangle 18"
                    BackgroundColor="Transparent"
                    Padding="12,8"
                    HorizontalOptions="Center">
                <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                    <ImageButton x:Name="WorkoutButton"
                                 Source="nav_dumbbell.svg"
                                 BackgroundColor="Transparent"
                                 WidthRequest="22"
                                 HeightRequest="22"
                                 Clicked="OnWorkoutClicked" />
                </VerticalStackLayout>
            </Border>

            <!-- FreakAI Tab -->
            <Border Grid.Column="2"
                    x:Name="FreakAiPill"
                    StrokeShape="RoundRectangle 18"
                    BackgroundColor="Transparent"
                    Padding="12,8"
                    HorizontalOptions="Center">
                <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                    <ImageButton x:Name="FreakAiButton"
                                 Source="nav_notebook.svg"
                                 BackgroundColor="Transparent"
                                 WidthRequest="22"
                                 HeightRequest="22"
                                 Clicked="OnFreakAiClicked" />
                </VerticalStackLayout>
            </Border>

            <!-- Calculations Tab -->
            <Border Grid.Column="3"
                    x:Name="CalculationsPill"
                    StrokeShape="RoundRectangle 18"
                    BackgroundColor="Transparent"
                    Padding="12,8"
                    HorizontalOptions="Center">
                <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                    <ImageButton x:Name="CalculationsButton"
                                 Source="nav_notebook.svg"
                                 BackgroundColor="Transparent"
                                 WidthRequest="22"
                                 HeightRequest="22"
                                 Clicked="OnCalculationsClicked" />
                </VerticalStackLayout>
            </Border>

            <!-- Profile Tab -->
            <Border Grid.Column="4"
                    x:Name="ProfilePill"
                    StrokeShape="RoundRectangle 18"
                    BackgroundColor="Transparent"
                    Padding="12,8"
                    HorizontalOptions="Center">
                <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                    <ImageButton x:Name="ProfileButton"
                                 Source="nav_profile.svg"
                                 BackgroundColor="Transparent"
                                 WidthRequest="22"
                                 HeightRequest="22"
                                 Clicked="OnProfileClicked" />
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Border>

</ContentView>

