<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FreakLete.BottomNavBar">

    <Border BackgroundColor="{StaticResource Surface}"
            Stroke="{StaticResource SurfaceBorder}"
            StrokeThickness="1"
            Padding="10,10"
            Margin="16,0,16,14"
            StrokeShape="RoundRectangle 26">
        <Border.Shadow>
            <Shadow Brush="{StaticResource Black}"
                    Radius="20"
                    Opacity="0.35"
                    Offset="0,4" />
        </Border.Shadow>
        <Grid ColumnDefinitions="*,*,*,*,*" ColumnSpacing="4">

            <!-- Home Tab -->
            <Border Grid.Column="0"
                    x:Name="HomePill"
                    StrokeShape="RoundRectangle 20"
                    StrokeThickness="0"
                    Stroke="Transparent"
                    BackgroundColor="Transparent"
                    Padding="16,10"
                    HorizontalOptions="Center">
                <VerticalStackLayout Spacing="3" HorizontalOptions="Center">
                    <Image x:Name="HomeIcon"
                           Source="nav_home_inactive.svg"
                           WidthRequest="28"
                           HeightRequest="28"
                           HorizontalOptions="Center" />
                    <Label x:Name="HomeLabel"
                           Text="Home"
                           FontSize="10"
                           FontFamily="OpenSansSemibold"
                           TextColor="{StaticResource TextMuted}"
                           HorizontalTextAlignment="Center"
                           IsVisible="False" />
                </VerticalStackLayout>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHomeClicked" />
                </Border.GestureRecognizers>
            </Border>

            <!-- Workout Tab -->
            <Border Grid.Column="1"
                    x:Name="WorkoutPill"
                    StrokeShape="RoundRectangle 20"
                    StrokeThickness="0"
                    Stroke="Transparent"
                    BackgroundColor="Transparent"
                    Padding="16,10"
                    HorizontalOptions="Center">
                <VerticalStackLayout Spacing="3" HorizontalOptions="Center">
                    <Image x:Name="WorkoutIcon"
                           Source="nav_dumbbell_inactive.svg"
                           WidthRequest="28"
                           HeightRequest="28"
                           HorizontalOptions="Center" />
                    <Label x:Name="WorkoutLabel"
                           Text="Workout"
                           FontSize="10"
                           FontFamily="OpenSansSemibold"
                           TextColor="{StaticResource TextMuted}"
                           HorizontalTextAlignment="Center"
                           IsVisible="False" />
                </VerticalStackLayout>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnWorkoutClicked" />
                </Border.GestureRecognizers>
            </Border>

            <!-- FreakAI Tab -->
            <Border Grid.Column="2"
                    x:Name="FreakAiPill"
                    StrokeShape="RoundRectangle 20"
                    StrokeThickness="0"
                    Stroke="Transparent"
                    BackgroundColor="Transparent"
                    Padding="16,10"
                    HorizontalOptions="Center">
                <VerticalStackLayout Spacing="3" HorizontalOptions="Center">
                    <Image x:Name="FreakAiIcon"
                           Source="nav_notebook_inactive.svg"
                           WidthRequest="28"
                           HeightRequest="28"
                           HorizontalOptions="Center" />
                    <Label x:Name="FreakAiLabel"
                           Text="FreakAI"
                           FontSize="10"
                           FontFamily="OpenSansSemibold"
                           TextColor="{StaticResource TextMuted}"
                           HorizontalTextAlignment="Center"
                           IsVisible="False" />
                </VerticalStackLayout>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnFreakAiClicked" />
                </Border.GestureRecognizers>
            </Border>

            <!-- Calculations Tab -->
            <Border Grid.Column="3"
                    x:Name="CalculationsPill"
                    StrokeShape="RoundRectangle 20"
                    StrokeThickness="0"
                    Stroke="Transparent"
                    BackgroundColor="Transparent"
                    Padding="16,10"
                    HorizontalOptions="Center">
                <VerticalStackLayout Spacing="3" HorizontalOptions="Center">
                    <Image x:Name="CalculationsIcon"
                           Source="nav_plates_inactive.svg"
                           WidthRequest="28"
                           HeightRequest="28"
                           HorizontalOptions="Center" />
                    <Label x:Name="CalculationsLabel"
                           Text="Calc"
                           FontSize="10"
                           FontFamily="OpenSansSemibold"
                           TextColor="{StaticResource TextMuted}"
                           HorizontalTextAlignment="Center"
                           IsVisible="False" />
                </VerticalStackLayout>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnCalculationsClicked" />
                </Border.GestureRecognizers>
            </Border>

            <!-- Profile Tab -->
            <Border Grid.Column="4"
                    x:Name="ProfilePill"
                    StrokeShape="RoundRectangle 20"
                    StrokeThickness="0"
                    Stroke="Transparent"
                    BackgroundColor="Transparent"
                    Padding="16,10"
                    HorizontalOptions="Center">
                <VerticalStackLayout Spacing="3" HorizontalOptions="Center">
                    <Image x:Name="ProfileIcon"
                           Source="nav_profile_inactive.svg"
                           WidthRequest="28"
                           HeightRequest="28"
                           HorizontalOptions="Center" />
                    <Label x:Name="ProfileLabel"
                           Text="Profile"
                           FontSize="10"
                           FontFamily="OpenSansSemibold"
                           TextColor="{StaticResource TextMuted}"
                           HorizontalTextAlignment="Center"
                           IsVisible="False" />
                </VerticalStackLayout>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnProfileClicked" />
                </Border.GestureRecognizers>
            </Border>

        </Grid>
    </Border>

</ContentView>
