<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FreakLete.BottomNavBar">

    <Border Style="{StaticResource CardBorder}"
            BackgroundColor="{StaticResource SurfaceRaised}"
            Stroke="{StaticResource SurfaceBorder}"
            Padding="18,12"
            Margin="14,0,14,10"
            StrokeShape="RoundRectangle 26">
        <Grid ColumnDefinitions="*,*,*,*">
            <VerticalStackLayout Grid.Column="0" Spacing="4" HorizontalOptions="Center">
                <ImageButton x:Name="HomeButton"
                             Source="nav_home.svg"
                             BackgroundColor="Transparent"
                             WidthRequest="22"
                             HeightRequest="22"
                             Clicked="OnHomeClicked" />
                <BoxView x:Name="HomeIndicator"
                         WidthRequest="16"
                         HeightRequest="4"
                         CornerRadius="2"
                         Color="{StaticResource Accent}"
                         IsVisible="False"
                         HorizontalOptions="Center" />
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="1" Spacing="4" HorizontalOptions="Center">
                <ImageButton x:Name="WorkoutButton"
                             Source="nav_dumbbell.svg"
                             BackgroundColor="Transparent"
                             WidthRequest="22"
                             HeightRequest="22"
                             Clicked="OnWorkoutClicked" />
                <BoxView x:Name="WorkoutIndicator"
                         WidthRequest="16"
                         HeightRequest="4"
                         CornerRadius="2"
                         Color="{StaticResource Accent}"
                         IsVisible="False"
                         HorizontalOptions="Center" />
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="2" Spacing="4" HorizontalOptions="Center">
                <ImageButton x:Name="CalculationsButton"
                             Source="nav_notebook.svg"
                             BackgroundColor="Transparent"
                             WidthRequest="22"
                             HeightRequest="22"
                             Clicked="OnCalculationsClicked" />
                <BoxView x:Name="CalculationsIndicator"
                         WidthRequest="16"
                         HeightRequest="4"
                         CornerRadius="2"
                         Color="{StaticResource Accent}"
                         IsVisible="False"
                         HorizontalOptions="Center" />
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="3" Spacing="4" HorizontalOptions="Center">
                <ImageButton x:Name="ProfileButton"
                             Source="nav_profile.svg"
                             BackgroundColor="Transparent"
                             WidthRequest="22"
                             HeightRequest="22"
                             Clicked="OnProfileClicked" />
                <BoxView x:Name="ProfileIndicator"
                         WidthRequest="16"
                         HeightRequest="4"
                         CornerRadius="2"
                         Color="{StaticResource Accent}"
                         IsVisible="False"
                         HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Grid>
    </Border>

</ContentView>
