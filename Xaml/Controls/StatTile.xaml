<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FreakLete.StatTile">

	<Border StrokeShape="RoundRectangle 18"
	        Stroke="{StaticResource SurfaceBorder}"
	        StrokeThickness="1"
	        Padding="14,16">
		<Border.Background>
			<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
				<GradientStop Color="{StaticResource SurfaceRaised}" Offset="0.0" />
				<GradientStop Color="{StaticResource Surface}" Offset="1.0" />
			</LinearGradientBrush>
		</Border.Background>
		<VerticalStackLayout Spacing="6" HorizontalOptions="Center">
			<HorizontalStackLayout Spacing="4" HorizontalOptions="Center">
				<Label x:Name="StatValueLabel"
				       FontSize="28"
				       FontFamily="OpenSansSemibold"
				       TextColor="{StaticResource AccentGlow}" />
				<Label x:Name="TrendIconLabel"
				       FontSize="20"
				       TextColor="{StaticResource Success}"
				       VerticalOptions="Center"
				       IsVisible="False" />
			</HorizontalStackLayout>
			<Label x:Name="StatLabelLabel"
			       FontSize="11"
			       FontFamily="OpenSansSemibold"
			       TextColor="{StaticResource TextSecondary}"
			       HorizontalTextAlignment="Center"
			       CharacterSpacing="0.3" />
		</VerticalStackLayout>
	</Border>

</ContentView>
