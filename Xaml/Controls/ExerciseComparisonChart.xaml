<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:microcharts="clr-namespace:Microcharts.Maui;assembly=Microcharts.Maui"
             x:Class="FreakLete.ExerciseComparisonChart"
             x:Name="ComparisonChartView">

    <Border StrokeShape="RoundRectangle 20"
            Stroke="{StaticResource SurfaceBorder}"
            StrokeThickness="1"
            Padding="0">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="{StaticResource SurfaceRaised}" Offset="0.0" />
                <GradientStop Color="{StaticResource Surface}" Offset="1.0" />
            </LinearGradientBrush>
        </Border.Background>
        <VerticalStackLayout Spacing="14" Padding="18,16">

            <!-- Title row with change button -->
            <Grid ColumnDefinitions="*,Auto">
                <VerticalStackLayout Spacing="2">
                    <Label x:Name="TitleLabel"
                           FontSize="16"
                           FontFamily="OpenSansSemibold"
                           TextColor="{StaticResource TextPrimary}"
                           Text="Bench Press vs Squat" />
                    <Label x:Name="SubtitleLabel"
                           FontSize="11"
                           FontFamily="OpenSansRegular"
                           TextColor="{StaticResource TextSecondary}"
                           Text="Best values in the last 14 days" />
                </VerticalStackLayout>
                <Border Grid.Column="1"
                        StrokeShape="RoundRectangle 10"
                        BackgroundColor="{StaticResource AccentSoft}"
                        Stroke="Transparent"
                        Padding="10,6"
                        VerticalOptions="Center">
                    <Label x:Name="ChangeButtonLabel"
                           FontSize="11"
                           FontFamily="OpenSansSemibold"
                           TextColor="{StaticResource AccentGlow}"
                           Text="Change" />
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnChangeButtonTapped" />
                    </Border.GestureRecognizers>
                </Border>
            </Grid>

            <!-- Range selector -->
            <HorizontalStackLayout x:Name="RangeSelectorRow" Spacing="6">
                <Border x:Name="RangeBtn14"
                        StrokeShape="RoundRectangle 10"
                        Stroke="Transparent"
                        Padding="10,5">
                    <Label x:Name="RangeLabel14"
                           FontSize="11"
                           FontFamily="OpenSansSemibold"
                           HorizontalTextAlignment="Center" />
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnRange14Tapped" />
                    </Border.GestureRecognizers>
                </Border>
                <Border x:Name="RangeBtn1M"
                        StrokeShape="RoundRectangle 10"
                        Stroke="Transparent"
                        Padding="10,5">
                    <Label x:Name="RangeLabel1M"
                           FontSize="11"
                           FontFamily="OpenSansSemibold"
                           HorizontalTextAlignment="Center" />
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnRange1MTapped" />
                    </Border.GestureRecognizers>
                </Border>
                <Border x:Name="RangeBtn3M"
                        StrokeShape="RoundRectangle 10"
                        Stroke="Transparent"
                        Padding="10,5">
                    <Label x:Name="RangeLabel3M"
                           FontSize="11"
                           FontFamily="OpenSansSemibold"
                           HorizontalTextAlignment="Center" />
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnRange3MTapped" />
                    </Border.GestureRecognizers>
                </Border>
                <Border x:Name="RangeBtn6M"
                        StrokeShape="RoundRectangle 10"
                        Stroke="Transparent"
                        Padding="10,5">
                    <Label x:Name="RangeLabel6M"
                           FontSize="11"
                           FontFamily="OpenSansSemibold"
                           HorizontalTextAlignment="Center" />
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnRange6MTapped" />
                    </Border.GestureRecognizers>
                </Border>
            </HorizontalStackLayout>

            <!-- Progress badges -->
            <HorizontalStackLayout Spacing="8">
                <Border x:Name="Badge1Border"
                        StrokeShape="RoundRectangle 12"
                        BackgroundColor="{StaticResource AccentSoft}"
                        Stroke="Transparent"
                        Padding="10,5">
                    <Label x:Name="Badge1Label"
                           FontSize="12"
                           FontFamily="OpenSansSemibold"
                           TextColor="{StaticResource AccentGlow}"
                           Text="Bench -" />
                </Border>
                <Border x:Name="Badge2Border"
                        StrokeShape="RoundRectangle 12"
                        BackgroundColor="{StaticResource SuccessSoft}"
                        Stroke="Transparent"
                        Padding="10,5">
                    <Label x:Name="Badge2Label"
                           FontSize="12"
                           FontFamily="OpenSansSemibold"
                           TextColor="{StaticResource Success}"
                           Text="Squat -" />
                </Border>
            </HorizontalStackLayout>

            <!-- Chart area: two overlaid ChartViews for dual series -->
            <Grid HeightRequest="160">
                <microcharts:ChartView x:Name="ChartView1"
                                       HeightRequest="160"
                                       HorizontalOptions="FillAndExpand" />
                <microcharts:ChartView x:Name="ChartView2"
                                       HeightRequest="160"
                                       HorizontalOptions="FillAndExpand" />
            </Grid>

            <!-- Empty state -->
            <Label x:Name="EmptyStateLabel"
                   FontSize="13"
                   FontFamily="OpenSansRegular"
                   TextColor="{StaticResource TextMuted}"
                   Text="No data yet"
                   HorizontalOptions="Center"
                   IsVisible="False" />

            <!-- Legend -->
            <HorizontalStackLayout x:Name="LegendRow" Spacing="16" HorizontalOptions="Center">
                <HorizontalStackLayout Spacing="4">
                    <BoxView WidthRequest="10" HeightRequest="10"
                             Color="{StaticResource Accent}"
                             CornerRadius="2"
                             VerticalOptions="Center" />
                    <Label x:Name="Legend1Label"
                           FontSize="10"
                           FontFamily="OpenSansRegular"
                           TextColor="{StaticResource TextSecondary}"
                           Text="Bench Press (kg)" />
                </HorizontalStackLayout>
                <HorizontalStackLayout Spacing="4">
                    <BoxView WidthRequest="10" HeightRequest="10"
                             Color="{StaticResource Success}"
                             CornerRadius="2"
                             VerticalOptions="Center" />
                    <Label x:Name="Legend2Label"
                           FontSize="10"
                           FontFamily="OpenSansRegular"
                           TextColor="{StaticResource TextSecondary}"
                           Text="Squat (kg)" />
                </HorizontalStackLayout>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </Border>

</ContentView>
