<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:GymTracker"
             x:Class="GymTracker.OneRmPage"
             NavigationPage.HasNavigationBar="False"
             Title="1RM Calculator">

    <Grid RowDefinitions="*,Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="24,18,24,24"
                                 Spacing="18">

                <local:TopHeader Title="1RM Calculator" />

                <Border Style="{StaticResource AccentCardBorder}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="STRENGTH ESTIMATE"
                               Style="{StaticResource Eyebrow}" />
                        <Label Text="Calculate your projected max and store the sets that matter."
                               Style="{StaticResource Headline}"
                               HorizontalTextAlignment="Start" />
                        <Label Text="RIR is included in the estimate, so strong training sets stay useful."
                               Style="{StaticResource BodyMuted}" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource CardBorder}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Input"
                               Style="{StaticResource SubHeadline}"
                               HorizontalTextAlignment="Start" />

                        <Label Text="Weight (kg): 40 - 250"
                               Style="{StaticResource BodyMuted}" />
                        <Entry x:Name="WeightEntry"
                               Keyboard="Numeric"
                               Placeholder="Example: 100" />

                        <Label Text="Reps: 1 - 8"
                               Style="{StaticResource BodyMuted}" />
                        <Entry x:Name="RepsEntry"
                               Keyboard="Numeric"
                               Placeholder="Example: 5" />

                        <Label Text="RIR: 0 - 5"
                               Style="{StaticResource BodyMuted}" />
                        <Entry x:Name="RirEntry"
                               Keyboard="Numeric"
                               Placeholder="Example: 1" />

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="12">
                            <Button Grid.Column="0"
                                    Text="Calculate"
                                    Clicked="OnCalculateClicked" />
                            <Button Grid.Column="1"
                                    x:Name="SaveExerciseButton"
                                    Style="{StaticResource SecondaryButton}"
                                    Text="Save PR"
                                    Clicked="OnSaveExerciseClicked" />
                        </Grid>

                        <Button x:Name="CancelEditButton"
                                Text="Cancel"
                                Style="{StaticResource SecondaryButton}"
                                IsVisible="False"
                                Clicked="OnCancelEditClicked" />

                        <Label x:Name="ErrorLabel"
                               TextColor="{StaticResource Danger}"
                               IsVisible="False"
                               FontSize="13" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource CardBorder}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Calculated Range"
                               Style="{StaticResource SubHeadline}"
                               HorizontalTextAlignment="Start" />

                        <Label x:Name="ResultsLabel"
                               Text=""
                               LineBreakMode="WordWrap"
                               Style="{StaticResource BodyMuted}" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource CardBorder}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Saved PR Entries"
                               Style="{StaticResource SubHeadline}"
                               HorizontalTextAlignment="Start" />

                        <CollectionView x:Name="SavedPrView">
                            <CollectionView.EmptyView>
                                <Label Text="No saved PR yet."
                                       HorizontalOptions="Center"
                                       Style="{StaticResource BodyMuted}" />
                            </CollectionView.EmptyView>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource CardBorder}"
                                            BackgroundColor="{StaticResource SurfaceRaised}"
                                            Padding="14"
                                            Margin="0,0,0,10">
                                        <Grid ColumnDefinitions="*,Auto,Auto"
                                              ColumnSpacing="8">
                                            <Label Grid.Column="0"
                                                   Text="{Binding Text}"
                                                   VerticalOptions="Center" />
                                            <ImageButton Grid.Column="1"
                                                         Source="icon_edit.svg"
                                                         Clicked="OnEditSavedPrInvoked"
                                                         BackgroundColor="#24203A"
                                                         Padding="8"
                                                         WidthRequest="36"
                                                         HeightRequest="36"
                                                         CornerRadius="12" />
                                            <ImageButton Grid.Column="2"
                                                         Source="icon_delete.svg"
                                                         Clicked="OnDeleteSavedPrInvoked"
                                                         BackgroundColor="#3A1623"
                                                         Padding="8"
                                                         WidthRequest="36"
                                                         HeightRequest="36"
                                                         CornerRadius="12" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <local:BottomNavBar Grid.Row="1"
                            ActiveTab="onerm" />
    </Grid>

</ContentPage>
