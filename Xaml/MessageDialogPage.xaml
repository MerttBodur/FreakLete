<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GymTracker.MessageDialogPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource OverlayScrim}">

    <Grid Padding="24">
        <Border Style="{StaticResource CardBorder}"
                Padding="20"
                VerticalOptions="Center"
                HorizontalOptions="Center"
                MaximumWidthRequest="420"
                BackgroundColor="{StaticResource SurfaceRaised}">
            <VerticalStackLayout Spacing="14">
                <Label x:Name="BadgeLabel"
                       Text="SUCCESS"
                       Style="{StaticResource Eyebrow}" />

                <Label x:Name="TitleLabel"
                       Text="Done"
                       Style="{StaticResource SubHeadline}"
                       HorizontalTextAlignment="Start" />

                <Label x:Name="MessageLabel"
                       Text="Everything is ready."
                       Style="{StaticResource BodyMuted}"
                       LineBreakMode="WordWrap" />

                <Button x:Name="CloseButton"
                        Text="Continue"
                        Margin="0,8,0,0"
                        Clicked="OnCloseClicked" />
            </VerticalStackLayout>
        </Border>
    </Grid>

</ContentPage>
