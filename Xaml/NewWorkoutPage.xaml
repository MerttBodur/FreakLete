<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:GymTracker"
             x:Class="GymTracker.NewWorkoutPage"
             NavigationPage.HasNavigationBar="False"
             Title="Add New Workout">

    <ScrollView>
        <VerticalStackLayout Padding="24,18,24,28"
                             Spacing="18">

            <local:TopHeader Title="New Workout"
                             ShowBackButton="True"
                             BackClicked="OnHeaderBackClicked" />

            <Border Style="{StaticResource AccentCardBorder}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="SESSION SETUP"
                           Style="{StaticResource Eyebrow}" />
                    <Label x:Name="PageTitleLabel"
                           Text="New Workout"
                           Style="{StaticResource Headline}"
                           HorizontalTextAlignment="Start" />
                    <Label x:Name="PageHelperLabel"
                           Text="Set the date, name your workout, then add exercises to the session."
                           Style="{StaticResource BodyMuted}" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource CardBorder}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Workout Details"
                           Style="{StaticResource SubHeadline}"
                           HorizontalTextAlignment="Start" />

                    <Label Text="Date"
                           Style="{StaticResource BodyMuted}" />
                    <DatePicker x:Name="WorkoutDatePicker" />

                    <Label Text="Workout Name"
                           Style="{StaticResource BodyMuted}" />
                    <Entry x:Name="WorkoutNameEntry"
                           Placeholder="Example: Push Day" />

                    <Button x:Name="AddExercisesButton"
                            Text="Continue"
                            Clicked="OnAddExercisesClicked" />
                </VerticalStackLayout>
            </Border>

                <Border x:Name="ExercisesSection"
                    Style="{StaticResource CardBorder}"
                    IsVisible="False">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Exercise Builder"
                           Style="{StaticResource SubHeadline}"
                           HorizontalTextAlignment="Start" />

                    <Label Text="Choose exercise"
                           Style="{StaticResource BodyMuted}" />
                    <Border Style="{StaticResource CardBorder}"
                            BackgroundColor="{StaticResource SurfaceRaised}"
                            Padding="14">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="10">
                            <VerticalStackLayout Grid.Column="0"
                                                 Spacing="4">
                                <Label x:Name="SelectedExerciseLabel"
                                       Text="No exercise selected"
                                       FontSize="18" />
                                <Label x:Name="SelectedExerciseHintLabel"
                                       Text="Tap browse to open your recommended movement library."
                                       Style="{StaticResource BodyMuted}" />
                            </VerticalStackLayout>

                            <Button Grid.Column="1"
                                    Text="Browse"
                                    Style="{StaticResource SecondaryButton}"
                                    Clicked="OnChooseExerciseClicked"
                                    VerticalOptions="Center" />
                        </Grid>
                    </Border>

                    <VerticalStackLayout x:Name="StrengthInputsSection"
                                         Spacing="12"
                                         IsVisible="False">
                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="12">
                            <VerticalStackLayout Grid.Column="0"
                                                 Spacing="8">
                                <Label Text="Set Count"
                                       Style="{StaticResource BodyMuted}" />
                                <Entry x:Name="SetCountEntry"
                                       Keyboard="Numeric"
                                       Placeholder="Example: 3" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="8">
                                <Label Text="Rep Count"
                                       Style="{StaticResource BodyMuted}" />
                                <Entry x:Name="RepCountEntry"
                                       Keyboard="Numeric"
                                       Placeholder="Example: 8" />
                            </VerticalStackLayout>
                        </Grid>

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="12">
                            <VerticalStackLayout Grid.Column="0"
                                                 Spacing="8">
                                <Label Text="RIR"
                                       Style="{StaticResource BodyMuted}" />
                                <Entry x:Name="RirEntry"
                                       Keyboard="Numeric"
                                       Placeholder="Optional" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="8">
                                <Label Text="Rest Seconds"
                                       Style="{StaticResource BodyMuted}" />
                                <Entry x:Name="RestSecondsEntry"
                                       Keyboard="Numeric"
                                       Placeholder="Optional" />
                            </VerticalStackLayout>
                        </Grid>

                        <VerticalStackLayout x:Name="StrengthTimingContainer"
                                             Spacing="8"
                                             IsVisible="False">
                            <Label Text="Concentric Time (s)"
                                   Style="{StaticResource BodyMuted}" />
                            <Entry x:Name="ConcentricTimeEntry"
                                   Keyboard="Numeric"
                                   Placeholder="Optional" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>

                    <VerticalStackLayout x:Name="CustomInputsSection"
                                         Spacing="12"
                                         IsVisible="False">
                        <VerticalStackLayout Spacing="8">
                            <Label x:Name="Metric1Label"
                                   Text="Metric 1"
                                   Style="{StaticResource BodyMuted}" />
                            <Entry x:Name="Metric1Entry"
                                   Keyboard="Numeric"
                                   Placeholder="Enter value" />
                        </VerticalStackLayout>

                        <VerticalStackLayout x:Name="Metric2Container"
                                             Spacing="8"
                                             IsVisible="False">
                            <Label x:Name="Metric2Label"
                                   Text="Metric 2"
                                   Style="{StaticResource BodyMuted}" />
                            <Entry x:Name="Metric2Entry"
                                   Keyboard="Numeric"
                                   Placeholder="Enter value" />
                        </VerticalStackLayout>

                        <VerticalStackLayout x:Name="GroundContactTimeContainer"
                                             Spacing="8"
                                             IsVisible="False">
                            <Label Text="Ground Contact Time (ms)"
                                   Style="{StaticResource BodyMuted}" />
                            <Entry x:Name="GroundContactTimeEntry"
                                   Keyboard="Numeric"
                                   Placeholder="Optional" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>

                    <Button Text="Add"
                            Style="{StaticResource SecondaryButton}"
                            Clicked="OnAddExerciseClicked" />
                </VerticalStackLayout>
            </Border>

            <Label x:Name="ErrorLabel"
                   TextColor="{StaticResource Danger}"
                   IsVisible="False"
                   FontSize="13" />

            <Border Style="{StaticResource CardBorder}">
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="12">
                        <Label Text="Session Exercises"
                               Style="{StaticResource SubHeadline}"
                               HorizontalTextAlignment="Start" />
                        <Label x:Name="ExerciseCountLabel"
                               Text="0 items"
                               Style="{StaticResource BodyMuted}"
                               VerticalOptions="Center" />
                    </Grid>

                    <CollectionView x:Name="ExercisesCollectionView">
                        <CollectionView.EmptyView>
                            <Label Text="No exercise added yet."
                                   HorizontalOptions="Center"
                                   Style="{StaticResource BodyMuted}" />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource CardBorder}"
                                        BackgroundColor="{StaticResource SurfaceRaised}"
                                        Padding="14"
                                        Margin="0,0,0,10">
                                    <Grid ColumnDefinitions="*,Auto"
                                          ColumnSpacing="8">
                                        <VerticalStackLayout Grid.Column="0"
                                                             Spacing="4">
                                            <Label Text="{Binding ExerciseName}"
                                                   FontSize="18" />
                                            <Label Text="{Binding SetRepText}"
                                                   Style="{StaticResource BodyMuted}" />
                                            <Label Text="{Binding RestText}"
                                                   Style="{StaticResource BodyMuted}" />
                                        </VerticalStackLayout>
                                        <ImageButton Grid.Column="1"
                                                     Source="icon_delete.svg"
                                                     Clicked="OnDeleteExerciseInvoked"
                                                     BackgroundColor="#3A1623"
                                                     Padding="8"
                                                     WidthRequest="36"
                                                     HeightRequest="36"
                                                     CornerRadius="12"
                                                     VerticalOptions="Start" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <Button x:Name="ConfirmWorkoutButton"
                    Text="Save Workout"
                    Clicked="OnConfirmWorkoutClicked" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
