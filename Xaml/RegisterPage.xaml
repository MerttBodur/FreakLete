<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GymTracker.RegisterPage"
             Title="Register">

    <ScrollView>
        <VerticalStackLayout Padding="30,24,30,30"
                             Spacing="16">

            <Label Text="Create Account"
                   FontSize="32"
                   HorizontalOptions="Center"
                   FontAttributes="Bold" />

            <Label Text="Register to start using GymTracker"
                   FontSize="16"
                   HorizontalOptions="Center"
                   Opacity="0.7" />

            <VerticalStackLayout Spacing="10">
                <Label Text="First Name"
                       FontSize="16" />
                <Entry x:Name="FirstNameEntry"
                       Placeholder="Enter your first name" />

                <Label Text="Last Name"
                       FontSize="16" />
                <Entry x:Name="LastNameEntry"
                       Placeholder="Enter your last name" />

                <Label Text="Email"
                       FontSize="16" />
                <Entry x:Name="EmailEntry"
                       Placeholder="Enter your email"
                       Keyboard="Email" />

                <Label Text="Password"
                       FontSize="16" />
                <Entry x:Name="PasswordEntry"
                       Placeholder="Create a password"
                       IsPassword="True" />

                <Label Text="Confirm Password"
                       FontSize="16" />
                <Entry x:Name="ConfirmPasswordEntry"
                       Placeholder="Confirm your password"
                       IsPassword="True" />
            </VerticalStackLayout>

            <Label Text="Password rules: 8+ chars, 1 uppercase, 1 special character."
                   FontSize="13"
                   Opacity="0.7" />

            <Label x:Name="ErrorLabel"
                   TextColor="Red"
                   FontSize="13"
                   IsVisible="False" />

            <Button Text="Create Account"
                    Clicked="OnCreateAccountClicked"
                    HorizontalOptions="Fill" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
