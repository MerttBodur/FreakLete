<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FreakLete.RegisterPage"
             xmlns:local="clr-namespace:FreakLete"
             NavigationPage.HasNavigationBar="False"
             Title="Register">

    <ScrollView>
        <VerticalStackLayout Padding="24,30,24,30"
                             Spacing="18">

            <local:TopHeader x:Name="TopHeader"
                             Title="Register"
                             ShowBackButton="True"
                             BackClicked="OnHeaderBackClicked" />

            <Border Style="{StaticResource AccentCardBorder}">
                <VerticalStackLayout Spacing="10">
                    <Label x:Name="EyebrowLabel"
                           Text="CREATE ACCOUNT"
                           Style="{StaticResource Eyebrow}" />
                    <Label x:Name="HeadlineLabel"
                           Text="Start your training profile."
                           Style="{StaticResource Headline}"
                           HorizontalTextAlignment="Start" />
                    <Label x:Name="SubtitleLabel"
                           Text="Create your account to save workouts, PRs, and athletic performance data."
                           Style="{StaticResource BodyMuted}" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource CardBorder}">
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="12">
                        <VerticalStackLayout Grid.Column="0"
                                             Spacing="8">
                            <Label x:Name="FirstNameLabel"
                                   Text="First Name"
                                   Style="{StaticResource BodyMuted}" />
                            <local:InputShell>
                                <Entry x:Name="FirstNameEntry"
                                       Placeholder="Enter your first name" />
                            </local:InputShell>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1"
                                             Spacing="8">
                            <Label x:Name="LastNameLabel"
                                   Text="Last Name"
                                   Style="{StaticResource BodyMuted}" />
                            <local:InputShell>
                                <Entry x:Name="LastNameEntry"
                                       Placeholder="Enter your last name" />
                            </local:InputShell>
                        </VerticalStackLayout>
                    </Grid>

                    <Label x:Name="RegEmailLabel"
                           Text="Email"
                           Style="{StaticResource BodyMuted}" />
                    <local:InputShell>
                        <Entry x:Name="EmailEntry"
                               Placeholder="Enter your email"
                               Keyboard="Email" />
                    </local:InputShell>

                    <Label x:Name="RegPasswordLabel"
                           Text="Password"
                           Style="{StaticResource BodyMuted}" />
                    <local:InputShell>
                        <Entry x:Name="PasswordEntry"
                               Placeholder="Create a password"
                               IsPassword="True" />
                    </local:InputShell>

                    <Label x:Name="ConfirmPasswordLabel"
                           Text="Confirm Password"
                           Style="{StaticResource BodyMuted}" />
                    <local:InputShell>
                        <Entry x:Name="ConfirmPasswordEntry"
                               Placeholder="Confirm your password"
                               IsPassword="True" />
                    </local:InputShell>

                    <Border Style="{StaticResource CardBorder}"
                            BackgroundColor="{StaticResource SurfaceRaised}"
                            Padding="14">
                        <Label x:Name="PasswordRulesLabel"
                               Text="Password rules: at least 8 characters, 1 uppercase letter, and 1 special character."
                               Style="{StaticResource BodyMuted}" />
                    </Border>

                    <Label x:Name="ErrorLabel"
                           TextColor="{StaticResource Danger}"
                           FontSize="13"
                           IsVisible="False" />

                    <Button x:Name="SignUpBtn"
                            Text="Sign Up"
                            Clicked="OnCreateAccountClicked"
                            HorizontalOptions="Fill" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
