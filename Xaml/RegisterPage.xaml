<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GymTracker.RegisterPage"
             xmlns:local="clr-namespace:GymTracker"
             NavigationPage.HasNavigationBar="False"
             Title="Register">

    <ScrollView>
        <VerticalStackLayout Padding="24,30,24,30"
                             Spacing="18">

            <local:TopHeader Title="Register"
                             ShowBackButton="True"
                             BackClicked="OnHeaderBackClicked" />

            <Border Style="{StaticResource AccentCardBorder}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="CREATE ACCOUNT"
                           Style="{StaticResource Eyebrow}" />
                    <Label Text="Start your training profile."
                           Style="{StaticResource Headline}"
                           HorizontalTextAlignment="Start" />
                    <Label Text="Create your account to save workouts, PRs, and athletic performance data."
                           Style="{StaticResource BodyMuted}" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource CardBorder}">
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="12">
                        <VerticalStackLayout Grid.Column="0"
                                             Spacing="8">
                            <Label Text="First Name"
                                   Style="{StaticResource BodyMuted}" />
                            <Entry x:Name="FirstNameEntry"
                                   Placeholder="Enter your first name" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1"
                                             Spacing="8">
                            <Label Text="Last Name"
                                   Style="{StaticResource BodyMuted}" />
                            <Entry x:Name="LastNameEntry"
                                   Placeholder="Enter your last name" />
                        </VerticalStackLayout>
                    </Grid>

                    <Label Text="Email"
                           Style="{StaticResource BodyMuted}" />
                    <Entry x:Name="EmailEntry"
                           Placeholder="Enter your email"
                           Keyboard="Email" />

                    <Label Text="Password"
                           Style="{StaticResource BodyMuted}" />
                    <Entry x:Name="PasswordEntry"
                           Placeholder="Create a password"
                           IsPassword="True" />

                    <Label Text="Confirm Password"
                           Style="{StaticResource BodyMuted}" />
                    <Entry x:Name="ConfirmPasswordEntry"
                           Placeholder="Confirm your password"
                           IsPassword="True" />

                    <Border Style="{StaticResource CardBorder}"
                            BackgroundColor="{StaticResource SurfaceRaised}"
                            Padding="14">
                        <Label Text="Password rules: at least 8 characters, 1 uppercase letter, and 1 special character."
                               Style="{StaticResource BodyMuted}" />
                    </Border>

                    <Label x:Name="ErrorLabel"
                           TextColor="{StaticResource Danger}"
                           FontSize="13"
                           IsVisible="False" />

                    <Button Text="Sign Up"
                            Clicked="OnCreateAccountClicked"
                            HorizontalOptions="Fill" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
