<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:FreakLete"
             x:Class="FreakLete.ExercisePickerPage"
             x:Name="ThisPage"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="Auto,*">
        <VerticalStackLayout Grid.Row="0"
                             Padding="24,18,24,12"
                             Spacing="18">

            <local:TopHeader x:Name="HeaderView"
                             ShowBackButton="True"
                             BackClicked="OnHeaderBackClicked" />

            <local:InputShell>
                <Entry x:Name="SearchEntry"
                       Placeholder=""
                       PlaceholderColor="{StaticResource TextMuted}"
                       TextColor="{StaticResource TextPrimary}"
                       TextChanged="OnSearchTextChanged" />
            </local:InputShell>

            <ScrollView Orientation="Horizontal">
                <HorizontalStackLayout x:Name="CategoriesLayout"
                                       Spacing="10"
                                       BindableLayout.ItemsSource="{Binding Categories}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate>
                            <Button Text="{Binding Name}"
                                    Clicked="OnCategoryClicked"
                                    BackgroundColor="{Binding BackgroundColor}"
                                    TextColor="{Binding TextColor}"
                                    BorderColor="{Binding BorderColor}"
                                    BorderWidth="1"
                                    CornerRadius="18"
                                    Padding="16,10"
                                    MinimumHeightRequest="40" />
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </HorizontalStackLayout>
            </ScrollView>
        </VerticalStackLayout>

        <CollectionView Grid.Row="1"
                        Margin="24,0,24,24"
                        ItemsSource="{Binding VisibleExercises}"
                        SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource CardBorder}"
                            BackgroundColor="{StaticResource SurfaceRaised}"
                            Margin="0,0,0,12"
                            Padding="16">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnExerciseTapped" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="10">
                            <VerticalStackLayout Grid.Column="0"
                                                 Spacing="6">
                                <Label Text="{Binding Name}"
                                       FontSize="18" />
                                <Label Text="{Binding HintText}"
                                       Style="{StaticResource BodyMuted}" />
                                <Label Text="{Binding DetailSummary}"
                                       Style="{StaticResource BodyMuted}"
                                       LineBreakMode="WordWrap"
                                       MaxLines="2" />
                            </VerticalStackLayout>

                            <Border Grid.Column="1"
                                    BackgroundColor="{StaticResource SurfaceRaised}"
                                    Stroke="{StaticResource BorderSubtle}"
                                    StrokeShape="RoundRectangle 18"
                                    Padding="10,6"
                                    VerticalOptions="Center">
                                <Label Text="{Binding ViewText, Source={x:Reference ThisPage}}"
                                       Style="{StaticResource BodyMuted}" />
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>

</ContentPage>
