<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FreakLete.ConfirmDialogPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource OverlayScrim}">

    <Grid Padding="24">
        <Border Style="{StaticResource CardBorder}"
                Padding="20"
                VerticalOptions="Center"
                HorizontalOptions="Center"
                MaximumWidthRequest="420"
                BackgroundColor="{StaticResource SurfaceRaised}">
            <VerticalStackLayout Spacing="14">
                <Label Text="CONFIRM ACTION"
                       Style="{StaticResource Eyebrow}" />

                <Label x:Name="TitleLabel"
                       Text="Delete Entry"
                       Style="{StaticResource SubHeadline}"
                       HorizontalTextAlignment="Start" />

                <Label x:Name="MessageLabel"
                       Text="Are you sure?"
                       Style="{StaticResource BodyMuted}"
                       LineBreakMode="WordWrap" />

                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="12"
                      Margin="0,8,0,0">
                    <Button Grid.Column="0"
                            x:Name="CancelButton"
                            Text="Cancel"
                            Style="{StaticResource SecondaryButton}"
                            Clicked="OnCancelClicked" />

                    <Button Grid.Column="1"
                            x:Name="ConfirmButton"
                            Text="Delete"
                            Clicked="OnConfirmClicked" />
                </Grid>
            </VerticalStackLayout>
        </Border>
    </Grid>

</ContentPage>
