<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Color x:Key="Primary">#8B5CF6</Color>
    <Color x:Key="PrimaryDark">#6D28D9</Color>
    <Color x:Key="PrimaryDarkText">#FFFFFF</Color>
    <Color x:Key="Secondary">#C4B5FD</Color>
    <Color x:Key="SecondaryDarkText">#EDE9FE</Color>
    <Color x:Key="Tertiary">#2B184B</Color>

    <Color x:Key="Background">#100D1A</Color>
    <Color x:Key="Surface">#171321</Color>
    <Color x:Key="SurfaceRaised">#1D1828</Color>
    <Color x:Key="SurfaceStrong">#251F33</Color>
    <Color x:Key="SurfaceBorder">#342D46</Color>
    <Color x:Key="BorderSubtle">#2A2437</Color>
    <Color x:Key="Accent">#8B5CF6</Color>
    <Color x:Key="AccentSoft">#2F2346</Color>
    <Color x:Key="AccentGlow">#A78BFA</Color>
    <Color x:Key="TextPrimary">#F7F7FB</Color>
    <Color x:Key="TextSecondary">#B3B2C5</Color>
    <Color x:Key="TextMuted">#8A889B</Color>
    <Color x:Key="OverlayScrim">#B3100D1A</Color>
    <Color x:Key="Success">#22C55E</Color>
    <Color x:Key="Danger">#DC2626</Color>
    <Color x:Key="DangerSoft">#3A1623</Color>
    <Color x:Key="EditSoft">#24203A</Color>
    <Color x:Key="TopBar">#161125</Color>
    <Color x:Key="Warning">#F59E0B</Color>
    <Color x:Key="SuccessSoft">#0D2818</Color>
    <Color x:Key="WarningSoft">#2A1F06</Color>
    <Color x:Key="InfoSoft">#0D1B2A</Color>
    <Color x:Key="Info">#3B82F6</Color>

    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#000000</Color>
    <Color x:Key="Magenta">#D600AA</Color>
    <Color x:Key="MidnightBlue">#190649</Color>
    <Color x:Key="OffBlack">#000000</Color>

    <Color x:Key="Gray100">#F1F1F5</Color>
    <Color x:Key="Gray200">#DDDCE7</Color>
    <Color x:Key="Gray300">#B3B2C5</Color>
    <Color x:Key="Gray400">#8A889B</Color>
    <Color x:Key="Gray500">#6A687A</Color>
    <Color x:Key="Gray600">#42404E</Color>
    <Color x:Key="Gray900">#141420</Color>
    <Color x:Key="Gray950">#0A0A12</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}" />
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}" />
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}" />
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}" />
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}" />
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource Background}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource Surface}" />
    <SolidColorBrush x:Key="SurfaceRaisedBrush" Color="{StaticResource SurfaceRaised}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource Danger}" />

    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}" />
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}" />
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}" />
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}" />
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}" />
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}" />
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}" />
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}" />
</ResourceDictionary>
