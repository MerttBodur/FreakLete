        <item name="colorPrimary">#161125</item>
        <item name="colorPrimaryVariant">#100D1A</item>
        <item name="colorSecondary">#8B5CF6</item>
        <item name="android:statusBarColor">#161125</item>
        <item name="android:navigationBarColor">#100D1A</item>
        <item name="android:windowBackground">#100D1A</item>
